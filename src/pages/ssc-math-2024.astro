---
import Base from '../layouts/Base.astro';
import QuestionCard from '../components/QuestionCard.svelte';

// Import all board data — add new boards by adding one line here
import dhaka     from '../data/ssc-2024-dhaka.json';
import rajshahi  from '../data/ssc-2024-rajshahi.json';
import chittagong from '../data/ssc-2024-chittagong.json';
import jessore   from '../data/ssc-2024-jessore.json';
import comilla   from '../data/ssc-2024-comilla.json';
import barisal   from '../data/ssc-2024-barisal.json';
import sylhet    from '../data/ssc-2024-sylhet.json';
import dinajpur  from '../data/ssc-2024-dinajpur.json';
import mymensingh from '../data/ssc-2024-mymensingh.json';

const boards = [dhaka, rajshahi, chittagong, jessore, comilla, barisal, sylhet, dinajpur, mymensingh];
const boardKeys = boards.map(b => b.label.toLowerCase());
---

<Base title="SSC Math 2024 — All Boards Solved" description="All 9 boards' SSC Math 2024 questions with full step-by-step solutions, bilingual, with interactive visualizations.">

<style>
  /* ── HERO ── */
  .hero { position:relative;z-index:1;padding:3rem 2rem 1.5rem;max-width:1100px;margin:0 auto; }
  .eyebrow { font-size:.62rem;letter-spacing:.18em;text-transform:uppercase;color:var(--amb);margin-bottom:.7rem; }
  .hero h1 { font-family:'Playfair Display',serif;font-size:clamp(1.5rem,3.5vw,2.4rem);font-weight:900;line-height:1.1;margin-bottom:.3rem; }
  .hero h1 em { font-style:italic;color:var(--teal); }
  .hero-sub { font-size:.76rem;color:var(--mut);margin-bottom:1.2rem; }
  .pills { display:flex;flex-wrap:wrap;gap:.4rem; }
  .pill { font-size:.6rem;letter-spacing:.08em;text-transform:uppercase;padding:.22rem .65rem;border-radius:2px;background:var(--surf);border:1px solid var(--bdr);color:var(--mut);cursor:pointer;transition:all .2s;user-select:none; }
  .pill:hover { background:var(--tdim);color:var(--teal);border-color:var(--tline); }

  /* ── BOARD BAR ── */
  .bbar {
    position:sticky;top:54px;z-index:200;
    background:rgba(13,15,20,.96);backdrop-filter:blur(12px);
    border-bottom:1px solid var(--bdr);
    display:flex;overflow-x:auto;
  }
  .btab {
    padding:.65rem 1rem;font-size:.65rem;font-weight:700;letter-spacing:.07em;text-transform:uppercase;
    color:var(--mut);cursor:pointer;white-space:nowrap;
    border:none;background:none;border-bottom:2px solid transparent;transition:all .2s;
    text-decoration:none;display:block;
  }
  .btab:hover { color:var(--txt2); }
  .btab.active { color:var(--teal);border-bottom-color:var(--teal); }

  /* ── MAIN ── */
  .main { position:relative;z-index:1;max-width:1100px;margin:0 auto;padding:0 1.5rem 5rem; }
  .board-section { display:none;padding-top:2rem; }
  .board-section.active { display:block; }
  .board-hdr { display:flex;align-items:center;gap:.8rem;margin-bottom:1.5rem; }
  .board-badge { font-size:.62rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--teal);background:var(--tdim);border:1px solid var(--tline);padding:.25rem .7rem;border-radius:2px; }
  .board-title { font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:700; }

  /* ── PART LABEL ── */
  .plabel { font-size:.62rem;letter-spacing:.15em;text-transform:uppercase;color:var(--mut);margin:1.5rem 0 .9rem;display:flex;align-items:center;gap:.6rem; }
  .plabel::after { content:'';flex:1;height:1px;background:var(--bdr); }

  /* ── PAPER IMAGE ── */
  .pblock { border:1px solid var(--bdr);border-radius:3px;overflow:hidden;margin-bottom:1.2rem; }
  .pbh { background:var(--surf);padding:.6rem 1rem;border-bottom:1px solid var(--bdr);display:flex;align-items:center;justify-content:space-between; }
  .pbh-t { font-size:.65rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--amb); }
  .pbh-n { font-size:.6rem;color:var(--mut); }
  .pimgs a { display:block; }
  .pimgs img { width:100%;display:block;border-bottom:1px solid var(--bdr);filter:brightness(.96)contrast(1.04);cursor:zoom-in; }
  .pimgs img:last-child { border-bottom:none; }

  /* ── SCROLL TOP ── */
  .stbtn { position:fixed;bottom:1.5rem;right:1.5rem;z-index:400;width:36px;height:36px;background:var(--surf);border:1px solid var(--bdr);color:var(--teal);display:flex;align-items:center;justify-content:center;border-radius:2px;text-decoration:none;opacity:0;transition:opacity .2s;font-size:.9rem; }

  @media (max-width:600px) {
    .hero { padding:2.5rem 1.2rem 1.5rem; }
    .main { padding-left:1rem;padding-right:1rem; }
  }
</style>

<!-- HERO -->
<section class="hero">
  <div class="eyebrow">SSC Board Exam · Mathematics · 2024 · All 9 Boards</div>
  <h1>All questions. <em>All solved.</em></h1>
  <p class="hero-sub">
    Real question papers · English translations · Step-by-step solutions with visualizations · 25 February 2024
  </p>
  <div class="pills" id="pills">
    <span class="pill" onclick="setFilter('all',this)">All Questions</span>
    <span class="pill" onclick="setFilter('mcq',this)">MCQ Only</span>
    <span class="pill" onclick="setFilter('cq',this)">Creative Only</span>
    <span class="pill" onclick="openAll()">Expand All</span>
    <span class="pill" onclick="closeAll()">Collapse All</span>
  </div>
</section>

<!-- BOARD TAB BAR -->
<div class="bbar" id="bbar">
  {boards.map((b, i) => (
    <a href={`#${b.label.toLowerCase()}`}
       class={`btab${i === 0 ? ' active' : ''}`}
       onclick={`switchBoard('${b.label.toLowerCase()}',this);return false;`}>
      {b.label}
    </a>
  ))}
</div>

<!-- MAIN CONTENT -->
<div class="main">
  {boards.map((board, bi) => (
    <div class={`board-section${bi === 0 ? ' active' : ''}`} id={`section-${board.label.toLowerCase()}`}>

      <!-- Board header -->
      <div class="board-hdr">
        <span class="board-badge">{board.label} Board</span>
        <span class="board-title">Mathematics 2024</span>
      </div>

      <!-- ── MCQ ── -->
      <div class="mcq-wrap">
        <div class="plabel">Part 1 — MCQ (বহুনির্বাচনি) · 30 marks · 30 min</div>

        <!-- Question paper image -->
        <div class="pblock">
          <div class="pbh">
            <span class="pbh-t">📄 Original Question Paper — {board.label} Board 2024</span>
            <span class="pbh-n">Click to open full size</span>
          </div>
          <div class="pimgs">
            {board.mcqImgs.map(img => (
              <a href={img} target="_blank" rel="noopener">
                <img src={img} loading="lazy" alt={`${board.label} Board SSC Math MCQ 2024`} />
              </a>
            ))}
          </div>
        </div>

        <!-- MCQ question cards — each is a Svelte island -->
        {board.mcq.map(q => (
          <QuestionCard client:visible q={q} boardKey={board.label.toLowerCase()} type="mcq" />
        ))}
      </div>

      <!-- ── CQ ── -->
      <div class="cq-wrap" style="margin-top:2.5rem;">
        <div class="plabel">Part 2 — Creative Questions (সৃজনশীল) · 70 marks · Answer any 5 of 7</div>

        <!-- CQ paper images -->
        <div class="pblock">
          <div class="pbh">
            <span class="pbh-t">📄 Creative Question Paper — {board.label} Board 2024</span>
            <span class="pbh-n">10 marks each · ক=2 · খ=4 · গ=4</span>
          </div>
          <div class="pimgs">
            {board.cqImgs.map(img => (
              <a href={img} target="_blank" rel="noopener">
                <img src={img} loading="lazy" alt={`${board.label} Board SSC Math CQ 2024`} />
              </a>
            ))}
          </div>
        </div>

        <!-- CQ question cards -->
        {board.cq.map(q => (
          <QuestionCard client:visible q={q} boardKey={board.label.toLowerCase()} type="cq" />
        ))}
      </div>

    </div>
  ))}
</div>

<a class="stbtn" id="stbtn" href="#top">↑</a>

<script is:inline>
  // ── BOARD SWITCHING ──────────────────────────────────────────────────
  function switchBoard(key, el) {
    document.querySelectorAll('.board-section').forEach(s => s.classList.remove('active'));
    document.querySelectorAll('.btab').forEach(t => t.classList.remove('active'));
    const section = document.getElementById('section-' + key);
    if (section) section.classList.add('active');
    if (el) el.classList.add('active');
    window.scrollTo({ top: 0, behavior: 'smooth' });
    // Re-typeset MathJax for newly visible section
    if (window.MathJax?.typesetPromise) MathJax.typesetPromise([section]);
  }

  // ── FILTER ───────────────────────────────────────────────────────────
  let currentFilter = 'all';
  function setFilter(type, el) {
    currentFilter = type;
    document.querySelectorAll('#pills .pill').forEach(p => p.style.background = '');
    if (el) { el.style.background = 'var(--tdim)'; el.style.color = 'var(--teal)'; }
    document.querySelectorAll('.mcq-wrap').forEach(w => {
      w.style.display = type === 'cq' ? 'none' : '';
    });
    document.querySelectorAll('.cq-wrap').forEach(w => {
      w.style.display = type === 'mcq' ? 'none' : '';
    });
  }

  // ── EXPAND / COLLAPSE ────────────────────────────────────────────────
  function openAll() {
    // Trigger click on all collapsed headers in active section
    const active = document.querySelector('.board-section.active');
    if (!active) return;
    active.querySelectorAll('.qcard:not(.open) .qhdr').forEach(h => h.click());
  }
  function closeAll() {
    const active = document.querySelector('.board-section.active');
    if (!active) return;
    active.querySelectorAll('.qcard.open .qhdr').forEach(h => h.click());
  }

  // ── SCROLL TOP ───────────────────────────────────────────────────────
  window.addEventListener('scroll', () => {
    const btn = document.getElementById('stbtn');
    if (btn) btn.style.opacity = window.scrollY > 400 ? '1' : '0';
  });

  // ── MATHJAX INIT ─────────────────────────────────────────────────────
  document.addEventListener('DOMContentLoaded', () => {
    if (window.MathJax?.typesetPromise) {
      MathJax.typesetPromise();
    }
  });
</script>

</Base>
