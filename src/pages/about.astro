---
import Main from '../layouts/Main.astro';
---
<Main title="About" description="About Mathify.us — free educational resources for Mathematics, Physics, Civil Engineering, and SSC Board exams." activeNav="">

<style>
  .about-wrap {
    max-width: 760px;
    margin: 0 auto;
    padding: 4rem 2rem 5rem;
  }
  .eyebrow {
    font-size: .62rem;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--amb);
    margin-bottom: .7rem;
    font-family: 'Space Mono', monospace;
  }
  .about-wrap h1 {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 700;
    margin-bottom: 1rem;
    line-height: 1.2;
  }
  .lead {
    font-size: 1rem;
    color: var(--txt2);
    line-height: 1.75;
    margin-bottom: 2.5rem;
    border-left: 3px solid var(--teal);
    padding-left: 1rem;
  }
  .section { margin-bottom: 2.5rem; }
  .section h2 {
    font-size: .7rem;
    font-family: 'Space Mono', monospace;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: .8rem;
  }
  .section p {
    font-size: .88rem;
    color: var(--txt2);
    line-height: 1.75;
    margin-bottom: .6rem;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: .8rem;
    margin-top: .8rem;
  }
  .card {
    background: var(--surf);
    border: 1px solid var(--bdr);
    border-radius: 6px;
    padding: 1.1rem 1.2rem;
  }
  .card-icon { font-size: 1.4rem; margin-bottom: .4rem; display: block; }
  .card h3 { font-size: .82rem; font-weight: 700; margin-bottom: .25rem; }
  .card p { font-size: .72rem; color: var(--mut); line-height: 1.5; margin: 0; }
  .contact-row {
    display: flex;
    align-items: center;
    gap: .6rem;
    margin-top: .5rem;
    font-size: .84rem;
    color: var(--txt2);
  }
  .contact-row a {
    color: var(--teal);
    text-decoration: none;
  }
  .contact-row a:hover { text-decoration: underline; }
  .divider {
    border: none;
    border-top: 1px solid var(--bdr);
    margin: 2.5rem 0;
  }
  @media (max-width: 600px) {
    .about-wrap { padding: 2.5rem 1.2rem 4rem; }
  }
</style>

<div class="about-wrap">
  <div class="eyebrow">About Mathify</div>
  <h1>Free education for everyone.</h1>
  <p class="lead">
    Mathify.us is a free, open educational platform built for students in Bangladesh and beyond.
    No ads, no paywalls — just clear explanations, step-by-step solutions, and interactive tools.
  </p>

  <div class="section">
    <h2>What We Cover</h2>
    <div class="grid">
      <div class="card">
        <span class="card-icon">📐</span>
        <h3>Mathematics</h3>
        <p>Class 9–12 curriculum with worked examples and visual explanations.</p>
      </div>
      <div class="card">
        <span class="card-icon">⚡</span>
        <h3>Physics</h3>
        <p>Class 11–12 topics with interactive simulations and problem walkthroughs.</p>
      </div>
      <div class="card">
        <span class="card-icon">🏗️</span>
        <h3>Civil Engineering</h3>
        <p>RC Design and Traffic Engineering guides aligned with Darwin, Dolan &amp; Nilson 15th Ed.</p>
      </div>
      <div class="card">
        <span class="card-icon">📋</span>
        <h3>SSC Board Exams</h3>
        <p>Full past-paper solutions for all 9 boards, 2020–2025, bilingual (English &amp; Bengali).</p>
      </div>
    </div>
  </div>

  <hr class="divider" />

  <div class="section">
    <h2>Our Mission</h2>
    <p>
      Quality education should not depend on where you live or what you can afford.
      We build free, intuition-first resources that help students genuinely understand concepts —
      not just memorize answers.
    </p>
    <p>
      Every page on Mathify is designed to explain the <em>why</em> behind each formula and method,
      with diagrams, worked problems, and interactive tools where possible.
    </p>
  </div>

  <div class="section">
    <h2>Contact</h2>
    <p>Questions, corrections, or contributions? Reach out:</p>
    <div class="contact-row">
      ✉️ <a href="mailto:hello@mathify.us">hello@mathify.us</a>
    </div>
    <div class="contact-row" style="margin-top:.4rem;">
      🌐 <a href="https://mathify.us">mathify.us</a>
    </div>
  </div>
</div>

</Main>
