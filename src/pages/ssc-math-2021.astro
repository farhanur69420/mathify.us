import chittagong from '../data/ssc-2021-chittagong.json';
import jessore   from '../data/ssc-2021-jessore.json';
import comilla   from '../data/ssc-2021-comilla.json';
import barisal   from '../data/ssc-2021-barisal.json';
import sylhet    from '../data/ssc-2021-sylhet.json';
import dinajpur  from '../data/ssc-2021-dinajpur.json';
