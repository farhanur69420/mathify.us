---
import Main from '../layouts/Main.astro';
import '../styles/roulette-calculator.css';
---
<Main title="Roulette Calculator" description="European Roulette betting calculator with smart bet suggestions and Martingale strategy engine">

<div class="rc-container">

  <!-- ── SETUP PANEL ── -->
  <div class="rc-setup" id="setupPanel">
    <div class="rc-panel">
      <h1 class="rc-page-title">Roulette Calculator</h1>
      <p class="rc-subtitle">European Roulette &middot; Adaptive AI Engine &middot; Multi-Window Analysis</p>

      <div class="rc-input-group">
        <label for="startBalance">Starting Balance</label>
        <input type="number" id="startBalance" class="rc-input" placeholder="Enter amount" min="10" step="1" />
      </div>

      <button class="rc-btn rc-btn-gold" id="startBtn" disabled>Start Session</button>
    </div>

    <!-- Previous Numbers -->
    <div class="rc-panel" style="text-align:left;">
      <div class="rc-panel-title">Load Previous Results (Optional)</div>
      <input type="text" id="prevNumbers" class="rc-previous-input"
        placeholder="e.g. 14, 0, 32, 7, 19, 25, 3..." />
      <p class="rc-helper-text">Enter previously landed numbers (0-36) separated by commas for better initial predictions.</p>
      <div class="rc-loaded-chips" id="prevChips"></div>
      <div class="rc-prev-actions">
        <button class="rc-btn rc-btn-outline rc-btn-small" id="loadPrevBtn">Load Numbers</button>
        <button class="rc-btn rc-btn-outline rc-btn-small" id="clearPrevBtn" style="display:none;">Clear</button>
      </div>
    </div>
  </div>

  <!-- ── GAME AREA ── -->
  <div class="rc-game" id="gameArea">

    <!-- Tier & Momentum Banner -->
    <div class="rc-tier-banner" id="tierBanner">
      <div class="rc-tier-left">
        <span class="rc-tier-badge" id="tierBadge">CONSERVATIVE</span>
        <span class="rc-tier-label">Risk Tier</span>
      </div>
      <div class="rc-tier-right">
        <div class="rc-momentum-bar">
          <div class="rc-momentum-fill" id="momentumFill"></div>
          <div class="rc-momentum-center"></div>
        </div>
        <span class="rc-momentum-label" id="momentumLabel">Momentum: 0</span>
      </div>
    </div>

    <!-- Balance & Progress -->
    <div class="rc-panel rc-balance-section">
      <div class="rc-balance-label">Current Balance</div>
      <div class="rc-balance-value" id="balanceDisplay">0</div>
      <div class="rc-progress-wrap">
        <div class="rc-progress-labels">
          <span id="stopLossLabel">Stop: 0</span>
          <span id="targetLabel">Target: 0</span>
        </div>
        <div class="rc-progress-bar">
          <div class="rc-progress-fill" id="progressFill" style="width:0%"></div>
          <div class="rc-progress-marker" id="stopLossMarker" style="left:0%"></div>
        </div>
      </div>
    </div>

    <!-- Number History Strip -->
    <div class="rc-panel">
      <div class="rc-panel-title">Last 15 Numbers</div>
      <div class="rc-history-strip" id="historyStrip">
        <div class="rc-empty">No results yet &mdash; enter a spin result below</div>
      </div>
    </div>

    <!-- Two Column: Bet Slip + Result Input -->
    <div class="rc-two-col">

      <!-- Bet Slip -->
      <div class="rc-panel">
        <div class="rc-panel-title">Suggested Bets</div>
        <div id="betSlipContent">
          <div class="rc-no-bet-msg">Suggestions will appear after first spin or with loaded history.</div>
        </div>
        <div class="rc-bet-total" id="betTotal" style="display:none;">
          Total Bet: <strong id="betTotalAmount">0</strong>
        </div>
      </div>

      <!-- Result Input -->
      <div class="rc-panel">
        <div class="rc-panel-title">Spin Result</div>
        <div class="rc-number-grid" id="numberGrid"></div>
        <div style="text-align:center;">
          <button class="rc-btn rc-btn-gold" id="confirmResultBtn" disabled>
            Confirm Result
          </button>
        </div>
        <div class="rc-result-display" id="resultDisplay">
          <div class="rc-result-text" id="resultText"></div>
        </div>
      </div>
    </div>

    <!-- Session Stats -->
    <div class="rc-panel">
      <div class="rc-panel-title">Session Statistics</div>
      <div class="rc-stats-grid rc-stats-grid-9">
        <div class="rc-stat">
          <div class="rc-stat-value" id="statWinRate">0%</div>
          <div class="rc-stat-label">Win Rate</div>
        </div>
        <div class="rc-stat">
          <div class="rc-stat-value" id="statSpins">0</div>
          <div class="rc-stat-label">Total Spins</div>
        </div>
        <div class="rc-stat">
          <div class="rc-stat-value" id="statStreak">0</div>
          <div class="rc-stat-label">Current Streak</div>
        </div>
        <div class="rc-stat">
          <div class="rc-stat-value" id="statBestStreak">0</div>
          <div class="rc-stat-label">Best Streak</div>
        </div>
        <div class="rc-stat">
          <div class="rc-stat-value" id="statBiggestWin">0</div>
          <div class="rc-stat-label">Biggest Win</div>
        </div>
        <div class="rc-stat">
          <div class="rc-stat-value" id="statROI">0%</div>
          <div class="rc-stat-label">ROI</div>
        </div>
        <div class="rc-stat">
          <div class="rc-stat-value" id="statPeak">0</div>
          <div class="rc-stat-label">Peak</div>
        </div>
        <div class="rc-stat">
          <div class="rc-stat-value" id="statValley">0</div>
          <div class="rc-stat-label">Valley</div>
        </div>
        <div class="rc-stat">
          <div class="rc-stat-value" id="statCoverage">0%</div>
          <div class="rc-stat-label">Coverage</div>
        </div>
      </div>
    </div>

    <!-- Reset -->
    <div class="rc-reset-row">
      <button class="rc-btn rc-btn-outline rc-btn-small" id="resetBtn">Reset Session</button>
    </div>
  </div>

</div>

<!-- Overlays -->
<div class="rc-warning-flash" id="warningFlash"></div>

<div class="rc-overlay stop-loss" id="stopLossOverlay">
  <div class="rc-overlay-title">Session Stopped</div>
  <div class="rc-overlay-sub">You've hit the stop-loss threshold (50% of starting balance). Consider taking a break.</div>
  <div style="display:flex;gap:.6rem;flex-wrap:wrap;justify-content:center;">
    <button class="rc-btn rc-btn-gold" id="stopLossReset">New Session</button>
    <button class="rc-btn rc-btn-outline" id="stopLossResume">Continue Anyway</button>
  </div>
</div>

<div class="rc-overlay celebration" id="celebrationOverlay">
  <div class="rc-overlay-title">&#127881; Target Reached!</div>
  <div class="rc-overlay-sub" id="celebrationMsg">Congratulations!</div>
  <div style="display:flex;gap:.6rem;flex-wrap:wrap;justify-content:center;">
    <button class="rc-btn rc-btn-gold" id="celebrationReset">New Session</button>
    <button class="rc-btn rc-btn-outline" id="celebrationContinue">Keep Going</button>
  </div>
</div>

<div class="rc-confetti" id="confettiContainer"></div>

</Main>

<script is:inline src="/scripts/roulette-engine.js"></script>

<script is:inline>
(function() {
  'use strict';

  var RE = window.RouletteEngine;
  var selectedNumber = null;
  var currentBets = [];

  // ── DOM REFS ──
  var $ = function(id) { return document.getElementById(id); };
  var startBalanceInput = $('startBalance');
  var startBtn = $('startBtn');
  var setupPanel = $('setupPanel');
  var gameArea = $('gameArea');
  var prevInput = $('prevNumbers');
  var prevChips = $('prevChips');
  var loadPrevBtn = $('loadPrevBtn');
  var clearPrevBtn = $('clearPrevBtn');
  var balanceDisplay = $('balanceDisplay');
  var progressFill = $('progressFill');
  var stopLossMarker = $('stopLossMarker');
  var stopLossLabel = $('stopLossLabel');
  var targetLabel = $('targetLabel');
  var historyStrip = $('historyStrip');
  var betSlipContent = $('betSlipContent');
  var betTotal = $('betTotal');
  var betTotalAmount = $('betTotalAmount');
  var numberGrid = $('numberGrid');
  var confirmResultBtn = $('confirmResultBtn');
  var resultDisplay = $('resultDisplay');
  var resultText = $('resultText');
  var tierBanner = $('tierBanner');
  var tierBadge = $('tierBadge');
  var momentumFill = $('momentumFill');
  var momentumLabel = $('momentumLabel');
  var warningFlash = $('warningFlash');
  var stopLossOverlay = $('stopLossOverlay');
  var celebrationOverlay = $('celebrationOverlay');
  var confettiContainer = $('confettiContainer');

  // ── INIT ──

  startBalanceInput.addEventListener('input', function() {
    var val = parseInt(this.value, 10);
    startBtn.disabled = !(val >= 10);
  });

  startBtn.addEventListener('click', function() {
    var balance = parseInt(startBalanceInput.value, 10);
    if (balance < 10) return;
    RE.initGame(balance);
    setupPanel.classList.add('collapsed');
    gameArea.classList.add('active');
    updateUI();
    refreshSuggestions();
  });

  // ── PREVIOUS NUMBERS ──

  loadPrevBtn.addEventListener('click', function() {
    var raw = prevInput.value.split(/[,\s]+/).filter(function(s) { return s.length > 0; });
    var nums = [];
    for (var i = 0; i < raw.length; i++) {
      var n = parseInt(raw[i], 10);
      if (!isNaN(n) && n >= 0 && n <= 36) nums.push(n);
    }
    if (nums.length === 0) return;
    RE.addPreviousNumbers(nums);
    renderPrevChips(nums);
    clearPrevBtn.style.display = 'inline-block';
    prevInput.value = '';
  });

  clearPrevBtn.addEventListener('click', function() {
    prevChips.innerHTML = '';
    clearPrevBtn.style.display = 'none';
  });

  function renderPrevChips(nums) {
    prevChips.innerHTML = '';
    for (var i = 0; i < nums.length; i++) {
      var chip = document.createElement('span');
      chip.className = 'rc-chip rc-chip-small ' + RE.getColor(nums[i]);
      chip.textContent = nums[i];
      prevChips.appendChild(chip);
    }
  }

  // ── NUMBER GRID ──

  function buildNumberGrid() {
    // Zero button
    var zeroBtn = document.createElement('button');
    zeroBtn.className = 'rc-grid-btn green rc-zero-btn';
    zeroBtn.textContent = '0';
    zeroBtn.dataset.num = '0';
    numberGrid.appendChild(zeroBtn);

    // Numbers 1-36
    for (var i = 1; i <= 36; i++) {
      var btn = document.createElement('button');
      btn.className = 'rc-grid-btn ' + RE.getColor(i);
      btn.textContent = i;
      btn.dataset.num = String(i);
      numberGrid.appendChild(btn);
    }

    numberGrid.addEventListener('click', function(e) {
      var btn = e.target.closest('.rc-grid-btn');
      if (!btn) return;
      // Deselect previous
      var prev = numberGrid.querySelector('.selected');
      if (prev) prev.classList.remove('selected');
      btn.classList.add('selected');
      selectedNumber = parseInt(btn.dataset.num, 10);
      confirmResultBtn.disabled = false;
    });
  }
  buildNumberGrid();

  // ── CONFIRM RESULT ──

  confirmResultBtn.addEventListener('click', function() {
    if (selectedNumber === null) return;
    if (currentBets.length === 0) {
      // No bets placed, just record the number
      RE.addPreviousNumbers([selectedNumber]);
      selectedNumber = null;
      var sel = numberGrid.querySelector('.selected');
      if (sel) sel.classList.remove('selected');
      confirmResultBtn.disabled = true;
      updateUI();
      refreshSuggestions();
      return;
    }

    var result = RE.resolveResult(selectedNumber, currentBets);
    showResult(result);
    selectedNumber = null;
    var sel2 = numberGrid.querySelector('.selected');
    if (sel2) sel2.classList.remove('selected');
    confirmResultBtn.disabled = true;

    updateUI();

    // Check overlays
    if (result.stopped) {
      if (result.stopReason === 'stop-loss') {
        stopLossOverlay.classList.add('active');
      } else if (result.stopReason === 'target') {
        celebrationOverlay.classList.add('active');
        launchConfetti();
        var msg = $('celebrationMsg');
        msg.textContent = 'You turned ' + RE.getState().startingBalance + ' into ' + result.balance + '!';
      }
    } else {
      // Warning flash if near stop-loss (within 30%)
      var st = RE.getState();
      var stopLossThreshold = st.startingBalance * 0.5;
      var warnZone = stopLossThreshold + (st.startingBalance * 0.15);
      if (result.balance <= warnZone && result.balance > stopLossThreshold) {
        warningFlash.classList.add('active');
        setTimeout(function() { warningFlash.classList.remove('active'); }, 1000);
      }
    }

    if (!result.stopped) {
      refreshSuggestions();
    }
  });

  // ── SHOW RESULT ──

  function showResult(result) {
    resultDisplay.classList.add('visible');
    resultDisplay.classList.remove('win', 'loss');

    if (result.anyWin) {
      resultDisplay.classList.add('win');
      var winDetails = result.results.filter(function(r) { return r.won; })
        .map(function(r) { return r.bet + ' +' + r.profit; }).join(', ');
      resultText.textContent = 'WIN! ' + winDetails + ' | Net: +' + result.netProfit;
    } else {
      resultDisplay.classList.add('loss');
      resultText.textContent = 'LOSS | -' + Math.abs(result.netProfit);
    }

    setTimeout(function() {
      resultDisplay.classList.remove('visible');
    }, 4000);
  }

  // ── UPDATE UI ──

  function updateUI() {
    var st = RE.getState();

    // Balance
    animateBalance(st.balance);

    // Balance color
    if (st.balance > st.startingBalance) {
      balanceDisplay.classList.add('winning');
      balanceDisplay.classList.remove('losing');
    } else if (st.balance < st.startingBalance) {
      balanceDisplay.classList.add('losing');
      balanceDisplay.classList.remove('winning');
    } else {
      balanceDisplay.classList.remove('winning', 'losing');
    }

    // Progress bar
    var stopLoss = Math.round(st.startingBalance * 0.5);
    var target = st.startingBalance * 5;
    stopLossLabel.textContent = 'Stop: ' + stopLoss;
    targetLabel.textContent = 'Target: ' + target;

    // Progress: map balance from 0 to target
    var pct = Math.max(0, Math.min(100, ((st.balance) / target) * 100));
    progressFill.style.width = pct + '%';

    // Stop-loss marker position
    var stopPct = (stopLoss / target) * 100;
    stopLossMarker.style.left = stopPct + '%';

    // History strip
    renderHistory();

    // Tier banner
    var tier = st.tier;
    tierBadge.textContent = tier.name;
    tierBadge.style.background = tier.color;
    tierBadge.style.color = '#fff';

    // Momentum bar
    var mom = st.momentum || 0;
    var momPct = 50 + mom * 50; // -1=0%, 0=50%, +1=100%
    momentumFill.style.width = momPct + '%';
    momentumFill.style.background = mom > 0.2 ? 'var(--rc-green)' : mom < -0.2 ? 'var(--warn)' : 'var(--gold)';
    momentumLabel.textContent = 'Momentum: ' + (mom >= 0 ? '+' : '') + mom.toFixed(2);

    // Stats
    var stats = RE.getSessionStats();
    $('statWinRate').textContent = stats.winRate + '%';
    $('statSpins').textContent = stats.totalSpins;
    $('statStreak').textContent = (stats.currentStreak > 0 ? '+' : '') + stats.currentStreak;
    $('statBestStreak').textContent = '+' + stats.bestStreak;
    $('statBiggestWin').textContent = stats.biggestWin;
    $('statROI').textContent = (stats.roi >= 0 ? '+' : '') + stats.roi + '%';
    $('statPeak').textContent = stats.peakBalance;
    $('statValley').textContent = stats.valleyBalance;
    $('statCoverage').textContent = stats.coverage + '%';

    // Color streak
    var streakEl = $('statStreak');
    streakEl.style.color = stats.currentStreak > 0 ? 'var(--rc-green)' :
      stats.currentStreak < 0 ? 'var(--warn)' : 'var(--cream)';

    var roiEl = $('statROI');
    roiEl.style.color = stats.roi > 0 ? 'var(--rc-green)' :
      stats.roi < 0 ? 'var(--warn)' : 'var(--cream)';
  }

  // ── ANIMATE BALANCE ──

  var currentDisplayBalance = 0;
  function animateBalance(target) {
    var start = currentDisplayBalance;
    var diff = target - start;
    if (diff === 0) { balanceDisplay.textContent = target; return; }
    var duration = 500;
    var startTime = performance.now();

    function tick(now) {
      var elapsed = now - startTime;
      var progress = Math.min(elapsed / duration, 1);
      // Ease out
      var eased = 1 - Math.pow(1 - progress, 3);
      var current = Math.round(start + diff * eased);
      balanceDisplay.textContent = current;
      if (progress < 1) {
        requestAnimationFrame(tick);
      } else {
        currentDisplayBalance = target;
      }
    }
    requestAnimationFrame(tick);
  }

  // ── RENDER HISTORY ──

  function renderHistory() {
    var recent = RE.getRecentHistory();
    if (recent.length === 0) {
      historyStrip.innerHTML = '<div class="rc-empty">No results yet</div>';
      return;
    }
    historyStrip.innerHTML = '';
    for (var i = 0; i < recent.length; i++) {
      var chip = document.createElement('span');
      chip.className = 'rc-chip ' + RE.getColor(recent[i]);
      if (i === recent.length - 1) chip.classList.add('rc-chip-new');
      chip.textContent = recent[i];
      historyStrip.appendChild(chip);
    }
    // Scroll to end
    historyStrip.scrollLeft = historyStrip.scrollWidth;
  }

  // ── REFRESH SUGGESTIONS ──

  function refreshSuggestions() {
    var recent = RE.getRecentHistory();
    if (recent.length < 1) {
      betSlipContent.innerHTML = '<div class="rc-no-bet-msg">Enter at least one number to get suggestions.</div>';
      betTotal.style.display = 'none';
      currentBets = [];
      return;
    }

    var suggestions = RE.generateSuggestions();
    currentBets = suggestions.map(function(s) {
      return { bet: s.bet, betKey: s.betKey, amount: s.amount, payout: s.payout };
    });

    betSlipContent.innerHTML = '';
    var totalAmt = 0;

    for (var i = 0; i < suggestions.length; i++) {
      var s = suggestions[i];
      totalAmt += s.amount;

      var card = document.createElement('div');
      card.className = 'rc-betslip-card';
      card.innerHTML =
        '<div class="rc-bet-header">' +
          '<span class="rc-bet-type">' + s.bet + '</span>' +
          '<span class="rc-bet-confidence">' + s.confidence + '% conf</span>' +
        '</div>' +
        '<div class="rc-bet-amount">' + s.amount + '</div>' +
        '<div class="rc-bet-meta">' +
          '<span class="rc-meta-item">Prob: ' + (s.probability || '—') + '</span>' +
          '<span class="rc-meta-item">Coverage: ' + (s.coverage || 0) + '%</span>' +
          '<span class="rc-meta-item rc-meta-tier" style="color:' + (RE.getState().tier.color || '#c9a84c') + '">' + (s.tier || '') + '</span>' +
        '</div>' +
        '<div class="rc-bet-reasoning">' + s.reasoning + '</div>' +
        '<div class="rc-bet-actions">' +
          '<button class="rc-btn rc-btn-gold rc-btn-small rc-accept-btn" data-idx="' + i + '">Accept</button>' +
          '<button class="rc-btn rc-btn-outline rc-btn-small rc-override-btn" data-idx="' + i + '">Override</button>' +
          '<input type="number" class="rc-override-input" data-idx="' + i + '" min="1" placeholder="Amount" />' +
        '</div>';
      betSlipContent.appendChild(card);
    }

    // Event delegation for accept/override
    betSlipContent.addEventListener('click', handleBetActions);

    betTotal.style.display = 'block';
    betTotalAmount.textContent = totalAmt;
  }

  function handleBetActions(e) {
    var target = e.target;
    if (target.classList.contains('rc-accept-btn')) {
      target.textContent = 'Accepted';
      target.disabled = true;
      target.style.opacity = '.6';
    } else if (target.classList.contains('rc-override-btn')) {
      var idx = target.dataset.idx;
      var input = betSlipContent.querySelector('.rc-override-input[data-idx="' + idx + '"]');
      if (input) {
        input.classList.toggle('visible');
        if (input.classList.contains('visible')) {
          input.focus();
          input.addEventListener('change', function() {
            var newAmt = parseInt(this.value, 10);
            if (!isNaN(newAmt) && newAmt >= 1 && currentBets[idx]) {
              currentBets[idx].amount = newAmt;
              // Update displayed amount
              var card = this.closest('.rc-betslip-card');
              if (card) card.querySelector('.rc-bet-amount').textContent = newAmt;
              // Update total
              var total = 0;
              for (var b = 0; b < currentBets.length; b++) total += currentBets[b].amount;
              betTotalAmount.textContent = total;
            }
          });
        }
      }
    }
  }

  // ── OVERLAYS ──

  $('stopLossReset').addEventListener('click', function() {
    stopLossOverlay.classList.remove('active');
    resetSession();
  });
  $('stopLossResume').addEventListener('click', function() {
    stopLossOverlay.classList.remove('active');
    RE.forceResume();
    refreshSuggestions();
  });
  $('celebrationReset').addEventListener('click', function() {
    celebrationOverlay.classList.remove('active');
    confettiContainer.classList.remove('active');
    confettiContainer.innerHTML = '';
    resetSession();
  });
  $('celebrationContinue').addEventListener('click', function() {
    celebrationOverlay.classList.remove('active');
    confettiContainer.classList.remove('active');
    confettiContainer.innerHTML = '';
    RE.forceResume();
    refreshSuggestions();
  });

  // ── CONFETTI ──

  function launchConfetti() {
    confettiContainer.classList.add('active');
    confettiContainer.innerHTML = '';
    var colors = ['#c9a84c', '#f1c40f', '#e74c3c', '#27ae60', '#fff', '#c0392b'];
    for (var i = 0; i < 60; i++) {
      var piece = document.createElement('div');
      piece.className = 'rc-confetti-piece';
      piece.style.left = Math.random() * 100 + '%';
      piece.style.background = colors[Math.floor(Math.random() * colors.length)];
      piece.style.animationDelay = (Math.random() * 1.5) + 's';
      piece.style.animationDuration = (2 + Math.random() * 2) + 's';
      piece.style.width = (5 + Math.random() * 8) + 'px';
      piece.style.height = (5 + Math.random() * 8) + 'px';
      confettiContainer.appendChild(piece);
    }
    setTimeout(function() {
      confettiContainer.classList.remove('active');
      confettiContainer.innerHTML = '';
    }, 5000);
  }

  // ── RESET ──

  $('resetBtn').addEventListener('click', function() {
    if (confirm('Reset the current session?')) resetSession();
  });

  function resetSession() {
    gameArea.classList.remove('active');
    setupPanel.classList.remove('collapsed');
    startBalanceInput.value = '';
    startBtn.disabled = true;
    selectedNumber = null;
    currentBets = [];
    currentDisplayBalance = 0;
    var sel = numberGrid.querySelector('.selected');
    if (sel) sel.classList.remove('selected');
    confirmResultBtn.disabled = true;
    resultDisplay.classList.remove('visible', 'win', 'loss');
    tierBadge.textContent = 'CONSERVATIVE';
    tierBadge.style.background = '#27ae60';
    momentumFill.style.width = '50%';
    momentumLabel.textContent = 'Momentum: 0';
    betSlipContent.innerHTML = '<div class="rc-no-bet-msg">Suggestions will appear after first spin or with loaded history.</div>';
    betTotal.style.display = 'none';
    historyStrip.innerHTML = '<div class="rc-empty">No results yet</div>';
    prevChips.innerHTML = '';
    clearPrevBtn.style.display = 'none';
  }

})();
</script>

<style>
  /* Override Main layout background for casino feel */
  :global(body) {
    background: #071a10 !important;
  }
</style>
