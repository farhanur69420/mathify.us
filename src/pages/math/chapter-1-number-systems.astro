---
import Main from '../../layouts/Main.astro';
---
<Main title="Chapter 1 — Number Systems | Mathematics" description="Master number systems: natural, whole, integer, rational, irrational, and real numbers." activeNav="math">

<style is:global>
  /* ═══ TOKENS ═══ */
  :root {
    --bg-page: #080810;
    --bg2-page: #0f0f1a;
    --bg3-page: #181826;
    --card-page: #111120;
    --card2-page: #1a1a2e;
    --border-page: #252538;
    --border2-page: #303050;
    --text-page: #e4e4f0;
    --text2-page: #8888aa;
    --text3-page: #4a4a6a;
    --accent-page: #7c6aff;
    --acc2-page: #ff6a9a;
    --acc3-page: #5dffa8;
    --acc4-page: #ffaa5a;
    --yellow-page: #ffd75a;
    --r-page: 14px;
    --rs-page: 8px;
  }

  .chapter-body {
    font-family: 'Lora', Georgia, serif;
    background: var(--bg-page); color: var(--text-page);
    line-height: 1.8; font-size: 16.5px;
  }

  /* ═══ HEADER ═══ */
  .progress-bar { position:fixed; top:52px; left:0; right:0; z-index:199; height:2px; background:var(--border-page); }
  .progress-fill { height:100%; width:0%; background:linear-gradient(90deg,var(--accent-page),var(--acc2-page)); transition:width .1s; }
  
  /* ═══ LAYOUT ═══ */
  .hero { max-width:860px; margin:0 auto; padding:80px 24px 56px; }
  .content { max-width:860px; margin:0 auto; padding:0 24px; }
  
  /* ═══ HERO ═══ */
  .chapter-tag {
    display:inline-flex; align-items:center; gap:8px;
    background:var(--bg3-page); border:1px solid var(--border-page);
    border-radius:20px; padding:4px 14px; margin-bottom:28px;
    font-family:'Space Mono',monospace; font-size:11px; color:var(--text2-page);
  }
  .chapter-tag em { color:var(--accent-page); font-style:normal; }
  .hero h1 {
    font-family:'Syne',sans-serif; font-size:clamp(38px,7vw,72px);
    font-weight:800; line-height:1.05; letter-spacing:-.025em; margin-bottom:22px;
  }
  .hero h1 span { color:var(--accent-page); }
  .hero-sub { font-size:18px; color:var(--text2-page); max-width:560px; margin-bottom:40px; line-height:1.65; }
  .hero-pills { display:flex; gap:12px; flex-wrap:wrap; }
  .pill {
    background:var(--card-page); border:1px solid var(--border-page);
    border-radius:8px; padding:8px 16px;
    font-family:'Space Mono',monospace; font-size:11px; color:var(--text2-page);
    display:flex; align-items:center; gap:8px;
  }
  .pill strong { color:var(--acc3-page); font-size:15px; }
  
  /* ═══ TOC ═══ */
  .toc-wrap { max-width:860px; margin:0 auto 56px; padding:0 24px; }
  .toc {
    background:var(--card-page); border:1px solid var(--border-page);
    border-radius:var(--r-page); padding:28px 32px;
  }
  .toc-title { font-family:'Space Mono',monospace; font-size:10px; color:var(--text3-page); text-transform:uppercase; letter-spacing:.1em; margin-bottom:20px; }
  .toc-grid { display:grid; grid-template-columns:repeat(auto-fit, minmax(200px, 1fr)); gap:4px; }
  .toc-link {
    display:flex; align-items:center; gap:10px;
    padding:8px 12px; border-radius:var(--rs-page);
    font-family:'Space Mono',monospace; font-size:12px;
    color:var(--text2-page); text-decoration:none; transition:.2s;
  }
  .toc-link:hover { background:var(--bg3-page); color:var(--text-page); }
  .toc-n { width:22px; height:22px; border-radius:50%; background:var(--bg3-page); display:flex; align-items:center; justify-content:center; font-size:10px; color:var(--accent-page); flex-shrink:0; }
  
  /* ═══ SECTION SHELL ═══ */
  .ch-section { margin-bottom:88px; padding-top:16px; }
  .sec-hdr { display:flex; align-items:flex-start; gap:18px; margin-bottom:32px; }
  .sec-num {
    width:46px; height:46px; border-radius:12px;
    background:var(--bg3-page); border:1px solid var(--border-page);
    display:flex; align-items:center; justify-content:center;
    font-family:'Space Mono',monospace; font-size:13px; color:var(--accent-page);
    flex-shrink:0; margin-top:4px;
  }
  .sec-meta h2 { font-family:'Syne',sans-serif; font-size:26px; font-weight:700; margin-bottom:5px; color: var(--text-page); }
  .sec-meta .sub { font-family:'Space Mono',monospace; font-size:10px; color:var(--text3-page); text-transform:uppercase; letter-spacing:.08em; }
  
  /* ═══ WHY BOX ═══ */
  .why {
    background:linear-gradient(135deg,rgba(124,106,255,.07),rgba(255,106,154,.05));
    border:1px solid rgba(124,106,255,.22); border-radius:var(--r-page);
    padding:22px 26px; margin-bottom:30px; position:relative; overflow:hidden;
  }
  .why::before { content:''; position:absolute; top:0; left:0; right:0; height:2px; background:linear-gradient(90deg,var(--accent-page),var(--acc2-page)); }
  .why-label { font-family:'Space Mono',monospace; font-size:10px; color:var(--accent-page); text-transform:uppercase; letter-spacing:.1em; margin-bottom:9px; }
  .why p { font-size:15px; color:var(--text2-page); line-height:1.7; }
  .why strong { color:var(--text-page); }
  
  /* ═══ ANALOGY ═══ */
  .analogy {
    background:var(--card-page); border:1px solid var(--border-page);
    border-radius:var(--r-page); padding:22px 26px; margin:26px 0;
    display:flex; gap:18px;
  }
  .analogy-ico { font-size:34px; flex-shrink:0; line-height:1; }
  .analogy h4 { font-family:'Syne',sans-serif; font-size:14px; font-weight:700; color:var(--acc4-page); margin-bottom:7px; }
  .analogy p { font-size:15px; color:var(--text2-page); line-height:1.65; }
  
  /* ═══ PROSE ═══ */
  .content p { margin-bottom:18px; }
  .content h3 { font-family:'Syne',sans-serif; font-size:19px; font-weight:700; margin:34px 0 12px; color: var(--text-page); }
  
  /* ═══ TIP ═══ */
  .tip {
    background:rgba(255,215,90,.05); border:1px solid rgba(255,215,90,.18);
    border-radius:var(--rs-page); padding:13px 17px; margin:14px 0;
    display:flex; gap:10px; align-items:flex-start;
  }
  .tip p { font-size:14px; color:var(--text2-page); margin:0; line-height:1.6; }
  .tip strong { color:var(--yellow-page); }
  
  /* ═══ FORMULA BOX ═══ */
  .formula {
    background:var(--card2-page); border:1px solid var(--border-page);
    border-left:3px solid var(--accent-page);
    border-radius:var(--rs-page); padding:18px 22px; margin:20px 0;
    overflow-x:auto;
  }
  .formula-lbl { font-family:'Space Mono',monospace; font-size:10px; color:var(--accent-page); text-transform:uppercase; letter-spacing:.1em; margin-bottom:9px; }
  
  /* ═══ KEY RULE ═══ */
  .key-rule {
    background:var(--card-page); border:1px solid var(--border-page);
    border-top:3px solid var(--acc3-page); border-radius:var(--r-page);
    padding:22px 26px; margin:26px 0;
  }
  .key-rule-lbl { font-family:'Space Mono',monospace; font-size:10px; color:var(--acc3-page); text-transform:uppercase; letter-spacing:.1em; margin-bottom:10px; }
  .key-rule h4 { font-family:'Syne',sans-serif; font-size:16px; font-weight:700; margin-bottom:10px; }
  
  /* ═══ WORKED EXAMPLE ═══ */
  .worked {
    background:var(--card-page); border:1px solid var(--border-page);
    border-radius:var(--r-page); overflow:hidden; margin:26px 0;
  }
  .worked-hdr {
    background:var(--bg3-page); padding:13px 22px;
    border-bottom:1px solid var(--border-page);
    display:flex; align-items:center; gap:10px;
  }
  .we-tag {
    background:var(--accent-page); color:#fff;
    font-family:'Space Mono',monospace; font-size:9px;
    padding:3px 9px; border-radius:4px; text-transform:uppercase; letter-spacing:.07em;
  }
  .we-title { font-family:'Syne',sans-serif; font-size:14px; font-weight:600; }
  .worked-body { padding:22px; }
  .we-q {
    background:var(--bg2-page); border-radius:var(--rs-page);
    padding:13px 17px; margin-bottom:18px;
    font-size:15px; line-height:1.65;
  }
  
  /* ═══ STEPS ═══ */
  .steps { display:flex; flex-direction:column; gap:0; }
  .step { display:flex; gap:14px; position:relative; padding-bottom:20px; }
  .step:last-child { padding-bottom:0; }
  .step:not(:last-child)::before {
    content:''; position:absolute;
    left:14px; top:31px; bottom:0;
    width:1px; background:var(--border-page);
  }
  .step-n {
    width:30px; height:30px; border-radius:50%;
    background:var(--accent-page); color:#fff;
    display:flex; align-items:center; justify-content:center;
    font-family:'Space Mono',monospace; font-size:11px; font-weight:700;
    flex-shrink:0;
  }
  .step-c { flex:1; padding-top:4px; }
  .step-c p { font-size:14.5px; color:var(--text2-page); margin-bottom:8px; }
  .step-c p:last-child { margin-bottom:0; }
  .step-math {
    background:var(--bg2-page); border-radius:6px;
    padding:9px 14px; margin:8px 0;
    font-size:15px; overflow-x:auto;
  }
  .step-ans {
    background:rgba(93,255,168,.07); border:1px solid rgba(93,255,168,.22);
    border-radius:6px; padding:9px 14px; margin-top:7px;
    font-size:15px; color:var(--acc3-page);
  }
  
  /* ═══ COMPARISON TABLE ═══ */
  .ctable { width:100%; border-collapse:collapse; margin:20px 0; font-size:14px; }
  .ctable th { font-family:'Space Mono',monospace; font-size:10px; text-transform:uppercase; letter-spacing:.07em; color:var(--text3-page); padding:9px 14px; border-bottom:1px solid var(--border-page); text-align:left; }
  .ctable td { padding:10px 14px; border-bottom:1px solid var(--border-page); color:var(--text2-page); }
  .ctable tr:last-child td { border-bottom:none; }
  .ctable tr:hover td { background:var(--bg3-page); }
  .ctable td:first-child { font-family:'Space Mono',monospace; font-size:12px; color:var(--accent-page); font-weight:700; }
  .yes { color:var(--acc3-page); font-weight:700; }
  .no  { color:var(--acc2-page); }

  /* ═══ SIMULATIONS ═══ */
  .sim {
    background:var(--card-page); border:1px solid var(--border-page);
    border-radius:var(--r-page); padding:24px; margin:32px 0;
  }
  .sim-title { font-family:'Syne',sans-serif; font-size:16px; font-weight:700; margin-bottom:6px; color:var(--accent-page); }
  .sim-desc { font-size:13px; color:var(--text2-page); margin-bottom:20px; line-height:1.5; }
  
  .ctrl-row { display:flex; gap:10px; flex-wrap:wrap; margin-bottom:18px; }
  .ctrl-btn {
    background:var(--bg3-page); border:1px solid var(--border-page);
    color:var(--text-page); padding:6px 14px; border-radius:6px;
    font-family:'Space Mono',monospace; font-size:11px; cursor:pointer; transition:.2s;
  }
  .ctrl-btn:hover { border-color:var(--accent-page); color:var(--accent-page); }
  .ctrl-btn.on { background:var(--accent-page); color:#fff; border-color:var(--accent-page); }
  
  .ctrl-inp {
    background:var(--bg2-page); border:1px solid var(--border-page);
    color:var(--text-page); padding:6px 10px; border-radius:6px;
    font-family:'Space Mono',monospace; font-size:12px; width:70px;
  }
  .ctrl-lbl { font-family:'Space Mono',monospace; font-size:11px; color:var(--text3-page); }

  /* VENN */
  .venn-wrap { position:relative; margin:0 auto; max-width:620px; }
  .venn-svg { width:100%; height:auto; display:block; }
  .venn-ring { transition: opacity .2s, stroke-width .2s; }
  .venn-ring:hover { opacity:.8; stroke-width:3; }
  .venn-tooltip {
    position:absolute; pointer-events:none; opacity:0;
    background:var(--card2-page); border:1px solid var(--accent-page);
    padding:8px 12px; border-radius:6px; font-size:12px;
    color:var(--text-page); z-index:10; transition:opacity .2s;
    box-shadow:0 4px 12px rgba(0,0,0,.3);
  }

  /* NUMBER LINE */
  .nl-wrap { background:var(--bg2-page); border-radius:var(--rs-page); padding:10px; position:relative; }
  canvas { width:100%; height:auto; border-radius:4px; display:block; }
  #nl-hover { position:absolute; top:15px; right:15px; font-family:'Space Mono',monospace; font-size:10px; color:var(--text3-page); }

  /* QUIZ */
  .quiz-card { background:var(--bg2-page); border-radius:var(--rs-page); padding:22px; }
  #qtext { font-size:19px; font-weight:600; margin-bottom:20px; text-align:center; min-height:40px; }
  .q-opts { display:grid; grid-template-columns:repeat(2,1fr); gap:10px; }
  .q-opt {
    background:var(--card-page); border:1px solid var(--border-page);
    padding:12px; border-radius:8px; cursor:pointer;
    font-family:'Space Mono',monospace; font-size:12px; text-align:center; transition:.2s;
  }
  .q-opt:hover { border-color:var(--accent-page); color:var(--accent-page); }
  .q-opt.right { background:rgba(93,255,168,.15); border-color:var(--acc3-page); color:var(--acc3-page); }
  .q-opt.wrong { background:rgba(255,106,154,.15); border-color:var(--acc2-page); color:var(--acc2-page); }
  #qfb { margin-top:18px; font-size:14px; line-height:1.5; min-height:20px; }
  #qnext { margin-top:14px; background:var(--accent-page); color:#fff; border:none; padding:8px 20px; border-radius:6px; cursor:pointer; font-family:'Space Mono',monospace; font-size:11px; display:none; }

  /* EXERCISES */
  .ex-section { margin-top:100px; border-top:1px solid var(--border-page); padding-top:60px; }
  .ex-hero { margin-bottom:48px; }
  .ex-hero h2 { font-family:'Syne',sans-serif; font-size:32px; font-weight:800; margin-bottom:12px; }
  .ex-hero p { color:var(--text2-page); font-size:15px; max-width:640px; }
  .book-tag { display:inline-flex; align-items:center; gap:8px; background:var(--bg3-page); padding:5px 12px; border-radius:6px; font-family:'Space Mono',monospace; font-size:10px; margin-top:16px; }
  .book-tag span { color:var(--accent-page); }

  .ex-set { margin-bottom:60px; }
  .ex-set-hdr { font-family:'Space Mono',monospace; font-size:13px; font-weight:700; color:var(--accent-page); margin-bottom:24px; display:flex; align-items:center; gap:12px; }
  .ex-set-hdr::after { content:''; flex:1; height:1px; background:var(--border-page); }
  .ex-set-tag { color:var(--text3-page); font-weight:400; font-size:11px; }

  .ex-card { background:var(--card-page); border:1px solid var(--border-page); border-radius:var(--r-page); padding:24px; margin-bottom:20px; }
  .ex-card-hdr { display:flex; justify-content:space-between; align-items:center; margin-bottom:16px; }
  .ex-num { font-family:'Space Mono',monospace; font-size:12px; color:var(--text3-page); font-weight:700; }
  .badge-solved { background:rgba(93,255,168,.1); color:var(--acc3-page); font-size:10px; font-family:'Space Mono',monospace; padding:2px 8px; border-radius:4px; }
  .badge-try { background:rgba(124,106,255,.1); color:var(--accent-page); font-size:10px; font-family:'Space Mono',monospace; padding:2px 8px; border-radius:4px; }
  .ex-q { font-size:16px; line-height:1.6; margin-bottom:20px; }
  .ex-sol { border-top:1px solid var(--border-page); padding-top:20px; }
  
  .reveal-wrap { margin-top:12px; }
  .reveal-btn { background:var(--bg3-page); border:1px solid var(--border-page); color:var(--text2-page); padding:6px 14px; border-radius:6px; cursor:pointer; font-family:'Space Mono',monospace; font-size:11px; transition:.2s; }
  .reveal-btn:hover { border-color:var(--accent-page); color:var(--accent-page); }
  .reveal-ans { margin-top:12px; padding:12px 16px; background:var(--bg2-page); border-radius:6px; font-size:14px; display:none; border-left:3px solid var(--accent-page); }

  @media (max-width: 600px) {
    .hero { padding:60px 20px 40px; }
    .content { padding:0 20px; }
    .toc-grid { grid-template-columns: 1fr; }
    .q-opts { grid-template-columns: 1fr; }
  }
</style>

<div class="chapter-body">
  <div class="progress-bar"><div class="progress-fill" id="pfill"></div></div>

  <main>
    <header class="hero">
      <div class="chapter-tag">Chapter <em>01</em></div>
      <h1>Number <span>Systems</span></h1>
      <p class="hero-sub">From basic counting to the infinite complexity of real numbers. A visual, interactive guide to understanding how we classify the world.</p>
      <div class="hero-pills">
        <div class="pill">Status: <strong>Complete</strong></div>
        <div class="pill">Difficulty: <strong>Beginner</strong></div>
        <div class="pill">Interactive: <strong>Yes</strong></div>
      </div>
    </header>

    <div class="toc-wrap">
      <div class="toc">
        <div class="toc-title">Table of Contents</div>
        <div class="toc-grid">
          <a href="#s1" class="toc-link"><span class="toc-n">1</span> Introduction</a>
          <a href="#s2" class="toc-link"><span class="toc-n">2</span> Rational Numbers</a>
          <a href="#s3" class="toc-link"><span class="toc-n">3</span> Irrational Numbers</a>
          <a href="#s4" class="toc-link"><span class="toc-n">4</span> Number Line</a>
          <a href="#ex" class="toc-link"><span class="toc-n">5</span> Exercises</a>
        </div>
      </div>
    </div>

    <section class="content">
      <!-- SECTION 1 -->
      <section class="ch-section" id="s1">
        <div class="sec-hdr">
          <div class="sec-num">01</div>
          <div class="sec-meta">
            <h2>Introduction</h2>
            <div class="sub">The hierarchy of numbers</div>
          </div>
        </div>

        <div class="why">
          <div class="why-label">Why this matters</div>
          <p>Before solving equations, you must know what kind of "tools" you are using. Just as a biologist classifies animals, a mathematician classifies numbers to know which rules apply. <strong>Integers behave differently than decimals.</strong></p>
        </div>

        <p>Numbers aren't just a random list; they are a nested hierarchy. Think of them like folders on a computer: <em>Natural numbers</em> are inside <em>Whole numbers</em>, which are inside <em>Integers</em>, and so on.</p>

        <div class="sim">
          <div class="sim-title">🗺 The Number Map (Venn Diagram)</div>
          <div class="sim-desc">Click each ring to explore the classification.</div>
          <div class="venn-wrap">
            <svg class="venn-svg" viewBox="0 0 400 300">
              <circle class="venn-ring" data-id="real" cx="200" cy="150" r="140" fill="rgba(124,106,255,0.05)" stroke="var(--accent-page)" stroke-width="1" />
              <circle class="venn-ring" data-id="rational" cx="200" cy="160" r="110" fill="rgba(124,106,255,0.08)" stroke="var(--accent-page)" stroke-width="1" />
              <circle class="venn-ring" data-id="integer" cx="200" cy="170" r="85" fill="rgba(124,106,255,0.12)" stroke="var(--accent-page)" stroke-width="1" />
              <circle class="venn-ring" data-id="whole" cx="200" cy="180" r="60" fill="rgba(124,106,255,0.15)" stroke="var(--accent-page)" stroke-width="1" />
              <circle class="venn-ring" data-id="natural" cx="200" cy="190" r="35" fill="rgba(124,106,255,0.2)" stroke="var(--accent-page)" stroke-width="1" />
            </svg>
            <div id="venn-info" style="margin-top:20px; padding:15px; background:var(--bg2-page); border-radius:8px; font-size:14px; min-height:60px;">
              Click a ring to see details...
            </div>
          </div>
        </div>
      </section>

      <!-- SECTION 2 -->
      <section class="ch-section" id="s2">
        <div class="sec-hdr">
          <div class="sec-num">02</div>
          <div class="sec-meta">
            <h2>Rational Numbers</h2>
            <div class="sub">Fractions and density</div>
          </div>
        </div>
        <p>A rational number is any number of the form {"\\(\\frac{p}{q}\\)"} where {"\\(p, q\\)"} are integers and {"\\(q \\neq 0\\)"}.</p>
        
        <div class="sim">
          <div class="sim-title">🔬 Decimal Expansion Visualizer</div>
          <div class="sim-desc">Enter a fraction to see its decimal expansion.</div>
          <div class="ctrl-row">
            <input class="ctrl-inp" id="dec-p" type="number" value="1">
            <span class="ctrl-lbl">/</span>
            <input class="ctrl-inp" id="dec-q" type="number" value="7">
            <button class="ctrl-btn" id="btn-expand">Expand →</button>
          </div>
          <div id="dec-visual"></div>
        </div>
      </section>

      <!-- SECTION 4 (Real Number Line) -->
      <section class="ch-section" id="s4">
        <div class="sec-hdr">
          <div class="sec-num">04</div>
          <div class="sec-meta">
            <h2>The Real Number Line</h2>
            <div class="sub">Visualizing every number</div>
          </div>
        </div>
        
        <div class="sim">
          <div class="sim-title">📏 Interactive Number Line</div>
          <div class="sim-desc">Filter number types and zoom in to see density.</div>
          <div class="ctrl-row">
            <button class="ctrl-btn on" id="btn-nl-all">All</button>
            <button class="ctrl-btn" id="btn-nl-nat">Natural</button>
            <button class="ctrl-btn" id="btn-nl-int">Integer</button>
            <button class="ctrl-btn" id="btn-nl-rat">Rational</button>
            <button class="ctrl-btn" id="btn-nl-irr">Irrational</button>
          </div>
          <div class="ctrl-row" style="align-items:center">
            <label class="ctrl-lbl">Zoom:</label>
            <input type="range" id="nlZoom" min="1" max="50" value="1" step="0.5" style="flex:1">
            <span class="ctrl-lbl" id="nlZoomVal">1.0×</span>
          </div>
          <div class="nl-wrap">
            <canvas id="nlCanvas" width="800" height="120"></canvas>
            <div id="nl-hover">Position: 0.0000</div>
          </div>
        </div>

        <div class="quiz-card">
          <div class="sim-title">🧠 Knowledge Check</div>
          <div id="qtext">Loading question...</div>
          <div class="q-opts">
            <div class="q-opt" data-ans="natural">Natural</div>
            <div class="q-opt" data-ans="integer">Integer</div>
            <div class="q-opt" data-ans="rational">Rational</div>
            <div class="q-opt" data-ans="irrational">Irrational</div>
          </div>
          <div id="qfb"></div>
          <button id="qnext">Next Question</button>
          <div id="qscore" style="margin-top:10px; font-family:'Space Mono',monospace; font-size:11px; color:var(--text3-page);">Score: 0 / 0</div>
        </div>
      </section>
      
      <!-- EXERCISES -->
      <section class="ex-section" id="ex">
        <div class="ex-hero">
          <h2>✍ Exercises</h2>
          <p>Test your understanding with these practice problems.</p>
        </div>

        <div class="ex-set">
          <div class="ex-card">
            <div class="ex-card-hdr"><span class="ex-num">Q1</span><span class="badge-solved">✓ Solved</span></div>
            <div class="ex-q">Is zero a rational number?</div>
            <div class="ex-sol">
              <p><strong>Yes</strong>. Zero can be written as {"\\(\\frac{0}{1}\\)"}, which fits the {"\\(\\frac{p}{q}\\)"} definition.</p>
            </div>
          </div>

          <div class="ex-card">
            <div class="ex-card-hdr"><span class="ex-num">Q2</span><span class="badge-try">✎ Try It</span></div>
            <div class="ex-q">State whether true or false: Every integer is a whole number.</div>
            <div class="reveal-wrap">
              <button class="reveal-btn">👁 Show Answer</button>
              <div class="reveal-ans"><strong>False</strong>. Negative integers (like -1) are not whole numbers.</div>
            </div>
          </div>
        </div>
      </section>
    </section>
  </main>
</div>

<script is:inline>
  // Progress bar
  window.addEventListener('scroll', () => {
    const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
    const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
    const scrolled = (winScroll / height) * 100;
    const pfill = document.getElementById('pfill');
    if (pfill) pfill.style.width = scrolled + '%';
  });

  // Venn Interaction
  const vennData = {
    natural: { t: 'Natural Numbers (ℕ)', d: 'Basic counting numbers: 1, 2, 3...', e: '1, 5, 100' },
    whole: { t: 'Whole Numbers (𝕎)', d: 'Natural numbers plus zero.', e: '0, 1, 2' },
    integer: { t: 'Integers (ℤ)', d: 'Positive and negative whole numbers.', e: '-3, 0, 42' },
    rational: { t: 'Rational Numbers (ℚ)', d: 'Any number expressible as p/q.', e: '1/2, 0.75, -4' },
    real: { t: 'Real Numbers (ℝ)', d: 'All rational and irrational numbers.', e: 'π, √2, 5.5' }
  };

  document.querySelectorAll('.venn-ring').forEach(ring => {
    ring.addEventListener('click', () => {
      const id = ring.getAttribute('data-id');
      const data = vennData[id];
      const info = document.getElementById('venn-info');
      if (info) info.innerHTML = `<strong>${data.t}</strong>: ${data.d} <br> <span style="color:var(--text3-page)">Examples: ${data.e}</span>`;
    });
  });

  // Decimal Expander
  function runDecimal() {
    const pVal = parseInt(document.getElementById('dec-p').value) || 1;
    const qVal = parseInt(document.getElementById('dec-q').value) || 7;
    const el = document.getElementById('dec-visual');
    
    let res = (pVal / qVal).toString();
    if (res.length > 15) res = res.substring(0, 15) + '...';
    
    if (el) el.innerHTML = `<div style="background:var(--bg2-page); padding:15px; border-radius:8px; margin-top:10px; font-family:'Space Mono',monospace;">
      ${pVal} ÷ ${qVal} = ${res}
    </div>`;
  }
  document.getElementById('btn-expand')?.addEventListener('click', runDecimal);

  // Number Line
  let nlMode = 'all';
  function drawNL() {
    const cv = document.getElementById('nlCanvas');
    if (!cv) return;
    const ctx = cv.getContext('2d');
    const W = cv.width, H = cv.height;
    const zoom = parseFloat(document.getElementById('nlZoom').value);
    const zoomVal = document.getElementById('nlZoomVal');
    if (zoomVal) zoomVal.textContent = zoom.toFixed(1) + '×';

    ctx.clearRect(0, 0, W, H);
    ctx.fillStyle = '#0f0f1a';
    ctx.fillRect(0, 0, W, H);

    const mid = H / 2;
    const scale = (W - 100) * zoom / 10;
    const origin = W / 2;

    ctx.strokeStyle = '#252538';
    ctx.beginPath(); ctx.moveTo(50, mid); ctx.lineTo(W-50, mid); ctx.stroke();

    const xOf = v => origin + v * scale;
    for (let i = -10; i <= 10; i++) {
      const x = xOf(i);
      if (x < 50 || x > W-50) continue;
      ctx.beginPath(); ctx.moveTo(x, mid-5); ctx.lineTo(x, mid+5); ctx.stroke();
      ctx.fillStyle = '#4a4a6a';
      ctx.font = '10px monospace';
      ctx.textAlign = 'center';
      ctx.fillText(i, x, mid + 20);
    }
  }
  
  document.getElementById('nlZoom')?.addEventListener('input', drawNL);
  ['all', 'nat', 'int', 'rat', 'irr'].forEach(m => {
    document.getElementById('btn-nl-' + m)?.addEventListener('click', (e) => {
      document.querySelectorAll('[id^=btn-nl-]').forEach(b => b.classList.remove('on'));
      e.target.classList.add('on');
      nlMode = m;
      drawNL();
    });
  });
  drawNL();

  // Quiz
  const quizQ = [
    { q: 'Is √16 a natural number?', a: 'natural' },
    { q: 'Is -7 an integer?', a: 'integer' },
    { q: 'Is 0.333... rational?', a: 'rational' },
    { q: 'Is π irrational?', a: 'irrational' }
  ];
  let qi = 0, qs = 0;
  function loadQ() {
    const q = quizQ[qi % quizQ.length];
    const qtext = document.getElementById('qtext');
    const qfb = document.getElementById('qfb');
    const qnext = document.getElementById('qnext');
    if (qtext) qtext.textContent = q.q;
    if (qfb) qfb.textContent = '';
    if (qnext) qnext.style.display = 'none';
    document.querySelectorAll('.q-opt').forEach(o => o.className = 'q-opt');
  }
  document.querySelectorAll('.q-opt').forEach(opt => {
    opt.addEventListener('click', () => {
      const chosen = opt.getAttribute('data-ans');
      const correct = quizQ[qi % quizQ.length].a;
      const qfb = document.getElementById('qfb');
      const qscore = document.getElementById('qscore');
      const qnext = document.getElementById('qnext');
      if (chosen === correct) {
        opt.classList.add('right');
        qs++;
        if (qfb) qfb.innerHTML = '<span style="color:var(--acc3-page)">Correct!</span>';
      } else {
        opt.classList.add('wrong');
        if (qfb) qfb.innerHTML = `<span style="color:var(--acc2-page)">Wrong. It is ${correct}.</span>`;
      }
      qi++;
      if (qscore) qscore.textContent = `Score: ${qs} / ${qi}`;
      if (qnext) qnext.style.display = 'block';
    });
  });
  document.getElementById('qnext')?.addEventListener('click', loadQ);
  loadQ();

  // Reveal Answer
  document.querySelectorAll('.reveal-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const ans = btn.nextElementSibling;
      if (ans) {
        ans.style.display = ans.style.display === 'block' ? 'none' : 'block';
        btn.textContent = ans.style.display === 'block' ? '🙈 Hide Answer' : '👁 Show Answer';
      }
    });
  });
</script>

</Main>
