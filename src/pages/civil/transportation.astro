---
import Main from '../../layouts/Main.astro';
const title = "Transportation Engineering";
const description = "Traffic flow, highway design, signal timing, and level of service — the math that keeps cities moving. Interactive calculators, simulations, and worked examples.";
---
<Main title={title} description={description} activeNav="civil">

<style>
  /* ── LAYOUT UTILITIES ── */
  .page-wrap {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .section-label {
    font-family: 'Space Mono', monospace;
    font-size: .6rem;
    letter-spacing: .15em;
    text-transform: uppercase;
    color: var(--mut);
    display: flex;
    align-items: center;
    gap: .8rem;
    margin-bottom: 1.5rem;
  }
  .section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--bdr);
  }

  /* ── HERO ── */
  .hero {
    padding: 4rem 1.5rem 3rem;
    max-width: 960px;
    margin: 0 auto;
  }
  .hero-eyebrow {
    font-family: 'Space Mono', monospace;
    font-size: .62rem;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--teal);
    margin-bottom: 1rem;
  }
  .hero h1 {
    font-size: clamp(1.9rem, 5vw, 3rem);
    font-weight: 700;
    letter-spacing: -.025em;
    line-height: 1.15;
    margin-bottom: 1rem;
    color: var(--txt);
  }
  .hero-sub {
    font-size: .95rem;
    color: var(--txt2);
    line-height: 1.7;
    max-width: 600px;
    margin-bottom: 1.6rem;
  }
  .hero-stats {
    display: flex;
    flex-wrap: wrap;
    gap: .5rem;
    margin-bottom: 1.8rem;
  }
  .stat-chip {
    font-family: 'Space Mono', monospace;
    font-size: .64rem;
    letter-spacing: .06em;
    color: var(--teal);
    background: var(--tdim);
    border: 1px solid var(--tline);
    border-radius: 100px;
    padding: .3rem .75rem;
  }
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: .75rem;
  }
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    background: var(--teal);
    color: #0a0a0f;
    font-weight: 700;
    font-size: .8rem;
    letter-spacing: .04em;
    text-decoration: none;
    padding: .65rem 1.25rem;
    border-radius: 6px;
    transition: opacity .2s, transform .2s;
  }
  .btn-primary:hover { opacity: .88; transform: translateY(-1px); }

  /* ── LESSONS GRID ── */
  .lessons {
    padding: 1rem 1.5rem 3.5rem;
    max-width: 960px;
    margin: 0 auto;
  }
  .lessons-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: .9rem;
  }
  .lesson-card {
    background: var(--surf);
    border: 1px solid var(--bdr);
    border-radius: 10px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: .45rem;
    position: relative;
    overflow: hidden;
    transition: border-color .2s, transform .2s, box-shadow .2s;
  }
  .lesson-card.live {
    border-color: rgba(78,201,176,.35);
    background: linear-gradient(135deg, var(--surf) 0%, rgba(78,201,176,.04) 100%);
    text-decoration: none;
    color: inherit;
  }
  .lesson-card.live:hover {
    border-color: var(--teal);
    transform: translateY(-3px);
    box-shadow: 0 8px 32px rgba(78,201,176,.14);
  }
  .lesson-card.soon {
    opacity: .55;
  }
  .live-badge {
    position: absolute;
    top: .8rem;
    right: .8rem;
    font-family: 'Space Mono', monospace;
    font-size: .52rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: #0a0a0f;
    background: var(--teal);
    padding: .2rem .5rem;
    border-radius: 100px;
    font-weight: 700;
  }
  .soon-badge {
    position: absolute;
    top: .8rem;
    right: .8rem;
    font-family: 'Space Mono', monospace;
    font-size: .52rem;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--mut);
    background: var(--surf2);
    border: 1px solid var(--bdr);
    padding: .2rem .5rem;
    border-radius: 100px;
  }
  .lesson-num {
    font-family: 'Space Mono', monospace;
    font-size: .58rem;
    letter-spacing: .12em;
    color: var(--mut);
    text-transform: uppercase;
  }
  .lesson-title {
    font-size: .92rem;
    font-weight: 700;
    color: var(--txt);
    padding-right: 3.5rem;
    line-height: 1.3;
  }
  .lesson-desc {
    font-size: .76rem;
    color: var(--txt2);
    line-height: 1.55;
    flex: 1;
  }
  .lesson-level {
    font-family: 'Space Mono', monospace;
    font-size: .56rem;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--mut);
    margin-top: .25rem;
  }
  .lesson-link {
    font-size: .72rem;
    color: var(--teal);
    font-weight: 600;
    margin-top: .25rem;
    display: inline-flex;
    align-items: center;
    gap: .3rem;
    transition: gap .2s;
  }
  .lesson-card.live:hover .lesson-link { gap: .6rem; }

  /* ── FORMULA STRIP ── */
  .formula-strip {
    padding: 1rem 1.5rem 3.5rem;
    max-width: 960px;
    margin: 0 auto;
  }
  .strip-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: .9rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .fcard {
    background: var(--surf2);
    border: 1px solid var(--bdr);
    border-radius: 8px;
    padding: .75rem 1rem;
    display: flex;
    flex-direction: column;
    gap: .4rem;
    min-width: 0;
    transition: border-color .2s;
  }
  .fcard:hover { border-color: rgba(78,201,176,.3); }
  .fcard-name {
    font-size: .78rem;
    font-weight: 700;
    color: var(--txt);
  }
  .fcard-math {
    font-family: 'Space Mono', monospace;
    font-size: .82rem;
    color: var(--teal);
    line-height: 1.5;
    word-break: break-word;
  }
  .fcard-desc {
    font-size: .7rem;
    color: var(--txt2);
    line-height: 1.5;
  }

  /* ── ABOUT ── */
  .about {
    padding: 1rem 1.5rem 3.5rem;
    max-width: 960px;
    margin: 0 auto;
  }
  .about-inner {
    background: var(--surf);
    border: 1px solid var(--bdr);
    border-radius: 10px;
    padding: 2rem;
  }
  .about-text {
    font-size: .88rem;
    color: var(--txt2);
    line-height: 1.8;
    max-width: 620px;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 640px) {
    .hero { padding: 2.5rem 1.25rem 2rem; }
    .lessons { padding-left: 1.25rem; padding-right: 1.25rem; }
    .formula-strip { padding-left: 1.25rem; padding-right: 1.25rem; }
    .about { padding-left: 1.25rem; padding-right: 1.25rem; }
    .lessons-grid { grid-template-columns: 1fr; }
    .strip-row { grid-template-columns: 1fr; }
    .hero-stats { gap: .4rem; }
    .hero-ctas { flex-direction: column; }
    .btn-primary { justify-content: center; width: 100%; }
    .about-inner { padding: 1.25rem; }
  }
</style>

<!-- SKIP TO CONTENT -->
<a href="#main-content" style="position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden;z-index:9999;background:var(--teal);color:#0a0a0f;padding:.5rem 1rem;border-radius:0 0 6px 6px;font-weight:700;text-decoration:none;" onfocus="this.style.left='50%';this.style.transform='translateX(-50%)';this.style.width='auto';this.style.height='auto';" onblur="this.style.left='-9999px';this.style.transform='';this.style.width='1px';this.style.height='1px';">Skip to content</a>

<main id="main-content">

  <!-- ── 1. HERO ── -->
  <section class="hero" aria-label="Transportation Engineering — Introduction">
    <div class="hero-eyebrow">&#8721; mathify.us &middot; Civil Engineering &middot; Transportation</div>
    <h1>Transportation Engineering</h1>
    <p class="hero-sub">Traffic flow, highway design, signal timing, and level of service &mdash; the math that keeps cities moving.</p>
    <div class="hero-stats" role="list">
      <span class="stat-chip" role="listitem">&#10003; 1 Active Lesson</span>
      <span class="stat-chip" role="listitem">&#10003; 4+ Calculators</span>
      <span class="stat-chip" role="listitem">&#10003; 2 Simulations</span>
      <span class="stat-chip" role="listitem">&#10003; HCM Standards</span>
    </div>
    <div class="hero-ctas">
      <a href="/civil/traffic-design" class="btn-primary">Start with Traffic Design &#8594;</a>
    </div>
  </section>

  <!-- ── 2. LESSONS GRID ── -->
  <section class="lessons" aria-labelledby="lessons-heading">
    <div class="section-label" id="lessons-heading">01 &mdash; Lessons</div>
    <div class="lessons-grid">

      <!-- 01 — Traffic Design — LIVE -->
      <a href="/civil/traffic-design" class="lesson-card live" aria-label="Traffic Design Fundamentals — Live">
        <span class="live-badge">LIVE</span>
        <span class="lesson-num">01</span>
        <span class="lesson-title">Traffic Design Fundamentals</span>
        <span class="lesson-desc">Flow theory, Greenshields model, LOS A&ndash;F, Webster&rsquo;s signal timing, stopping sight distance.</span>
        <span class="lesson-level">University &rarr; Professional</span>
        <span class="lesson-link">Open Lesson &#8594;</span>
      </a>

      <!-- 02 — Highway Geometric Design — Soon -->
      <div class="lesson-card soon" aria-label="Highway Geometric Design — Coming Soon">
        <span class="soon-badge">Soon</span>
        <span class="lesson-num">02</span>
        <span class="lesson-title">Highway Geometric Design</span>
        <span class="lesson-desc">Horizontal curves, vertical alignment, superelevation, sight distance for curves.</span>
        <span class="lesson-level">University &rarr; Professional</span>
      </div>

      <!-- 03 — Traffic Signal Systems — Soon -->
      <div class="lesson-card soon" aria-label="Traffic Signal Systems — Coming Soon">
        <span class="soon-badge">Soon</span>
        <span class="lesson-num">03</span>
        <span class="lesson-title">Traffic Signal Systems</span>
        <span class="lesson-desc">Multi-phase signals, actuated control, coordination, progression.</span>
        <span class="lesson-level">University &rarr; Professional</span>
      </div>

      <!-- 04 — Pavement Design — Soon -->
      <div class="lesson-card soon" aria-label="Pavement Design — Coming Soon">
        <span class="soon-badge">Soon</span>
        <span class="lesson-num">04</span>
        <span class="lesson-title">Pavement Design</span>
        <span class="lesson-desc">AASHTO method, structural numbers, layer coefficients, drainage.</span>
        <span class="lesson-level">University &rarr; Professional</span>
      </div>

      <!-- 05 — Traffic Impact Studies — Soon -->
      <div class="lesson-card soon" aria-label="Traffic Impact Studies — Coming Soon">
        <span class="soon-badge">Soon</span>
        <span class="lesson-num">05</span>
        <span class="lesson-title">Traffic Impact Studies</span>
        <span class="lesson-desc">Trip generation, distribution, assignment, mitigation measures.</span>
        <span class="lesson-level">University &rarr; Professional</span>
      </div>

      <!-- 06 — Public Transport Planning — Soon -->
      <div class="lesson-card soon" aria-label="Public Transport Planning — Coming Soon">
        <span class="soon-badge">Soon</span>
        <span class="lesson-num">06</span>
        <span class="lesson-title">Public Transport Planning</span>
        <span class="lesson-desc">Headways, capacity, modal split, network design.</span>
        <span class="lesson-level">University &rarr; Professional</span>
      </div>

    </div>
  </section>

  <!-- ── 3. KEY FORMULAS STRIP ── -->
  <section class="formula-strip" id="formulas" aria-labelledby="formula-heading">
    <div class="section-label" id="formula-heading">02 &mdash; Key Formulas</div>
    <div class="strip-row">

      <!-- Fundamental Flow -->
      <div class="fcard">
        <div class="fcard-name">Fundamental Flow</div>
        <div class="fcard-math">$$q = u \cdot k$$</div>
        <div class="fcard-desc">flow = speed &times; density</div>
      </div>

      <!-- Webster's Cycle -->
      <div class="fcard">
        <div class="fcard-name">Webster&rsquo;s Cycle</div>
        <div class="fcard-math">$$C_0 = \dfrac&#123;1.5L + 5&#125;&#123;1 - Y&#125;$$</div>
        <div class="fcard-desc">optimal signal cycle length</div>
      </div>

      <!-- Stopping Sight Distance -->
      <div class="fcard">
        <div class="fcard-name">Stopping Sight Distance</div>
        <div class="fcard-math">$$\text&#123;SSD&#125; = 0.278Vt + \dfrac&#123;V^2&#125;&#123;254f&#125;$$</div>
        <div class="fcard-desc">AASHTO model</div>
      </div>

    </div>
  </section>

  <!-- ── 4. ABOUT ── -->
  <section class="about" aria-labelledby="about-heading">
    <div class="section-label" id="about-heading">03 &mdash; About This Section</div>
    <div class="about-inner">
      <p class="about-text">Transportation engineering sits at the intersection of physics, statistics, and human behaviour. We study how people and goods move through space &mdash; and how to make that movement safer, faster, and more efficient.</p>
    </div>
  </section>

</main>

</Main>
