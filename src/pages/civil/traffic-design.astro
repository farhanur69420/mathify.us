        <div><label>P₂</label><input type="number" id="gP2" value="200"></div>
        <div><label>P₃</label><input type="number" id="gP3" value="0"></div>
        <div><label>A₁</label><input type="number" id="gA1" value="0"></div>
        <div><label>A₂</label><input type="number" id="gA2" value="400"></div>
        <div><label>A₃</label><input type="number" id="gA3" value="500"></div>
      </div>
    </div>
    <div>
      <div style="font-family:'Space Mono',monospace;font-size:.72rem;color:var(--teal);margin-bottom:8px;">TRAVEL TIMES (min)</div>
      <div class="ig">
        <div><label>t₁₁</label><input type="number" id="gt11" value="2"></div>
        <div><label>t₁₂</label><input type="number" id="gt12" value="4"></div>
        <div><label>t₁₃</label><input type="number" id="gt13" value="6"></div>
        <div><label>t₂₁</label><input type="number" id="gt21" value="4"></div>
        <div><label>t₂₂</label><input type="number" id="gt22" value="2"></div>
        <div><label>t₂₃</label><input type="number" id="gt23" value="8"></div>
      </div>
    </div>
    <div>
      <div style="font-family:'Space Mono',monospace;font-size:.72rem;color:var(--teal);margin-bottom:8px;">FRICTION FACTORS</div>
      <div id="gFF" style="font-family:'Space Mono',monospace;font-size:.78rem;color:var(--txt2);line-height:2.1;background:var(--surf2);border:1px solid var(--bdr);border-radius:3px;padding:10px;">Click Calculate</div>
    </div>
