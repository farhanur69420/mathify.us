<script is:inline>
/* ═══ UTILITY ═══ */
function szC(id,pad=36){const cv=document.getElementById(id);if(!cv)return;cv.width=Math.max(200,(cv.parentElement?.offsetWidth||400)-pad);}
window.addEventListener('resize',()=>{clearTimeout(window._rdT);window._rdT=setTimeout(()=>{szAll();redrawAll();},200);});
function szAll(){['cPHF','cSig','cDelayCurve','cModePie','cQueue'].forEach(id=>szC(id));}
function redrawAll(){calcPHF();drawSignal();drawDelayCurve();}

/* ═══ PRACTICE PROBLEM TOGGLE ═══ */
function togglePP(qEl){
  const sol=qEl.nextElementSibling;
  const arrow=qEl.querySelector('.pp-arrow');
  sol.classList.toggle('show');
  arrow.classList.toggle('open');
}

/* ═══ ANIMATED TRAFFIC LIGHT ═══ */
let tlInterval=null, tlT=0, tlRunning=true;
function getTLParams(){
  const C=+document.getElementById('tlCyc').value;
  const split=+document.getElementById('tlSplit').value/100;
  const G_EW=Math.round(C*split), Y=3, AR=1;
  const G_NS=C-G_EW-2*(Y+AR);
  return{C,G_EW,G_NS,Y,AR};
}
function setLens(id,state){
  const el=document.getElementById(id);
  if(!el)return;
  el.className='tl-lens '+(state==='off'?'off':'active-'+state);
}
function updateTL(){
  const {C,G_EW,G_NS,Y,AR}=getTLParams();
  const t=tlT%C;
  // EW phase timing: 0 → G_EW (green), G_EW → G_EW+Y (yellow), G_EW+Y → G_EW+Y+AR (AR), then red
  let ewState='red',nsState='red',phaseTxt='',remaining=0;
  if(t<G_EW){ewState='green';nsState='red';phaseTxt='EW GREEN ↔';remaining=G_EW-t;}
  else if(t<G_EW+Y){ewState='yellow';nsState='red';phaseTxt='EW YELLOW';remaining=G_EW+Y-t;}
  else if(t<G_EW+Y+AR){ewState='red';nsState='red';phaseTxt='ALL RED';remaining=G_EW+Y+AR-t;}
  else if(t<G_EW+Y+AR+G_NS){ewState='red';nsState='green';phaseTxt='NS GREEN ↕';remaining=G_EW+Y+AR+G_NS-t;}
  else if(t<G_EW+Y+AR+G_NS+Y){ewState='red';nsState='yellow';phaseTxt='NS YELLOW';remaining=C-Y-AR-t+G_EW+Y+AR+G_NS;}
  else{ewState='red';nsState='red';phaseTxt='ALL RED';remaining=C-t;}
  setLens('tlR-EW',ewState==='red'?'red':'off');
  setLens('tlY-EW',ewState==='yellow'?'yellow':'off');
  setLens('tlG-EW',ewState==='green'?'green':'off');
  setLens('tlR-NS',nsState==='red'?'red':'off');
  setLens('tlY-NS',nsState==='yellow'?'yellow':'off');
  setLens('tlG-NS',nsState==='green'?'green':'off');
  document.getElementById('tlPhaseText').textContent=phaseTxt;
  document.getElementById('tlPhaseText').style.color=ewState==='green'||nsState==='green'?'var(--teal)':ewState==='yellow'||nsState==='yellow'?'var(--amb)':'var(--red)';
  document.getElementById('tlCountdown').textContent=Math.ceil(remaining);
  document.getElementById('tlProgress').style.width=(t/C*100)+'%';
  document.getElementById('tlTimingPlan').innerHTML=
    `G_EW = ${G_EW}s\nY    = ${Y}s\nAR   = ${AR}s\nG_NS = ${G_NS}s\nY    = ${Y}s\nAR   = ${AR}s\n─────\nC    = ${C}s`.replace(/\n/g,'<br>');
  tlT++;
}
function resetTL(){tlT=0;}
tlInterval=setInterval(updateTL,1000);

/* ═══ ANIMATED INTERSECTION ═══ */
let intRunning=true, intT=0, intLoop=null, vehicles=[];
const VEH_COLORS=['#2a6ae0','#e04a2a','#2ae06a','#e0c42a','#a02ae0'];
function createVehicles(){
  const scene=document.getElementById('intScene');
  vehicles.forEach(v=>v.el&&v.el.remove());
  vehicles=[];
  const W=scene.offsetWidth||400, H=scene.offsetHeight||320;
  const cx=W/2, cy=H/2;
  // EW vehicles
  for(let i=0;i<3;i++){
    const el=document.createElement('div');
    el.className='vehicle v-east v-going';
    el.style.cssText=`top:${cy-24}px;width:28px;height:16px;border-radius:4px;position:absolute;animation:moveEast ${3+i*1.2}s ${i*1.1}s linear infinite;background:${VEH_COLORS[i]};`;
    scene.appendChild(el);vehicles.push({el,dir:'EW'});
  }
  for(let i=0;i<2;i++){
    const el=document.createElement('div');
    el.className='vehicle v-west v-going';
    el.style.cssText=`top:${cy+8}px;width:28px;height:16px;border-radius:4px;position:absolute;animation:moveWest ${3.5+i*1.3}s ${i*1.4}s linear infinite;background:${VEH_COLORS[i+2]};`;
    scene.appendChild(el);vehicles.push({el,dir:'EW'});
  }
  for(let i=0;i<2;i++){
    const el=document.createElement('div');
    el.style.cssText=`left:${cx+8}px;width:16px;height:28px;border-radius:4px;position:absolute;animation:moveSouth ${4+i*1.5}s ${i*2}s linear infinite;background:${VEH_COLORS[i+1]};`;
    scene.appendChild(el);vehicles.push({el,dir:'NS'});
  }
}
function updateIntersectionSignals(){
  const {C,G_EW,Y,AR}=getTLParams();
  const t=intT%C;
  const ewGreen=t<G_EW;
  const ewYellow=t>=G_EW&&t<G_EW+Y;
  const nsGreen=t>=G_EW+Y+AR&&t<G_EW+Y+AR+(C-G_EW-2*(Y+AR));
  const setDot=(id,on)=>{const el=document.getElementById(id);if(el)el.classList.toggle('on',on);};
  ['sNE-r','sSW-r'].forEach(id=>setDot(id,!ewGreen&&!ewYellow));
  ['sNE-y','sSW-y'].forEach(id=>setDot(id,ewYellow));
  ['sNE-g','sSW-g'].forEach(id=>setDot(id,ewGreen));
  ['sNW-r','sSE-r'].forEach(id=>setDot(id,!nsGreen));
  ['sNW-y','sSE-y'].forEach(id=>setDot(id,false));
  ['sNW-g','sSE-g'].forEach(id=>setDot(id,nsGreen));
  // Pause EW vehicles on red, NS on red
  vehicles.forEach(v=>{
    if(!v.el)return;
    if(v.dir==='EW'){v.el.style.animationPlayState=ewGreen||ewYellow?'running':'paused';}
    else{v.el.style.animationPlayState=nsGreen?'running':'paused';}
  });
  document.getElementById('intPhaseLabel').textContent=ewGreen?'EW GREEN':ewYellow?'EW YELLOW':nsGreen?'NS GREEN':'ALL RED';
  document.getElementById('intTimer').textContent=intT%C+'s';
  intT++;
}
function toggleIntersection(){
  intRunning=!intRunning;
  document.getElementById('intBtn').textContent=intRunning?'⏸ PAUSE':'▶ RESUME';
  if(intRunning)startIntLoop();else clearInterval(intLoop);
}
function startIntLoop(){clearInterval(intLoop);intLoop=setInterval(updateIntersectionSignals,1000);}
window.addEventListener('load',()=>{createVehicles();startIntLoop();});

/* ═══ PHF CALCULATOR ═══ */
function calcPHF(){
  const v=[+document.getElementById('v1').value,+document.getElementById('v2').value,+document.getElementById('v3').value,+document.getElementById('v4').value];
  const V=v.reduce((a,b)=>a+b,0),Vmax=Math.max(...v);
  const PHF=Vmax>0?V/(4*Vmax):0,flowRate=PHF>0?V/PHF:0;
  const cv=document.getElementById('cPHF');if(!cv)return;
  const ctx=cv.getContext('2d'),W=cv.width,H=cv.height;ctx.clearRect(0,0,W,H);
  const labels=['4:30–4:45','4:45–5:00','5:00–5:15','5:15–5:30'];
  const cols=['rgba(0,255,163,.5)','rgba(0,212,255,.5)','rgba(167,139,250,.5)','rgba(255,179,0,.5)'];
  const hlCols=['#00ffa3','#00d4ff','#a78bfa','#ffb300'];
  const maxV=Math.max(...v)*1.15;
  const ox=50,oy=H-32,aw=W-70,ah=H-48,bw=aw/5.5,gap=aw/5.5*.4;
  ctx.strokeStyle='rgba(0,212,255,.15)';ctx.lineWidth=.8;
  for(let i=0;i<=5;i++){const y=oy-ah*i/5;ctx.beginPath();ctx.moveTo(ox,y);ctx.lineTo(ox+aw,y);ctx.stroke();ctx.font='9px JetBrains Mono,monospace';ctx.textAlign='right';ctx.fillStyle='#5a7a99';ctx.fillText(Math.round(maxV*i/5),ox-4,y+3);}
  ctx.strokeStyle='rgba(0,212,255,.3)';ctx.lineWidth=1;ctx.beginPath();ctx.moveTo(ox,oy-ah-4);ctx.lineTo(ox,oy);ctx.lineTo(ox+aw+4,oy);ctx.stroke();
  v.forEach((vi,i)=>{
    const bx=ox+aw*.12+i*(bw+gap),bh=ah*(vi/maxV),isMax=vi===Vmax;
    ctx.fillStyle=isMax?hlCols[i]:cols[i];ctx.fillRect(bx,oy-bh,bw,bh);
    if(isMax){ctx.strokeStyle=hlCols[i];ctx.lineWidth=2;ctx.strokeRect(bx,oy-bh,bw,bh);}
    ctx.font='9px JetBrains Mono,monospace';ctx.textAlign='center';
    ctx.fillStyle=isMax?hlCols[i]:'#5a7a99';ctx.fillText(vi,bx+bw/2,oy-bh-6);
    ctx.fillStyle='#5a7a99';ctx.fillText(labels[i],bx+bw/2,oy+14);
  });
  const avgH=ah*(V/4/maxV);
  ctx.strokeStyle='rgba(255,179,0,.4)';ctx.setLineDash([4,3]);ctx.lineWidth=1;
  ctx.beginPath();ctx.moveTo(ox,oy-avgH);ctx.lineTo(ox+aw,oy-avgH);ctx.stroke();ctx.setLineDash([]);
  ctx.font='9px JetBrains Mono,monospace';ctx.fillStyle='rgba(255,179,0,.7)';ctx.textAlign='right';
  ctx.fillText('avg='+(V/4).toFixed(0),ox+aw-2,oy-avgH-4);
  const lc=PHF>=.95?'#00ffa3':PHF>=.85?'#00d4ff':PHF>=.75?'#ffb300':'#ff4d6d';
  document.getElementById('phfResult').innerHTML=
    `<div style="background:var(--surf2);border:1px solid var(--bdr);border-radius:3px;padding:12px 14px;"><div style="font-family:'Space Mono',monospace;font-size:.62rem;color:var(--mut);">HOURLY VOLUME</div><div style="font-family:'Space Mono',monospace;font-size:1.1rem;color:var(--teal);">${V} veh/h</div></div>
     <div style="background:var(--surf2);border:1px solid var(--bdr);border-radius:3px;padding:12px 14px;"><div style="font-family:'Space Mono',monospace;font-size:.62rem;color:var(--mut);">PHF</div><div style="font-family:'Space Mono',monospace;font-size:1.1rem;color:${lc};">${PHF.toFixed(3)}</div></div>
     <div style="background:var(--surf2);border:1px solid var(--bdr);border-radius:3px;padding:12px 14px;"><div style="font-family:'Space Mono',monospace;font-size:.62rem;color:var(--mut);">MAX FLOW RATE v</div><div style="font-family:'Space Mono',monospace;font-size:1.1rem;color:var(--amb);">${flowRate.toFixed(0)} veh/h</div></div>`;
}

/* ═══ QUEUE ANIMATION ═══ */
let queueInterval=null,qIdx=0,qRunning=false;
function resetQueue(){qRunning=false;clearInterval(queueInterval);qIdx=0;drawQueueStatic();document.getElementById('qBtn').textContent='▶ GO GREEN';}
function drawQueueStatic(){
  const cv=document.getElementById('cQueue');if(!cv)return;
  const ctx=cv.getContext('2d'),W=cv.width,H=cv.height;ctx.clearRect(0,0,W,H);
  const n=+document.getElementById('slQueue').value;
  const cw=32,ch=18,gap=6,startX=20;
  // Road
  ctx.fillStyle='#1a2230';ctx.fillRect(0,H/2-16,W,32);
  ctx.strokeStyle='rgba(255,179,0,.3)';ctx.setLineDash([8,8]);ctx.lineWidth=1;
  ctx.beginPath();ctx.moveTo(0,H/2);ctx.lineTo(W,H/2);ctx.stroke();ctx.setLineDash([]);
  // Stop bar
  ctx.strokeStyle='#fff';ctx.lineWidth=3;ctx.setLineDash([]);
  ctx.beginPath();ctx.moveTo(20+n*(cw+gap)+20,H/2-16);ctx.lineTo(20+n*(cw+gap)+20,H/2+16);ctx.stroke();
  // Signal
  ctx.fillStyle='#111';ctx.fillRect(20+n*(cw+gap)+30,H/2-28,12,28);
  ctx.beginPath();ctx.arc(20+n*(cw+gap)+36,H/2-22,5,0,Math.PI*2);ctx.fillStyle='#ff0000';ctx.shadowColor='#ff0000';ctx.shadowBlur=8;ctx.fill();ctx.shadowBlur=0;
  // Cars
  for(let i=0;i<n;i++){
    const x=startX+(n-1-i)*(cw+gap),y=H/2-ch/2;
    ctx.fillStyle='#2a4a7a';ctx.strokeStyle='#00d4ff';ctx.lineWidth=1;
    ctx.beginPath();ctx.roundRect(x,y,cw,ch,4);ctx.fill();ctx.stroke();
    ctx.fillStyle='rgba(0,212,255,.3)';ctx.fillRect(x+3,y+2,cw-6,ch/2-2);
  }
  document.getElementById('queueResult').textContent=`Queue: ${n} vehicles waiting. Press "GO GREEN" to see discharge.`;
}
function startQueue(){
  if(qRunning)return;
  qRunning=true;qIdx=0;
  const n=+document.getElementById('slQueue').value;
  const h=+document.getElementById('slH').value/10;
  const s=Math.round(3600/h);
  document.getElementById('qBtn').textContent='⏳ Discharging...';
  let t=0;
  clearInterval(queueInterval);
  // Green light first
  const cv=document.getElementById('cQueue');if(!cv)return;
  const ctx=cv.getContext('2d'),W=cv.width,H=cv.height;
  queueInterval=setInterval(()=>{
    ctx.clearRect(0,0,W,H);
    const remaining=n-qIdx;
    ctx.fillStyle='#1a2230';ctx.fillRect(0,H/2-16,W,32);
    ctx.strokeStyle='rgba(255,179,0,.3)';ctx.setLineDash([8,8]);ctx.lineWidth=1;
    ctx.beginPath();ctx.moveTo(0,H/2);ctx.lineTo(W,H/2);ctx.stroke();ctx.setLineDash([]);
    ctx.strokeStyle='#fff';ctx.lineWidth=3;
    ctx.beginPath();ctx.moveTo(20+n*38+20,H/2-16);ctx.lineTo(20+n*38+20,H/2+16);ctx.stroke();
    // Green signal
    ctx.fillStyle='#111';ctx.fillRect(20+n*38+30,H/2-28,12,28);
    ctx.beginPath();ctx.arc(20+n*38+36,H/2-16,5,0,Math.PI*2);ctx.fillStyle='#00ff66';ctx.shadowColor='#00ff66';ctx.shadowBlur=8;ctx.fill();ctx.shadowBlur=0;
    const cw=32,ch=18,gap=6;
    for(let i=0;i<remaining;i++){
      const x=20+(remaining-1-i)*38,y=H/2-ch/2;
      ctx.fillStyle='#2a4a7a';ctx.strokeStyle='#00d4ff';ctx.lineWidth=1;
      ctx.beginPath();ctx.roundRect(x,y,cw,ch,4);ctx.fill();ctx.stroke();
      ctx.fillStyle='rgba(0,212,255,.3)';ctx.fillRect(x+3,y+2,cw-6,ch/2-2);
    }
    document.getElementById('queueResult').textContent=`🟢 GREEN — Discharged: ${qIdx} veh | Remaining: ${remaining} veh | Rate: ${s} veh/hr (h=${h}s)`;
    if(qIdx>=n){clearInterval(queueInterval);document.getElementById('queueResult').textContent=`✓ All ${n} vehicles discharged! Saturation rate: ${s} veh/hr. Time to clear: ~${(n*h).toFixed(0)}s`;document.getElementById('qBtn').textContent='▶ GO GREEN';qRunning=false;return;}
    qIdx++;
    t+=h;
  },Math.round(h*1000));
}

/* ═══ SIGNAL TIMING ANIMATOR ═══ */
let sigRunning=false,sigT=0,sigAF=null,sigLast=null;
function initSignal(){sigT=0;}
function toggleSignal(){sigRunning=!sigRunning;document.getElementById('sigBtn').textContent=sigRunning?'⏸ PAUSE':'▶ START';if(sigRunning)sigLoop();else if(sigAF)cancelAnimationFrame(sigAF);}
function sigLoop(ts){if(!sigRunning)return;if(sigLast)sigT=(sigT+(ts-sigLast)/1000)%(+document.getElementById('slCyc').value);sigLast=ts;drawSignal();sigAF=requestAnimationFrame(sigLoop);}
function drawSignal(){
  const cv=document.getElementById('cSig');if(!cv)return;
  const C=+document.getElementById('slCyc').value,G1=+document.getElementById('slG1').value;
  const y=3,ar=2,tL=4;const r1=C-G1,G2=Math.max(4,r1-y-ar-y-ar),g2=G2-tL+y+ar;
  const ctx=cv.getContext('2d'),W=cv.width,H=cv.height;ctx.clearRect(0,0,W,H);
  const t=sigT;
  const progW=W-80;
  ctx.fillStyle='var(--surf2)';ctx.fillRect(40,H*.15,progW,12);
  ctx.fillStyle='rgba(0,212,255,.3)';ctx.fillRect(40,H*.15,progW*(t/C),12);
  ctx.font='9px JetBrains Mono,monospace';ctx.fillStyle='#5a7a99';ctx.textAlign='left';ctx.fillText('t='+t.toFixed(1)+'s / C='+C+'s',40,H*.15-6);
  const bH=28,gap=10,bY=H*.32;
  const drawBar=(y0,label,segs)=>{
    ctx.font='9px JetBrains Mono,monospace';ctx.fillStyle='#5a7a99';ctx.textAlign='right';ctx.fillText(label,36,y0+bH/2+4);
    let cx2=40;segs.forEach(s=>{const sw=progW*s.dur/C;ctx.fillStyle=s.col;ctx.fillRect(cx2,y0,sw,bH);if(sw>20){ctx.font='9px JetBrains Mono,monospace';ctx.fillStyle='rgba(0,0,0,.8)';ctx.textAlign='center';ctx.fillText(s.lbl,cx2+sw/2,y0+bH/2+4);}cx2+=sw;});
    const tx=40+progW*(t/C);ctx.strokeStyle='#fff';ctx.lineWidth=2;ctx.beginPath();ctx.moveTo(tx,y0-3);ctx.lineTo(tx,y0+bH+3);ctx.stroke();
  };
  drawBar(bY,'Φ1',[{dur:G1,col:'#00ffa3',lbl:'G='+G1+'s'},{dur:y,col:'#ffb300',lbl:'Y'},{dur:ar,col:'#444',lbl:'AR'},{dur:r1,col:'#ff4d6d',lbl:'R='+r1+'s'}]);
  const r2=G1+y+ar;
  drawBar(bY+bH+gap,'Φ2',[{dur:r2,col:'#ff4d6d',lbl:'R='+r2+'s'},{dur:G2,col:'#00ffa3',lbl:'G≈'+G2+'s'},{dur:y,col:'#ffb300',lbl:'Y'},{dur:ar,col:'#444',lbl:'AR'}]);
  const headX=W-90,h1Y=bY-10,h2Y=bY+bH*2+gap+25;
  [h1Y,h2Y].forEach((hy,pi)=>{
    const isGreen=pi===0?t<G1:t>=G1+y+ar&&t<G1+y+ar+G2;
    const isYellow=pi===0?(t>=G1&&t<G1+y):t>=G1+y+ar+G2&&t<G1+y+ar+G2+y;
    const isRed=!isGreen&&!isYellow;
    ctx.fillStyle='#111';ctx.beginPath();ctx.roundRect(headX-14,hy,28,70,4);ctx.fill();
    [{c:'#ff4d6d',y:hy+12,on:isRed},{c:'#ffb300',y:hy+32,on:isYellow},{c:'#00ffa3',y:hy+52,on:isGreen}].forEach(l=>{
      ctx.beginPath();ctx.arc(headX,l.y,8,0,Math.PI*2);
      if(l.on){ctx.fillStyle=l.c;ctx.shadowColor=l.c;ctx.shadowBlur=12;}else{ctx.fillStyle='#222';ctx.shadowBlur=0;}
      ctx.fill();ctx.shadowBlur=0;
    });
  });
  const phase=t<G1?'Φ1 GREEN':t<G1+y?'Φ1 YELLOW':t<G1+y+ar?'ALL RED':t<G1+y+ar+G2?'Φ2 GREEN':t<G1+y+ar+G2+y?'Φ2 YELLOW':'ALL RED';
  const pc=phase.includes('GREEN')?'var(--teal)':phase.includes('YELLOW')?'var(--amb)':'var(--mut)';
  document.getElementById('sigPhase').textContent=phase;document.getElementById('sigPhase').style.color=pc;
  document.getElementById('sigStats').innerHTML=`C=${C}s | G₁=${G1}s | Y=${y}s | AR=${ar}s | g₁≈${G1-tL+y+ar}s | G₂=${G2}s | g₂≈${g2}s | Lost/cycle≈${tL*2}s`;
}

/* ═══ CALCULATORS ═══ */
function calcVC(){
  const v=+document.getElementById('cv_v').value,s=+document.getElementById('cv_s').value;
  const g=+document.getElementById('cv_g').value,C=+document.getElementById('cv_C').value;
  const cap=s*(g/C),X=v/cap;
  const col=X<.7?'var(--teal)':X<.9?'var(--teal)':X<1?'var(--amb)':'var(--red)';
  document.getElementById('vcR').innerHTML=
    `<div class="ri"><div class="rilbl">g/C</div><div class="rival">${(g/C).toFixed(3)}</div></div>
     <div class="ri"><div class="rilbl">Capacity c</div><div class="rival">${cap.toFixed(0)} veh/h</div></div>
     <div class="ri"><div class="rilbl">X = v/c</div><div class="rival" style="color:${col}">${X.toFixed(3)}</div></div>
     <div class="ri"><div class="rilbl">Status</div><div class="rival" style="color:${X<1?'var(--teal)':'var(--red)'}">${X<1?'✓ OK':'✗ FAIL'}</div></div>`;
}
function calcDelay(){
  const C=+document.getElementById('dc_C').value,g=+document.getElementById('dc_g').value;
  const v=+document.getElementById('dc_v').value,s=+document.getElementById('dc_s').value;
  const cap=s*(g/C),X=v/cap,gc=g/C;
  const d1=0.5*C*Math.pow(1-gc,2)/(1-Math.min(1,X)*gc);
  const los=d1<=10?'A':d1<=20?'B':d1<=35?'C':d1<=55?'D':d1<=80?'E':'F';
  const lc={'A':'stA','B':'stB','C':'stC','D':'stD','E':'stE','F':'stF'};
  document.getElementById('dR').innerHTML=
    `<div class="ri"><div class="rilbl">v/c (X)</div><div class="rival" style="color:${X<1?'var(--teal)':'var(--red)'}">${X.toFixed(3)}</div></div>
     <div class="ri"><div class="rilbl">Capacity</div><div class="rival">${cap.toFixed(0)} veh/h</div></div>
     <div class="ri"><div class="rilbl">d₁ (s/veh)</div><div class="rival" style="color:var(--amb)">${X>=1?'N/A (LOS F)':d1.toFixed(2)}</div></div>
     <div class="ri"><div class="rilbl">LOS</div><div class="rival"><span class="spill ${lc[los]}">${X>1?'F':los}</span></div></div>`;
  const s2=document.getElementById('dSteps');s2.style.display='block';
  s2.textContent=`g/C = ${g}/${C} = ${gc.toFixed(4)}\nc = ${s}×${gc.toFixed(4)} = ${cap.toFixed(0)} veh/h\nX = ${v}/${cap.toFixed(0)} = ${X.toFixed(4)}\n`+(X>=1?'X ≥ 1.0 → LOS F (queue grows indefinitely)':
  `d₁ = 0.5×${C}×(1−${gc.toFixed(3)})² / [1−min(1,${X.toFixed(3)})×${gc.toFixed(3)}]\n   = ${(0.5*C*Math.pow(1-gc,2)).toFixed(2)} / ${(1-Math.min(1,X)*gc).toFixed(4)}\n   = ${d1.toFixed(2)} s/veh → LOS ${los}`);
}
function drawDelayCurve(){
  const cv=document.getElementById('cDelayCurve');if(!cv)return;
  const ctx=cv.getContext('2d'),W=cv.width,H=cv.height;ctx.clearRect(0,0,W,H);
  const C=+document.getElementById('slDC').value,gc=+document.getElementById('slGC').value/100;
  const ox=56,oy=H-36,aw=W-76,ah=H-52,delMax=120;
  ctx.strokeStyle='rgba(0,212,255,.08)';ctx.lineWidth=.8;
  for(let i=0;i<=10;i++){const y=oy-ah*i/10;ctx.beginPath();ctx.moveTo(ox,y);ctx.lineTo(ox+aw,y);ctx.stroke();}
  ctx.strokeStyle='rgba(0,212,255,.3)';ctx.lineWidth=1.5;ctx.beginPath();ctx.moveTo(ox,oy-ah);ctx.lineTo(ox,oy);ctx.lineTo(ox+aw+6,oy);ctx.stroke();
  ctx.font='9px JetBrains Mono,monospace';ctx.textAlign='center';ctx.fillStyle='#5a7a99';
  ctx.fillText('v/c ratio (X)',ox+aw/2,oy+24);
  ctx.save();ctx.translate(13,oy-ah/2);ctx.rotate(-Math.PI/2);ctx.fillText('Delay d₁ (s/veh)',0,0);ctx.restore();
  ctx.beginPath();
  for(let xi=0;xi<=98;xi++){
    const X=xi/100,d1=0.5*C*Math.pow(1-gc,2)/(1-Math.min(1,X)*gc);
    const px=ox+aw*xi/100,py=oy-ah*Math.min(d1/delMax,1);
    if(xi===0)ctx.moveTo(px,py);else if(d1<=delMax)ctx.lineTo(px,py);else break;
  }
  ctx.strokeStyle='#00ffa3';ctx.lineWidth=2;ctx.stroke();
  [{d:10,c:'#00ffa3',l:'A'},{d:20,c:'#00d4ff',l:'B'},{d:35,c:'#a78bfa',l:'C'},{d:55,c:'#ffb300',l:'D'},{d:80,c:'#ff6400',l:'E'}].forEach(({d,c,l})=>{
    const y=oy-ah*d/delMax;ctx.strokeStyle=c;ctx.lineWidth=.8;ctx.setLineDash([3,4]);ctx.beginPath();ctx.moveTo(ox,y);ctx.lineTo(ox+aw,y);ctx.stroke();ctx.setLineDash([]);
    ctx.font='bold 9px JetBrains Mono,monospace';ctx.textAlign='left';ctx.fillStyle=c;ctx.fillText(l,ox+aw+4,y+3);
  });
  ctx.fillStyle='#5a7a99';ctx.font='9px JetBrains Mono,monospace';ctx.textAlign='center';
  [0,.2,.4,.6,.8,1.0].forEach(x=>{ctx.fillText(x.toFixed(1),ox+aw*x,oy+16);});
  ctx.textAlign='right';[0,20,40,60,80,100].forEach(d=>{ctx.fillText(d,ox-4,oy-ah*d/delMax+3);});
  ctx.font='bold 10px JetBrains Mono,monospace';ctx.textAlign='left';ctx.fillStyle='#00d4ff';
  ctx.fillText(`C=${C}s, g/C=${gc.toFixed(2)}`,ox+8,oy-ah+14);
}

/* ═══ GRAVITY MODEL ═══ */
function calcGravity(){
  const P=[+document.getElementById('gP1').value,+document.getElementById('gP2').value,+document.getElementById('gP3').value];
  const A=[+document.getElementById('gA1').value,+document.getElementById('gA2').value,+document.getElementById('gA3').value];
  const t=[[+document.getElementById('gt11').value,+document.getElementById('gt12').value,+document.getElementById('gt13').value],
           [+document.getElementById('gt21').value,+document.getElementById('gt22').value,+document.getElementById('gt23').value],
           [2,8,2]];
  const F=t.map(row=>row.map(tv=>tv>0?1/(tv*tv):0));
  const T=P.map((Pi,i)=>{const denom=A.reduce((sum,Aj,j)=>sum+Aj*F[i][j],0);if(denom===0)return[0,0,0];return A.map((Aj,j)=>Math.round(Pi*Aj*F[i][j]/denom));});
  let ffHtml='';for(let i=0;i<3;i++)for(let j=0;j<3;j++){ffHtml+=`<span style="color:var(--amb)">F${i+1}${j+1}</span>=<span style="color:var(--teal)">${F[i][j].toFixed(4)}</span><br>`;}
  document.getElementById('gFF').innerHTML=ffHtml;
  const totCol=[0,1,2].map(j=>T.reduce((s,r)=>s+r[j],0)),grandT=totCol.reduce((a,b)=>a+b,0);
  let html=`<table class="dt"><thead><tr><th>From\To</th><th>Zone 1</th><th>Zone 2</th><th>Zone 3</th><th>Total</th></tr></thead><tbody>`;
  T.forEach((row,i)=>{html+=`<tr><td class="hl">Zone ${i+1}</td>${row.map(v=>`<td>${v}</td>`).join('')}<td style="color:var(--amb)">${P[i]}</td></tr>`;});
  html+=`<tr><td style="color:var(--teal)">Computed Dⱼ</td>${totCol.map(v=>`<td style="color:var(--teal)">${v}</td>`).join('')}<td>${grandT}</td></tr>`;
  html+=`<tr><td style="color:var(--mut)">Given Aⱼ</td>${A.map(v=>`<td style="color:var(--amb)">${v}</td>`).join('')}<td>${A.reduce((a,b)=>a+b,0)}</td></tr>`;
  html+='</tbody></table>';
  document.getElementById('gravityResult').innerHTML=html;
}

/* ═══ LOGIT MODE SPLIT ═══ */
function calcModeSplit(){
  const modes=[
    {n:'Automobile',col:'#00ffa3',a:+document.getElementById('ma_a').value,c:+document.getElementById('ma_c').value,t:+document.getElementById('ma_t').value},
    {n:'Bus',col:'#00d4ff',a:+document.getElementById('mb_a').value,c:+document.getElementById('mb_c').value,t:+document.getElementById('mb_t').value},
    {n:'Light Rail',col:'#a78bfa',a:+document.getElementById('ml_a').value,c:+document.getElementById('ml_c').value,t:+document.getElementById('ml_t').value}
  ];
  modes.forEach(m=>{m.U=m.a-0.002*m.c-0.05*m.t;m.eU=Math.exp(m.U);});
  const sumEU=modes.reduce((s,m)=>s+m.eU,0);
  modes.forEach(m=>{m.P=m.eU/sumEU;m.pct=Math.round(m.P*100);});
  let html=`<table class="dt"><thead><tr><th>Mode</th><th>U</th><th>eᵁ</th><th>P</th><th>%</th></tr></thead><tbody>`;
  modes.forEach(m=>{html+=`<tr><td style="color:${m.col}">${m.n}</td><td>${m.U.toFixed(3)}</td><td>${m.eU.toFixed(3)}</td><td>${m.P.toFixed(3)}</td><td style="color:${m.col};font-weight:600;">${m.pct}%</td></tr>`;});
  html+=`</tbody></table>`;
  document.getElementById('modeResult').innerHTML=html;
  const cv=document.getElementById('cModePie');if(!cv)return;
  szC('cModePie');
  const ctx=cv.getContext('2d'),W=cv.width,H=cv.height;ctx.clearRect(0,0,W,H);
  const cxP=W*.35,cyP=H/2,r=Math.min(W*.28,H*.4);
  let start=0;
  modes.forEach(m=>{
    const end=start+m.P*Math.PI*2;
    ctx.beginPath();ctx.moveTo(cxP,cyP);ctx.arc(cxP,cyP,r,start,end);ctx.closePath();
    ctx.fillStyle=m.col+'cc';ctx.fill();ctx.strokeStyle='#060b14';ctx.lineWidth=2;ctx.stroke();
    const mid=(start+end)/2,lx=cxP+r*.7*Math.cos(mid),ly=cyP+r*.7*Math.sin(mid);
    ctx.font='bold 11px JetBrains Mono,monospace';ctx.textAlign='center';ctx.fillStyle='#000';ctx.fillText(m.pct+'%',lx,ly+4);
    start=end;
  });
  modes.forEach((m,i)=>{
    const lx=W*.68,ly=H*.2+i*H*.22;
    ctx.fillStyle=m.col;ctx.fillRect(lx,ly,14,14);
    ctx.font='10px JetBrains Mono,monospace';ctx.textAlign='left';ctx.fillStyle='#8aabcc';ctx.fillText(m.n,lx+20,ly+10);
    ctx.fillStyle=m.col;ctx.font='bold 13px JetBrains Mono,monospace';ctx.fillText(m.pct+'%',lx+20,ly+26);
  });
}

/* ═══ TOC ACTIVE ═══ */
const tocAs=document.querySelectorAll('.toc a');
const obs=new IntersectionObserver(es=>{es.forEach(e=>{if(e.isIntersecting){tocAs.forEach(a=>a.classList.remove('act'));const l=document.querySelector(`.toc a[href="#${e.target.id}"]`);if(l)l.classList.add('act');}});},{rootMargin:'-10% 0px -75% 0px'});
document.querySelectorAll('section.sec').forEach(s=>{if(s.id)obs.observe(s);});

/* ═══ INIT ═══ */
szAll();calcPHF();drawSignal();drawDelayCurve();drawQueueStatic();
document.fonts.ready.then(()=>{szAll();redrawAll();drawQueueStatic();});
</script>
