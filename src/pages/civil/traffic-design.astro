---
import Main from '../../layouts/Main.astro';
---
<Main title="Traffic Analysis & Design — CEE350" description="CEE 350 traffic flow theory, signal timing, LOS, trip generation and mode split with interactive calculators." activeNav="civil">
<style is:inline>
/* ─── HERO ─── */
.hero{position:relative;z-index:1;padding:70px 60px 56px;max-width:1100px;margin:0 auto;}
.hero-tag{display:inline-flex;align-items:center;gap:8px;font-family:'Space Mono',monospace;font-size:.65rem;letter-spacing:.15em;color:var(--teal);border:1px solid rgba(0,212,255,.3);padding:5px 14px;border-radius:2px;margin-bottom:20px;text-transform:uppercase;}
.hero h1{font-family:'Space Mono',sans-serif;font-weight:800;font-size:clamp(2.2rem,5vw,3.6rem);line-height:1.05;margin-bottom:18px;}
.hero h1 span{color:var(--teal);}
.hero-lead{font-size:1.05rem;color:var(--txt2);max-width:640px;margin-bottom:32px;line-height:1.8;}
.hero-stats{display:flex;gap:32px;flex-wrap:wrap;}
.hs{border-left:2px solid var(--bdr);padding-left:14px;}
.hs strong{display:block;font-family:'Space Mono',sans-serif;font-weight:700;font-size:1.4rem;color:var(--teal);}
.hs span{font-family:'Space Mono',monospace;font-size:.68rem;color:var(--mut);}

/* ─── LAYOUT ─── */
.wrap{display:grid;grid-template-columns:200px 1fr;max-width:1200px;margin:0 auto;position:relative;z-index:1;}
.toc{position:sticky;top:56px;height:calc(100vh - 56px);overflow-y:auto;padding:20px 0 20px 28px;border-right:1px solid var(--bdr);}
.toclbl{font-family:'Space Mono',monospace;font-size:.58rem;letter-spacing:.16em;color:var(--mut);margin-bottom:12px;text-transform:uppercase;}
.toc ul{list-style:none;}
.toc li{margin-bottom:2px;}
.toc a{display:block;font-family:'Space Mono',monospace;font-size:.68rem;color:var(--mut);text-decoration:none;padding:3px 8px;border-left:2px solid transparent;transition:all .15s;}
.toc a:hover,.toc a.act{color:var(--teal);border-left-color:var(--teal);background:var(--tdim);}
.content{padding:0 48px 80px;}

/* ─── SECTIONS ─── */
.sec{padding:60px 0 20px;border-top:1px solid var(--bdr);}
.sec:first-child{border-top:none;padding-top:36px;}
.snum{font-family:'Space Mono',monospace;font-size:.62rem;letter-spacing:.18em;color:var(--mut);margin-bottom:8px;text-transform:uppercase;}
.sec h2{font-family:'Space Mono',sans-serif;font-weight:800;font-size:clamp(1.5rem,3vw,2.1rem);line-height:1.15;margin-bottom:12px;}
.sec h2 em{color:var(--teal);font-style:normal;}
.sec h2 .cy{color:var(--teal);}
.lead{color:var(--txt2);font-size:.97rem;max-width:680px;margin-bottom:28px;line-height:1.8;}
h3{font-family:'Space Mono',sans-serif;font-weight:700;font-size:1rem;color:var(--teal);margin:24px 0 10px;}

/* ─── CARDS ─── */
.cg{display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:12px;margin:16px 0;}
.cc{background:var(--surf);border:1px solid var(--bdr);border-radius:4px;padding:18px;transition:border-color .2s,transform .2s;}
.cc:hover{border-color:rgba(0,255,163,.3);transform:translateY(-2px);}
.ci{font-size:1.5rem;margin-bottom:10px;}
.cc h4{font-family:'Space Mono',sans-serif;font-size:.9rem;font-weight:700;margin-bottom:6px;}
.cc p{font-size:.82rem;color:var(--txt2);line-height:1.55;}
.cval{font-family:'Space Mono',monospace;color:var(--teal);font-size:.8rem;margin-top:8px;display:block;}

/* ─── CALLOUTS ─── */
.analogy{background:linear-gradient(135deg,rgba(0,255,163,.05),rgba(0,212,255,.05));border:1px solid rgba(0,255,163,.2);border-left:3px solid var(--teal);border-radius:4px;padding:14px 18px;margin:14px 0;font-size:.9rem;color:var(--txt2);position:relative;}
.analogy::before{content:'🧠 ANALOGY';display:block;font-family:'Space Mono',monospace;font-size:.58rem;letter-spacing:.15em;color:var(--teal);margin-bottom:5px;}
.analogy strong{color:var(--teal);}
.infobox{background:rgba(0,212,255,.04);border:1px solid rgba(0,212,255,.2);border-radius:4px;padding:13px 17px;margin:12px 0;font-size:.87rem;color:var(--txt2);}
.infobox strong{color:var(--teal);}
.warn{background:rgba(255,179,0,.04);border:1px solid rgba(255,179,0,.2);border-radius:4px;padding:13px 17px;margin:12px 0;font-size:.87rem;color:var(--txt2);}
.warn strong{color:var(--amb);}

/* ─── EQ BOX ─── */
.eq{background:var(--surf);border:1px solid var(--bdr);border-left:3px solid var(--amb);border-radius:4px;padding:14px 20px;margin:12px 0;}
.eqlbl{font-family:'Space Mono',monospace;font-size:.6rem;letter-spacing:.12em;color:var(--amb);margin-bottom:6px;text-transform:uppercase;}
.eqbody{font-family:'Space Mono',monospace;font-size:.95rem;color:var(--txt);overflow-x:auto;padding:4px 0;}
.eqnote{font-size:.8rem;color:var(--mut);margin-top:6px;line-height:1.5;}
.eqnote code{font-family:'Space Mono',monospace;background:var(--surf2);color:var(--teal);padding:1px 5px;border-radius:2px;font-size:.78rem;}

/* ─── SIM ─── */
.sim{background:var(--surf);border:1px solid var(--bdr);border-radius:6px;overflow:hidden;margin:20px 0;}
.simhdr{background:var(--surf2);padding:10px 18px;border-bottom:1px solid var(--bdr);display:flex;align-items:center;gap:10px;flex-wrap:wrap;}
.simtitle{font-family:'Space Mono',monospace;font-size:.65rem;letter-spacing:.08em;color:var(--teal);text-transform:uppercase;}
.simbody{padding:18px;}
canvas{display:block;width:100%;}
.crow{display:flex;align-items:center;gap:12px;margin-top:12px;flex-wrap:wrap;}
.clbl{font-family:'Space Mono',monospace;font-size:.7rem;color:var(--mut);}
input[type=range]{-webkit-appearance:none;height:3px;background:var(--bdr);border-radius:2px;outline:none;}
input[type=range]::-webkit-slider-thumb{-webkit-appearance:none;width:14px;height:14px;background:var(--teal);border-radius:50%;cursor:pointer;}
.cval2{font-family:'Space Mono',monospace;font-size:.85rem;color:var(--teal);min-width:70px;}
.sbtn{font-family:'Space Mono',monospace;font-size:.68rem;padding:5px 14px;background:var(--teal);color:#000;border:none;border-radius:2px;cursor:pointer;transition:opacity .2s;font-weight:600;}
.sbtn:hover{opacity:.8;}
.sbtn.sec2{background:transparent;color:var(--teal);border:1px solid rgba(0,212,255,.3);}
.sbtn.sec2:hover{background:var(--tdim);}
.spill{padding:3px 10px;border-radius:2px;font-family:'Space Mono',monospace;font-size:.68rem;font-weight:600;letter-spacing:.04em;}
.stA{background:rgba(0,255,163,.1);color:var(--teal);border:1px solid rgba(0,255,163,.3);}
.stB{background:rgba(0,212,255,.1);color:var(--teal);border:1px solid rgba(0,212,255,.3);}
.stC{background:rgba(167,139,250,.1);color:var(--violet);border:1px solid rgba(167,139,250,.3);}
.stD{background:rgba(255,179,0,.1);color:var(--amb);border:1px solid rgba(255,179,0,.3);}
.stE{background:rgba(255,100,0,.1);color:#ff6400;border:1px solid rgba(255,100,0,.3);}
.stF{background:rgba(255,77,109,.1);color:var(--red);border:1px solid rgba(255,77,109,.3);}

/* ─── CALC ─── */
.calc{background:var(--surf);border:1px solid var(--bdr);border-radius:6px;padding:24px;margin:18px 0;}
.calctitle{font-family:'Space Mono',monospace;font-size:.7rem;letter-spacing:.1em;color:var(--teal);text-transform:uppercase;margin-bottom:16px;padding-bottom:12px;border-bottom:1px solid var(--bdr);}
.ig{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;margin-bottom:16px;}
.ig label{display:block;font-family:'Space Mono',monospace;font-size:.65rem;color:var(--mut);letter-spacing:.05em;margin-bottom:4px;text-transform:uppercase;}
.ig input,.ig select{width:100%;background:var(--surf2);border:1px solid var(--bdr);border-radius:3px;padding:8px 10px;color:var(--txt);font-family:'Space Mono',monospace;font-size:.85rem;outline:none;transition:border-color .2s;}
.ig input:focus,.ig select:focus{border-color:var(--teal);}
.ig select option{background:var(--surf2);}
.cbtn{background:var(--teal);color:#000;border:none;padding:10px 22px;border-radius:3px;font-family:'Space Mono',monospace;font-size:.78rem;font-weight:700;cursor:pointer;transition:opacity .2s;letter-spacing:.05em;}
.cbtn:hover{opacity:.85;}
.rg{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:8px;margin-top:16px;}
.ri{background:var(--surf2);border:1px solid var(--bdr);border-radius:3px;padding:12px 14px;}
.rilbl{font-family:'Space Mono',monospace;font-size:.62rem;color:var(--mut);letter-spacing:.05em;text-transform:uppercase;margin-bottom:3px;}
.rival{font-family:'Space Mono',monospace;font-size:1.05rem;color:var(--teal);font-weight:600;}
.csteps{background:var(--surf2);border:1px solid var(--bdr);border-radius:3px;padding:12px 16px;margin-top:12px;font-family:'Space Mono',monospace;font-size:.73rem;color:var(--txt2);line-height:2;display:none;white-space:pre-wrap;}

/* ─── TABLE ─── */
.dt{width:100%;border-collapse:collapse;font-size:.82rem;margin:14px 0;}
.dt th{background:var(--surf2);color:var(--teal);font-family:'Space Mono',monospace;font-size:.66rem;letter-spacing:.08em;padding:9px 13px;text-align:left;text-transform:uppercase;border-bottom:1px solid var(--bdr);}
.dt td{padding:8px 13px;border-bottom:1px solid rgba(255,255,255,.04);color:var(--txt2);font-family:'Space Mono',monospace;font-size:.78rem;}
.dt tr:hover td{background:var(--surf2);}
.dt .hl{color:var(--teal);}

/* ─── LOS BADGES ─── */
.los-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:8px;margin:12px 0;}
.los-item{text-align:center;padding:12px 6px;border-radius:4px;border:1px solid transparent;}
.los-item .los-lbl{font-family:'Space Mono',sans-serif;font-weight:800;font-size:1.3rem;margin-bottom:3px;}
.los-item .los-d{font-family:'Space Mono',monospace;font-size:.65rem;color:rgba(255,255,255,.7);}
.losA{background:rgba(0,255,163,.1);border-color:rgba(0,255,163,.3);}.losA .los-lbl{color:var(--teal);}
.losB{background:rgba(0,212,255,.1);border-color:rgba(0,212,255,.3);}.losB .los-lbl{color:var(--teal);}
.losC{background:rgba(167,139,250,.1);border-color:rgba(167,139,250,.3);}.losC .los-lbl{color:var(--violet);}
.losD{background:rgba(255,179,0,.1);border-color:rgba(255,179,0,.3);}.losD .los-lbl{color:var(--amb);}
.losE{background:rgba(255,100,0,.1);border-color:rgba(255,100,0,.3);}.losE .los-lbl{color:#ff6400;}
.losF{background:rgba(255,77,109,.1);border-color:rgba(255,77,109,.3);}.losF .los-lbl{color:var(--red);}

/* ─── PRACTICE PROBLEMS ─── */
.pp-section{margin:28px 0;}
.pp-title{font-family:'Space Mono',sans-serif;font-weight:700;font-size:1rem;color:var(--amb);margin-bottom:16px;display:flex;align-items:center;gap:8px;}
.pp-title::before{content:'📝';font-size:1rem;}
.pp{background:var(--surf);border:1px solid rgba(255,179,0,.2);border-left:3px solid var(--amb);border-radius:4px;margin-bottom:12px;overflow:hidden;}
.pp-q{padding:14px 18px;cursor:pointer;display:flex;justify-content:space-between;align-items:flex-start;gap:12px;}
.pp-q:hover{background:rgba(255,179,0,.04);}
.pp-qnum{font-family:'Space Mono',monospace;font-size:.62rem;color:var(--amb);white-space:nowrap;margin-top:2px;}
.pp-qtext{font-size:.88rem;color:var(--txt);line-height:1.6;flex:1;}
.pp-arrow{font-family:'Space Mono',monospace;font-size:.8rem;color:var(--amb);transition:transform .3s;flex-shrink:0;}
.pp-arrow.open{transform:rotate(90deg);}
.pp-sol{display:none;padding:0 18px 18px;border-top:1px solid rgba(255,179,0,.1);}
.pp-sol.show{display:block;}
.pp-hint{background:rgba(0,255,163,.05);border:1px solid rgba(0,255,163,.1);border-radius:3px;padding:10px 14px;margin:12px 0;font-size:.82rem;color:var(--txt2);}
.pp-hint strong{color:var(--teal);font-family:'Space Mono',monospace;font-size:.7rem;display:block;margin-bottom:4px;}
.pp-steps{background:var(--surf2);border:1px solid var(--bdr);border-radius:3px;padding:14px 18px;font-family:'Space Mono',monospace;font-size:.77rem;color:var(--txt2);line-height:2.1;margin:10px 0;}
.pp-steps .step{color:var(--teal);font-weight:600;}
.pp-ans{font-family:'Space Mono',monospace;font-size:.88rem;color:var(--teal);font-weight:700;background:rgba(0,255,163,.08);border:1px solid rgba(0,255,163,.2);border-radius:3px;padding:8px 14px;display:inline-block;margin-top:8px;}

/* ─── ANIMATED TRAFFIC LIGHT ─── */
.tl-demo{display:flex;gap:32px;align-items:flex-start;flex-wrap:wrap;margin:20px 0;}
.tl-signal{display:flex;flex-direction:column;align-items:center;gap:8px;}
.tl-pole{width:6px;height:60px;background:linear-gradient(to bottom,var(--mut),#2a3a4a);border-radius:3px;}
.tl-arm{width:80px;height:6px;background:linear-gradient(to right,#2a3a4a,var(--mut));border-radius:3px;align-self:flex-end;margin-bottom:-3px;}
.tl-box{background:#1a1a1a;border:2px solid #333;border-radius:8px;padding:10px 8px;display:flex;flex-direction:column;gap:8px;box-shadow:0 4px 20px rgba(0,0,0,.6);}
.tl-lens{width:36px;height:36px;border-radius:50%;border:2px solid #2a2a2a;position:relative;transition:all .3s;}
.tl-lens.active-red{background:radial-gradient(circle at 35% 35%,#ff8080,#ff0000);box-shadow:0 0 20px #ff000088,0 0 40px #ff000044;}
.tl-lens.active-yellow{background:radial-gradient(circle at 35% 35%,#ffe080,#ffb300);box-shadow:0 0 20px #ffb30088,0 0 40px #ffb30044;}
.tl-lens.active-green{background:radial-gradient(circle at 35% 35%,#80ffc0,#00ff66);box-shadow:0 0 20px #00ff6688,0 0 40px #00ff6644;}
.tl-lens.off{background:#1a1a1a;}
.tl-lbl{font-family:'Space Mono',monospace;font-size:.65rem;color:var(--mut);text-align:center;}
.tl-status{font-family:'Space Mono',monospace;font-size:.75rem;padding:4px 12px;border-radius:2px;text-align:center;min-width:80px;}
.tl-timer{font-family:'Space Mono',sans-serif;font-weight:800;font-size:2rem;color:var(--teal);min-width:60px;text-align:center;}

/* ─── INTERSECTION ANIMATION ─── */
.intersect-wrap{background:var(--surf);border:1px solid var(--bdr);border-radius:6px;padding:20px;margin:20px 0;}
.intersect-scene{position:relative;width:100%;height:320px;overflow:hidden;}
/* Roads */
.road-h{position:absolute;top:50%;left:0;right:0;height:64px;transform:translateY(-50%);background:#1a2230;}
.road-v{position:absolute;left:50%;top:0;bottom:0;width:64px;transform:translateX(-50%);background:#1a2230;}
.road-line-h{position:absolute;top:50%;left:0;right:0;height:2px;transform:translateY(-50%);background:repeating-linear-gradient(90deg,var(--amb) 0,var(--amb) 20px,transparent 20px,transparent 40px);opacity:.4;animation:dashH 1s linear infinite;}
.road-line-v{position:absolute;left:50%;top:0;bottom:0;width:2px;transform:translateX(-50%);background:repeating-linear-gradient(180deg,var(--amb) 0,var(--amb) 20px,transparent 20px,transparent 40px);opacity:.4;animation:dashV 1s linear infinite;}
@keyframes dashH{from{background-position:0 0;}to{background-position:-40px 0;}}
@keyframes dashV{from{background-position:0 0;}to{background-position:0 -40px;}}
.intersection-box{position:absolute;left:50%;top:50%;width:64px;height:64px;transform:translate(-50%,-50%);background:#1a2230;}
/* Vehicles */
.vehicle{position:absolute;width:28px;height:16px;border-radius:4px;transition:background .3s;}
.v-going{animation-timing-function:linear;animation-iteration-count:infinite;}
.v-east{top:calc(50% - 24px);animation-name:moveEast;}
.v-west{top:calc(50% + 8px);animation-name:moveWest;}
.v-south{left:calc(50% + 8px);animation-name:moveSouth;width:16px;height:28px;}
.v-north{left:calc(50% - 24px);animation-name:moveNorth;width:16px;height:28px;}
@keyframes moveEast{0%{left:-40px}100%{left:calc(100% + 40px)}}
@keyframes moveWest{0%{right:-40px;left:auto;transform:scaleX(-1)}100%{right:calc(100% + 40px);left:auto;transform:scaleX(-1)}}
@keyframes moveSouth{0%{top:-40px}100%{top:calc(100% + 40px)}}
@keyframes moveNorth{0%{bottom:-40px;top:auto;transform:scaleY(-1)}100%{bottom:calc(100% + 40px);top:auto;transform:scaleY(-1)}}
/* Signal heads on intersection */
.sig-head{position:absolute;width:14px;height:36px;background:#111;border-radius:4px;border:1px solid #333;display:flex;flex-direction:column;align-items:center;justify-content:space-evenly;padding:2px;}
.sig-dot{width:8px;height:8px;border-radius:50%;background:#1a1a1a;}
.sig-ne{top:calc(50% - 52px);right:calc(50% - 68px);}
.sig-sw{bottom:calc(50% - 52px);left:calc(50% - 68px);}
.sig-nw{top:calc(50% - 52px);left:calc(50% - 68px);}
.sig-se{bottom:calc(50% - 52px);right:calc(50% - 68px);}
.sd-red.on{background:#ff0000;box-shadow:0 0 6px #ff0000;}
.sd-yellow.on{background:#ffb300;box-shadow:0 0 6px #ffb300;}
.sd-green.on{background:#00ff66;box-shadow:0 0 6px #00ff66;}
/* Queue buildup */
.queue-wrap{margin:16px 0;}
.queue-car{display:inline-block;width:32px;height:18px;background:#2a4a7a;border:1px solid var(--teal);border-radius:4px;margin:2px;position:relative;transition:transform .4s,opacity .4s;}
.queue-car::after{content:'';position:absolute;top:2px;left:4px;right:4px;height:6px;background:rgba(0,212,255,.3);border-radius:2px;}

/* ─── FORMULA SHEET ─── */
.fsgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:12px;margin-top:18px;}
.fscard{background:var(--surf);border:1px solid var(--bdr);border-radius:4px;padding:16px 20px;}
.fscard.key{border-left:3px solid var(--teal);}
.fscat{font-family:'Space Mono',monospace;font-size:.58rem;text-transform:uppercase;letter-spacing:.14em;color:var(--mut);margin-bottom:4px;}
.fsname{font-family:'Space Mono',sans-serif;font-weight:700;font-size:.88rem;margin-bottom:8px;color:var(--txt);}
.fseq{font-family:'Space Mono',monospace;font-size:.82rem;background:var(--surf2);padding:6px 10px;border-radius:2px;margin-bottom:4px;color:var(--amb);overflow-x:auto;}
.fsnote{font-size:.74rem;color:var(--mut);line-height:1.5;}

/* ─── EXAM TIPS ─── */
.tip-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:12px;margin:16px 0;}
.tip{background:var(--surf);border:1px solid rgba(167,139,250,.2);border-left:3px solid var(--violet);border-radius:4px;padding:14px 18px;}
.tip-num{font-family:'Space Mono',sans-serif;font-weight:800;font-size:1.3rem;color:var(--violet);margin-bottom:6px;}
.tip h4{font-family:'Space Mono',sans-serif;font-size:.88rem;color:var(--txt);margin-bottom:6px;}
.tip p{font-size:.8rem;color:var(--txt2);line-height:1.55;}

/* ─── RESPONSIVE ─── */
@media(max-width:900px){.wrap{grid-template-columns:1fr;}.toc{display:none;}.content{padding:0 20px 60px;}.hero{padding:40px 24px 36px;}.los-grid{grid-template-columns:repeat(3,1fr);}}
@media(max-width:580px){.tl-demo{justify-content:center;}}
</style>

<div class="hero">
  <div class="hero-tag">🎓 CEE 350 · Traffic Analysis & Design · Spring 2026</div>
