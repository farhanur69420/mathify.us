<script is:inline>
// ─── SHARED CANVAS UTILS ────────────────────────────────────
function dpr(canvas) {
  const r = window.devicePixelRatio || 1;
  canvas.width = canvas.clientWidth * r;
  canvas.height = canvas.clientHeight * r;
  const ctx = canvas.getContext('2d');
  ctx.scale(r, r);
  return { ctx, w: canvas.clientWidth, h: canvas.clientHeight };
}
const C = {
  bg:        '#0d0d14',
  surface:   '#111118',
  surface2:  '#1a1a24',
  blueprint: '#4ec9b0',
  blueprintD:'rgba(78,201,176,0.2)',
  rust:      '#c0392b',
  rustD:     'rgba(192,57,43,0.25)',
  amber:     '#d4a94a',
  amberD:    'rgba(212,169,74,0.2)',
  text:      '#e8e8f0',
  textMuted: '#9090a8',
  textDim:   '#5a5a72',
  grid:      'rgba(255,255,255,0.05)',
};

function drawGrid(ctx, w, h, padL, padT, padR, padB) {
  const iw = w - padL - padR, ih = h - padT - padB;
  ctx.strokeStyle = C.grid;
  ctx.lineWidth = 1;
  const nx = 8, ny = 6;
  for (let i = 0; i <= nx; i++) {
    const x = padL + (i / nx) * iw;
    ctx.beginPath(); ctx.moveTo(x, padT); ctx.lineTo(x, padT + ih); ctx.stroke();
  }
  for (let i = 0; i <= ny; i++) {
    const y = padT + (i / ny) * ih;
    ctx.beginPath(); ctx.moveTo(padL, y); ctx.lineTo(padL + iw, y); ctx.stroke();
  }
}

function label(ctx, txt, x, y, color, size, align) {
  ctx.font = `${size || 11}px 'Space Mono', monospace`;
  ctx.fillStyle = color || C.textMuted;
  ctx.textAlign = align || 'center';
  ctx.fillText(txt, x, y);
}

// ─── CANVAS 1: RC BEAM ──────────────────────────────────────
(function() {
  const canvas = document.getElementById('canvas-beam');
  let animId, running = true, t = 0;

  function draw() {
    const cw = canvas.clientWidth || 780, ch = canvas.clientHeight || 340;
    canvas.width = cw; canvas.height = ch;
    const ctx = canvas.getContext('2d');

    ctx.fillStyle = C.bg;
    ctx.fillRect(0, 0, cw, ch);

    const load = (Math.sin(t * 0.7) * 0.5 + 0.5);
    const bx = cw * 0.12, bw = cw * 0.76;
    const by = ch * 0.25, bh = ch * 0.35;
    const cx = bx + bw / 2, na = by + bh * 0.4;
    const deflect = load * ch * 0.04;

    // Compression zone gradient
    const cg = ctx.createLinearGradient(bx, by, bx, na);
    cg.addColorStop(0, `rgba(78,201,176,${0.15 + load * 0.25})`);
    cg.addColorStop(1, 'rgba(78,201,176,0)');
    ctx.fillStyle = cg;
    ctx.fillRect(bx, by, bw, na - by);

    // Tension zone gradient
    const tg = ctx.createLinearGradient(bx, na, bx, by + bh + deflect);
    tg.addColorStop(0, 'rgba(192,57,43,0)');
    tg.addColorStop(1, `rgba(192,57,43,${0.12 + load * 0.3})`);
    ctx.fillStyle = tg;
    ctx.fillRect(bx, na, bw, bh - (na - by) + deflect);

    // Beam outline with deflection
    ctx.beginPath();
    ctx.moveTo(bx, by);
    ctx.lineTo(bx + bw, by);
    const midBot = by + bh + deflect;
    ctx.lineTo(bx + bw, by + bh);
    ctx.quadraticCurveTo(cx, midBot, bx, by + bh);
    ctx.closePath();
    ctx.strokeStyle = C.textDim;
    ctx.lineWidth = 1;
    ctx.stroke();

    // Neutral axis
    ctx.setLineDash([8, 5]);
    ctx.beginPath();
    ctx.moveTo(bx, na);
    ctx.lineTo(bx + bw, na);
    ctx.strokeStyle = C.amber;
    ctx.lineWidth = 1.5;
    ctx.stroke();
    ctx.setLineDash([]);
    label(ctx, 'Neutral Axis', bx + bw + 8, na + 4, C.amber, 10, 'left');

    // Steel bars (3 bars in tension zone)
    [0.2, 0.5, 0.8].forEach(xf => {
      const bxp = bx + bw * xf;
      const byp = by + bh + deflect - ch * 0.06;
      ctx.beginPath();
      ctx.arc(bxp, byp, 5, 0, Math.PI * 2);
      ctx.fillStyle = C.blueprint;
      ctx.fill();
      ctx.strokeStyle = C.bg;
      ctx.lineWidth = 1.5;
      ctx.stroke();
    });
    label(ctx, '3 × #8 Steel Bars', cx, by + bh + deflect - ch * 0.03, C.blueprint, 10);

    // Load arrow
    const arrowLen = 30 + load * 30;
    ctx.beginPath();
    ctx.moveTo(cx, by - arrowLen - 20);
    ctx.lineTo(cx, by - 8);
    ctx.strokeStyle = C.rust;
    ctx.lineWidth = 2;
    ctx.stroke();
    ctx.beginPath();
    ctx.moveTo(cx - 7, by - 14);
    ctx.lineTo(cx, by - 4);
    ctx.lineTo(cx + 7, by - 14);
    ctx.strokeStyle = C.rust;
    ctx.stroke();
    label(ctx, `P = ${(load * 80 + 20).toFixed(0)} kips`, cx + 14, by - arrowLen / 2 - 8, C.rust, 10, 'left');

    // Support triangles
    [[bx, by + bh + deflect], [bx + bw, by + bh]].forEach(([sx, sy]) => {
      ctx.beginPath();
      ctx.moveTo(sx, sy + 2);
      ctx.lineTo(sx - 12, sy + 22);
      ctx.lineTo(sx + 12, sy + 22);
      ctx.closePath();
      ctx.fillStyle = C.textDim;
      ctx.fill();
    });

    // Labels
    label(ctx, 'COMPRESSION (concrete works)', cx, by + (na - by) / 2, C.blueprint, 11);
    label(ctx, 'TENSION (steel works)', cx, na + (bh - (na - by)) / 2 + deflect * 0.6, C.rust, 11);

    if (running) { t += 0.025; animId = requestAnimationFrame(draw); }
  }

  document.getElementById('btn-beam-toggle').addEventListener('click', function() {
    running = !running;
    this.textContent = running ? '⏸ Pause' : '▶ Play';
    if (running) draw();
  });
  document.getElementById('btn-beam-reset').addEventListener('click', () => {
    t = 0; running = true;
    document.getElementById('btn-beam-toggle').textContent = '⏸ Pause';
    cancelAnimationFrame(animId); draw();
  });

  draw();
})();

// ─── CANVAS 2: HYDRATION ────────────────────────────────────
(function() {
  const canvas = document.getElementById('canvas-hydration');
  let animId, running = true, t = 0;

  const particles = [];
  function initParticles(cw, ch) {
    particles.length = 0;
    const N = 60;
    for (let i = 0; i < N; i++) {
      const type = i < 20 ? 'cement' : i < 35 ? 'coarse' : i < 55 ? 'fine' : 'water';
      particles.push({
        x: Math.random() * cw,
        y: Math.random() * ch,
        r: type === 'coarse' ? 9 + Math.random() * 6
           : type === 'fine' ? 3 + Math.random() * 3
           : type === 'cement' ? 4 + Math.random() * 3
           : 3,
        vx: (Math.random() - 0.5) * 0.6,
        vy: (Math.random() - 0.5) * 0.6,
        type,
      });
    }
  }

  function draw() {
    const cw = canvas.clientWidth || 780, ch = 320;
    if (!particles.length) initParticles(cw, ch);
    canvas.width = cw; canvas.height = ch;
    const ctx = canvas.getContext('2d');
    ctx.fillStyle = C.bg;
    ctx.fillRect(0, 0, cw, ch);

    const hydrated = Math.min(1, t / 300);

    // Divider
    const divX = cw * 0.48;
    ctx.fillStyle = C.textDim;
    ctx.fillRect(divX - 0.5, 10, 1, ch - 20);
    label(ctx, 'DRY MIX', divX * 0.5, 22, C.textMuted, 10);
    label(ctx, 'HYDRATING', divX + (cw - divX) * 0.5, 22, C.blueprint, 10);

    // Background gel on right
    if (hydrated > 0) {
      const grd = ctx.createRadialGradient(cw * 0.74, ch / 2, 10, cw * 0.74, ch / 2, (cw - divX) * 0.7);
      grd.addColorStop(0, `rgba(78,201,176,${hydrated * 0.12})`);
      grd.addColorStop(1, 'rgba(78,201,176,0)');
      ctx.fillStyle = grd;
      ctx.fillRect(divX, 0, cw - divX, ch);
    }

    particles.forEach(p => {
      const side = p.x < divX ? 'left' : 'right';

      // Colors
      const colorMap = {
        cement: side === 'right' && hydrated > 0.2 ? C.blueprint : '#b0a090',
        coarse: '#8090a0',
        fine:   '#c0b090',
        water:  side === 'right' ? `rgba(78,201,176,${0.5 + hydrated * 0.5})` : 'rgba(100,160,220,0.7)',
      };

      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fillStyle = colorMap[p.type];
      ctx.fill();
      if (p.type === 'coarse') {
        ctx.strokeStyle = 'rgba(255,255,255,0.1)';
        ctx.lineWidth = 1;
        ctx.stroke();
      }

      // Gel tendrils on right when hydrated
      if (side === 'right' && hydrated > 0.3 && p.type === 'cement') {
        const numTendrils = 3;
        for (let i = 0; i < numTendrils; i++) {
          const angle = (i / numTendrils) * Math.PI * 2 + t * 0.01;
          const len = p.r * 2 * hydrated;
          ctx.beginPath();
          ctx.moveTo(p.x, p.y);
          ctx.lineTo(p.x + Math.cos(angle) * len, p.y + Math.sin(angle) * len);
          ctx.strokeStyle = `rgba(78,201,176,${hydrated * 0.4})`;
          ctx.lineWidth = 1;
          ctx.stroke();
        }
      }

      // Move
      p.x += p.vx;
      p.y += p.vy;
      if (p.x < p.r || p.x > cw - p.r) p.vx *= -1;
      if (p.y < p.r || p.y > ch - p.r) p.vy *= -1;
      // Right-side particles slow down as they hydrate
      if (p.x > divX) { p.vx *= (1 - hydrated * 0.008); p.vy *= (1 - hydrated * 0.008); }
    });

    // Legend
    [['Cement', '#b0a090'], ['Coarse Agg', '#8090a0'], ['Fine Agg', '#c0b090'], ['Water', 'rgba(100,160,220,0.9)']].forEach(([txt, col], i) => {
      const lx = 12, ly = ch - 12 - (3 - i) * 20;
      ctx.beginPath(); ctx.arc(lx + 6, ly, 5, 0, Math.PI * 2); ctx.fillStyle = col; ctx.fill();
      label(ctx, txt, lx + 16, ly + 4, C.textMuted, 9, 'left');
    });

    if (running) { t++; animId = requestAnimationFrame(draw); }
  }

  document.getElementById('btn-hydrate-toggle').addEventListener('click', function() {
    running = !running;
    this.textContent = running ? '⏸ Pause' : '▶ Play';
    if (running) draw();
  });
  document.getElementById('btn-hydrate-reset').addEventListener('click', () => {
    t = 0; running = true;
    particles.length = 0;
    document.getElementById('btn-hydrate-toggle').textContent = '⏸ Pause';
    cancelAnimationFrame(animId); draw();
  });

  draw();
})();

// ─── CANVAS 3: W/C vs STRENGTH SLIDER ───────────────────────
(function() {
  const canvas = document.getElementById('canvas-wc');
  const slider = document.getElementById('wc-slider');
  const display = document.getElementById('wc-display');

  function wcToFc(wc) {
    // Abrams-style: exponential decay
    return 12000 * Math.pow(0.6, wc * 10);
  }
  function wcToSlump(wc) {
    return Math.min(200, 20 + wc * 280);
  }

  function draw() {
    const wc = parseInt(slider.value) / 100;
    display.textContent = wc.toFixed(2);
    const cw = canvas.clientWidth || 780, ch = 300;
    canvas.width = cw; canvas.height = ch;
    const ctx = canvas.getContext('2d');
    ctx.fillStyle = C.bg;
    ctx.fillRect(0, 0, cw, ch);

    const pad = 50, mid = cw / 2;
    const chartW = mid - pad - 20;
    const chartH = ch - 80;

    // Left chart: f'c bar
    const fc = wcToFc(wc);
    const maxFc = wcToFc(0.3);
    const fcBarH = (fc / maxFc) * chartH;

    label(ctx, "COMPRESSIVE STRENGTH f'c", mid * 0.5, 20, C.blueprint, 10);
    ctx.fillStyle = C.blueprintD;
    ctx.fillRect(mid * 0.5 - 30, pad + chartH - fcBarH, 60, fcBarH);
    ctx.fillStyle = C.blueprint;
    ctx.fillRect(mid * 0.5 - 30, pad + chartH - fcBarH, 60, 3);
    label(ctx, `${(fc).toFixed(0)} psi`, mid * 0.5, pad + chartH - fcBarH - 10, C.blueprint, 13);
    ctx.strokeStyle = C.textDim;
    ctx.strokeRect(mid * 0.5 - 30, pad, 60, chartH);

    // Right chart: workability bar
    const sl = wcToSlump(wc);
    const maxSl = wcToSlump(0.70);
    const slBarH = (sl / maxSl) * chartH;
    label(ctx, 'WORKABILITY (Slump)', mid + (cw - mid) * 0.5, 20, C.amber, 10);
    ctx.fillStyle = C.amberD;
    ctx.fillRect(mid + (cw - mid) * 0.5 - 30, pad + chartH - slBarH, 60, slBarH);
    ctx.fillStyle = C.amber;
    ctx.fillRect(mid + (cw - mid) * 0.5 - 30, pad + chartH - slBarH, 60, 3);
    label(ctx, `${sl.toFixed(0)} mm`, mid + (cw - mid) * 0.5, pad + chartH - slBarH - 10, C.amber, 13);
    ctx.strokeStyle = C.textDim;
    ctx.strokeRect(mid + (cw - mid) * 0.5 - 30, pad, 60, chartH);

    // W/C label center
    label(ctx, `W/C = ${wc.toFixed(2)}`, mid, pad + chartH + 28, C.textMuted, 11);

    // Axis labels
    label(ctx, '0', mid * 0.5 - 42, pad + chartH + 4, C.textDim, 9, 'right');
    label(ctx, `${maxFc.toFixed(0)}`, mid * 0.5 - 42, pad + 4, C.textDim, 9, 'right');
    label(ctx, '0 mm', mid + (cw - mid) * 0.5 + 42, pad + chartH + 4, C.textDim, 9, 'left');
    label(ctx, '200 mm', mid + (cw - mid) * 0.5 + 42, pad + 4, C.textDim, 9, 'left');
  }

  slider.addEventListener('input', draw);
  draw();
})();

// ─── CANVAS 4: CONCRETE STRESS-STRAIN ───────────────────────
(function() {
  const canvas = document.getElementById('canvas-fc');
  let animId, running = false, progress = 0;

  function getSS(fc) {
    // Hognestad parabola approximation
    const eo = 2 * fc / (57000 * Math.sqrt(fc));
    const pts = [];
    for (let e = 0; e <= 0.004; e += 0.0001) {
      let f;
      if (e <= eo) {
        f = fc * (2 * e / eo - (e / eo) ** 2);
      } else {
        f = fc * (1 - 0.15 * (e - eo) / (0.004 - eo));
      }
      pts.push({ e, f: Math.max(0, f) });
    }
    return pts;
  }

  function draw() {
    const fc = parseInt(document.getElementById('fc-select').value);
    const cw = canvas.clientWidth || 780, ch = 360;
    canvas.width = cw; canvas.height = ch;
    const ctx = canvas.getContext('2d');
    ctx.fillStyle = C.bg;
    ctx.fillRect(0, 0, cw, ch);

    const pad = { l: 70, r: 40, t: 40, b: 60 };
    const iw = cw - pad.l - pad.r, ih = ch - pad.t - pad.b;
    const maxE = 0.004, maxF = fc * 1.1;

    drawGrid(ctx, cw, ch, pad.l, pad.t, pad.r, pad.b);

    // Axes
    ctx.strokeStyle = C.textDim;
    ctx.lineWidth = 1.5;
    ctx.beginPath();
    ctx.moveTo(pad.l, pad.t); ctx.lineTo(pad.l, pad.t + ih);
    ctx.lineTo(pad.l + iw, pad.t + ih);
    ctx.stroke();

    // Axis labels
    label(ctx, 'fc (psi)', pad.l - 50, pad.t + ih / 2, C.textMuted, 10);
    label(ctx, 'Strain ε (in/in)', pad.l + iw / 2, pad.t + ih + 40, C.textMuted, 10);

    const toX = e => pad.l + (e / maxE) * iw;
    const toY = f => pad.t + ih - (f / maxF) * ih;

    // εcu line
    ctx.setLineDash([6, 4]);
    ctx.beginPath();
    ctx.moveTo(toX(0.003), pad.t);
    ctx.lineTo(toX(0.003), pad.t + ih);
    ctx.strokeStyle = C.amber;
    ctx.lineWidth = 1;
    ctx.stroke();
    ctx.setLineDash([]);
    label(ctx, 'εcu=0.003', toX(0.003), pad.t + 14, C.amber, 9);

    // f'c line
    ctx.setLineDash([6, 4]);
    ctx.beginPath();
    ctx.moveTo(pad.l, toY(fc));
    ctx.lineTo(pad.l + iw, toY(fc));
    ctx.strokeStyle = C.rust;
    ctx.lineWidth = 1;
    ctx.stroke();
    ctx.setLineDash([]);
    label(ctx, `f'c=${fc}`, pad.l - 8, toY(fc), C.rust, 9, 'right');

    // Stress-strain curve (animated)
    const pts = getSS(fc);
    const end = Math.floor(progress * pts.length);
    if (end > 1) {
      ctx.beginPath();
      ctx.moveTo(toX(pts[0].e), toY(pts[0].f));
      for (let i = 1; i < end; i++) {
        ctx.lineTo(toX(pts[i].e), toY(pts[i].f));
      }
      ctx.strokeStyle = C.blueprint;
      ctx.lineWidth = 2.5;
      ctx.shadowColor = C.blueprint;
      ctx.shadowBlur = 8;
      ctx.stroke();
      ctx.shadowBlur = 0;
    }

    // Tick marks
    [0.001, 0.002, 0.003, 0.004].forEach(e => {
      const x = toX(e);
      ctx.fillStyle = C.textDim;
      ctx.fillRect(x - 0.5, pad.t + ih, 1, 6);
      label(ctx, e.toFixed(3), x, pad.t + ih + 18, C.textDim, 9);
    });
    [fc * 0.25, fc * 0.5, fc * 0.75, fc].forEach(f => {
      const y = toY(f);
      ctx.fillStyle = C.textDim;
      ctx.fillRect(pad.l - 6, y - 0.5, 6, 1);
      label(ctx, `${(f / 1000).toFixed(1)}k`, pad.l - 8, y + 4, C.textDim, 9, 'right');
    });

    if (running && progress < 1) {
      progress = Math.min(1, progress + 0.006);
      animId = requestAnimationFrame(draw);
    } else if (progress >= 1) {
      running = false;
      document.getElementById('btn-fc-toggle').textContent = '↺ Replay';
    }
  }

  document.getElementById('btn-fc-toggle').addEventListener('click', function() {
    if (progress >= 1) { progress = 0; running = true; this.textContent = '⏸ Pause'; draw(); return; }
    running = !running;
    this.textContent = running ? '⏸ Pause' : '▶ Play';
    if (running) draw();
  });
  document.getElementById('btn-fc-reset').addEventListener('click', () => {
    progress = 0; running = false;
    document.getElementById('btn-fc-toggle').textContent = '▶ Play';
    cancelAnimationFrame(animId); draw();
  });
  document.getElementById('fc-select').addEventListener('change', () => {
    progress = 0; running = false;
    document.getElementById('btn-fc-toggle').textContent = '▶ Play';
    draw();
  });

  draw();
})();

// ─── CANVAS 5: EC VISUALIZATION ─────────────────────────────
(function() {
  const canvas = document.getElementById('canvas-ec');
  const sel = document.getElementById('ec-fc-select');

  function getSS(fc) {
    const eo = 2 * fc / (57000 * Math.sqrt(fc));
    const pts = [];
    for (let e = 0; e <= 0.004; e += 0.0001) {
      let f = e <= eo
        ? fc * (2 * e / eo - (e / eo) ** 2)
        : fc * (1 - 0.15 * (e - eo) / (0.004 - eo));
      pts.push({ e, f: Math.max(0, f) });
    }
    return pts;
  }

  function draw() {
    const fc = parseInt(sel.value);
    const Ec = 57000 * Math.sqrt(fc);
    document.getElementById('ec-display-val').textContent = `Ec = ${(Ec / 1000).toFixed(0)} ksi`;

    const cw = canvas.clientWidth || 780, ch = 340;
    canvas.width = cw; canvas.height = ch;
    const ctx = canvas.getContext('2d');
    ctx.fillStyle = C.bg; ctx.fillRect(0, 0, cw, ch);

    const pad = { l: 70, r: 60, t: 40, b: 60 };
    const iw = cw - pad.l - pad.r, ih = ch - pad.t - pad.b;
    const maxE = 0.004, maxF = fc * 1.1;
    drawGrid(ctx, cw, ch, pad.l, pad.t, pad.r, pad.b);

    // Axes
    ctx.strokeStyle = C.textDim; ctx.lineWidth = 1.5;
    ctx.beginPath();
    ctx.moveTo(pad.l, pad.t); ctx.lineTo(pad.l, pad.t + ih);
    ctx.lineTo(pad.l + iw, pad.t + ih); ctx.stroke();

    const toX = e => pad.l + (e / maxE) * iw;
    const toY = f => pad.t + ih - (f / maxF) * ih;

    const pts = getSS(fc);
    ctx.beginPath();
    ctx.moveTo(toX(pts[0].e), toY(pts[0].f));
    pts.forEach(p => ctx.lineTo(toX(p.e), toY(p.f)));
    ctx.strokeStyle = C.textMuted; ctx.lineWidth = 2; ctx.stroke();

    // Ec chord line (origin to ~0.4f'c)
    const eChord = fc * 0.4 / Ec;
    ctx.beginPath();
    ctx.moveTo(toX(0), toY(0));
    ctx.lineTo(toX(eChord), toY(fc * 0.4));
    ctx.setLineDash([10, 5]);
    ctx.strokeStyle = C.blueprint; ctx.lineWidth = 2.5;
    ctx.shadowColor = C.blueprint; ctx.shadowBlur = 8;
    ctx.stroke();
    ctx.shadowBlur = 0; ctx.setLineDash([]);

    // Extend Ec line faintly
    const eExt = maxF * 0.85 / Ec;
    ctx.beginPath();
    ctx.moveTo(toX(0), toY(0));
    ctx.lineTo(toX(eExt), toY(maxF * 0.85));
    ctx.setLineDash([4, 8]);
    ctx.strokeStyle = 'rgba(78,201,176,0.25)'; ctx.lineWidth = 1.5;
    ctx.stroke(); ctx.setLineDash([]);

    // Slope angle label
    const mx = toX(eChord / 2), my = toY(fc * 0.2) + 18;
    label(ctx, `Ec = ${(Ec / 1000).toFixed(0)} ksi`, mx + 30, my, C.blueprint, 11, 'left');

    // f'c and εcu markers
    ctx.setLineDash([5, 4]);
    ctx.strokeStyle = C.amber; ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(pad.l, toY(fc)); ctx.lineTo(toX(0.003), toY(fc)); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(toX(0.003), pad.t); ctx.lineTo(toX(0.003), toY(fc)); ctx.stroke();
    ctx.setLineDash([]);
    label(ctx, `f'c`, pad.l - 6, toY(fc) + 4, C.amber, 9, 'right');
    label(ctx, 'εcu', toX(0.003), pad.t + ih + 18, C.amber, 9);

    label(ctx, 'Stress fc (psi)', pad.l - 50, pad.t + ih / 2, C.textMuted, 10);
    label(ctx, 'Strain ε', pad.l + iw / 2, pad.t + ih + 40, C.textMuted, 10);

    [fc * 0.5, fc].forEach(f => {
      label(ctx, `${(f/1000).toFixed(1)}k`, pad.l - 8, toY(f) + 4, C.textDim, 9, 'right');
    });
    [0.001, 0.002, 0.003].forEach(e => {
      label(ctx, e.toFixed(3), toX(e), pad.t + ih + 18, C.textDim, 9);
    });
  }

  sel.addEventListener('change', draw);
  draw();
})();

// ─── CANVAS 6: STEEL STRESS-STRAIN ──────────────────────────
(function() {
  const canvas = document.getElementById('canvas-steel');
  let animId, running = false, progress = 0;

  const grades = [
    { fy: 40000, color: C.amber,     label: 'Grade 40', id: 'chk-gr40' },
    { fy: 60000, color: C.blueprint, label: 'Grade 60', id: 'chk-gr60' },
    { fy: 75000, color: C.rust,      label: 'Grade 75', id: 'chk-gr75' },
  ];

  function getSteelCurve(fy) {
    const Es = 29e6, ey = fy / Es;
    const pts = [];
    for (let e = 0; e <= 0.02; e += 0.0002) {
      let f = e < ey ? Es * e : fy;
      pts.push({ e, f });
    }
    return pts;
  }

  function draw() {
    const cw = canvas.clientWidth || 780, ch = 360;
    canvas.width = cw; canvas.height = ch;
    const ctx = canvas.getContext('2d');
    ctx.fillStyle = C.bg; ctx.fillRect(0, 0, cw, ch);

    const pad = { l: 70, r: 40, t: 40, b: 60 };
    const iw = cw - pad.l - pad.r, ih = ch - pad.t - pad.b;
    const maxE = 0.02, maxF = 80000;
    drawGrid(ctx, cw, ch, pad.l, pad.t, pad.r, pad.b);

    ctx.strokeStyle = C.textDim; ctx.lineWidth = 1.5;
    ctx.beginPath();
    ctx.moveTo(pad.l, pad.t); ctx.lineTo(pad.l, pad.t + ih);
    ctx.lineTo(pad.l + iw, pad.t + ih); ctx.stroke();

    const toX = e => pad.l + (e / maxE) * iw;
    const toY = f => pad.t + ih - (f / maxF) * ih;

    grades.forEach((g) => {
      const chk = document.getElementById(g.id);
      if (chk && !chk.checked) return;

      const pts = getSteelCurve(g.fy);
      const end = Math.floor(progress * pts.length);
      if (end > 1) {
        ctx.beginPath();
        ctx.moveTo(toX(pts[0].e), toY(pts[0].f));
        for (let i = 1; i < end; i++) ctx.lineTo(toX(pts[i].e), toY(pts[i].f));
        ctx.strokeStyle = g.color; ctx.lineWidth = 2.5;
        ctx.shadowColor = g.color; ctx.shadowBlur = 6;
        ctx.stroke(); ctx.shadowBlur = 0;

        // fy label
        if (end > 20) {
          ctx.setLineDash([5, 4]);
          ctx.strokeStyle = g.color + '55'; ctx.lineWidth = 1;
          ctx.beginPath();
          ctx.moveTo(pad.l, toY(g.fy)); ctx.lineTo(pad.l + iw, toY(g.fy)); ctx.stroke();
          ctx.setLineDash([]);
          label(ctx, `fy=${g.fy/1000}k`, pad.l + iw + 4, toY(g.fy) + 4, g.color, 9, 'left');
        }
      }
    });

    // Legend
    let lx = pad.l + 20, ly = pad.t + 14;
    grades.forEach(g => {
      const chk = document.getElementById(g.id);
      if (chk && !chk.checked) return;
      ctx.fillStyle = g.color; ctx.fillRect(lx, ly - 8, 24, 2);
      label(ctx, g.label, lx + 30, ly, g.color, 9, 'left');
      lx += 100;
    });

    label(ctx, 'Stress fs (psi)', pad.l - 52, pad.t + ih / 2, C.textMuted, 10);
    label(ctx, 'Strain ε (in/in)', pad.l + iw / 2, pad.t + ih + 40, C.textMuted, 10);

    [20000, 40000, 60000, 75000].forEach(f => {
      const y = toY(f);
      ctx.fillStyle = C.textDim; ctx.fillRect(pad.l - 6, y - 0.5, 6, 1);
      label(ctx, `${f / 1000}k`, pad.l - 8, y + 4, C.textDim, 9, 'right');
    });
    [0.005, 0.01, 0.015, 0.02].forEach(e => {
      const x = toX(e);
      ctx.fillStyle = C.textDim; ctx.fillRect(x - 0.5, pad.t + ih, 1, 6);
      label(ctx, e.toFixed(3), x, pad.t + ih + 18, C.textDim, 9);
    });

    if (running && progress < 1) {
      progress = Math.min(1, progress + 0.005);
      animId = requestAnimationFrame(draw);
    } else if (progress >= 1) {
      running = false;
      document.getElementById('btn-steel-toggle').textContent = '↺ Replay';
    }
  }

  document.getElementById('btn-steel-toggle').addEventListener('click', function() {
    if (progress >= 1) { progress = 0; running = true; this.textContent = '⏸ Pause'; draw(); return; }
    running = !running;
    this.textContent = running ? '⏸ Pause' : '▶ Play';
    if (running) draw();
  });
  document.getElementById('btn-steel-reset').addEventListener('click', () => {
    progress = 0; running = false;
    document.getElementById('btn-steel-toggle').textContent = '▶ Play';
    cancelAnimationFrame(animId); draw();
  });
  ['chk-gr40','chk-gr60','chk-gr75'].forEach(id => {
    document.getElementById(id).addEventListener('change', draw);
  });

  draw();
})();

// ─── CALCULATORS ────────────────────────────────────────────
function showResult(id, html) {
  const el = document.getElementById(`result-${id}`);
  el.innerHTML = html; el.style.display = 'block';
  const btn = document.getElementById(`toggle-steps-${id}`);
  btn.style.display = 'block';
}
function showStepsContent(id, html) {
  const el = document.getElementById(`steps-${id}`);
  el.innerHTML = html;
}
function toggleSteps(id) {
  const el = document.getElementById(`steps-${id}`);
  const btn = document.getElementById(`toggle-steps-${id}`);
  if (el.style.display === 'none' || !el.style.display) {
    el.style.display = 'block';
    btn.textContent = '▲ Hide Steps';
  } else {
    el.style.display = 'none';
    btn.textContent = '▼ Show Steps';
  }
}

// Calc 1: Effective depth
function calcRCDepth() {
  const h = parseFloat(document.getElementById('rc-h').value);
  const cov = parseFloat(document.getElementById('rc-cover').value);
  const stir = parseFloat(document.getElementById('rc-stirrup').value);
  const bar = parseFloat(document.getElementById('rc-bar').value);
  const d = h - cov - stir - bar / 2;
  showResult('rc', `Effective Depth  d = ${d.toFixed(2)} in\n( d/h ratio = ${(d/h).toFixed(3)} )`);
  showStepsContent('rc',
    `h  = ${h} in (overall depth)\n` +
    `Cover = ${cov} in\n` +
    `Stirrup ø = ${stir} in\n` +
    `Main bar ø = ${bar} in\n\n` +
    `d = h − cover − stirrup − bar/2\n` +
    `d = ${h} − ${cov} − ${stir} − ${(bar/2).toFixed(3)}\n` +
    `d = ${d.toFixed(2)} in`
  );
}

// Calc 2: Mix proportioning
document.getElementById('mix-ratio').addEventListener('change', function() {
  document.getElementById('mix-custom-row').style.display =
    this.value === 'custom' ? 'flex' : 'none';
});
function calcMix() {
  const vol = parseFloat(document.getElementById('mix-vol').value);
  let ratioStr = document.getElementById('mix-ratio').value;
  if (ratioStr === 'custom') ratioStr = document.getElementById('mix-custom').value;
  const parts = ratioStr.split(':').map(Number);
  if (parts.length !== 3 || parts.some(isNaN)) { alert('Invalid ratio format. Use c:fa:ca'); return; }
  const [c, fa, ca] = parts, sum = c + fa + ca;
  const wc = parseFloat(document.getElementById('mix-wc').value);
  const density = 1500;
  const totalMass = density * vol;
  const Mc = (c / sum) * totalMass, Mfa = (fa / sum) * totalMass, Mca = (ca / sum) * totalMass;
  const Mw = wc * Mc;
  showResult('mix',
    `Cement        = ${Mc.toFixed(1)} kg  (${(Mc/50).toFixed(1)} bags)\n` +
    `Fine Agg      = ${Mfa.toFixed(1)} kg\n` +
    `Coarse Agg    = ${Mca.toFixed(1)} kg\n` +
    `Water         = ${Mw.toFixed(1)} kg = ${Mw.toFixed(0)} L`
  );
  showStepsContent('mix',
    `Ratio ${ratioStr}  →  sum of parts = ${sum}\n` +
    `Total dry mass = ${density} × ${vol} = ${totalMass.toFixed(0)} kg\n\n` +
    `Cement  = (${c}/${sum}) × ${totalMass.toFixed(0)} = ${Mc.toFixed(1)} kg\n` +
    `Fine Agg = (${fa}/${sum}) × ${totalMass.toFixed(0)} = ${Mfa.toFixed(1)} kg\n` +
    `Coarse Agg = (${ca}/${sum}) × ${totalMass.toFixed(0)} = ${Mca.toFixed(1)} kg\n` +
    `Water = W/C × Cement = ${wc} × ${Mc.toFixed(1)} = ${Mw.toFixed(1)} kg`
  );
}

// Calc 3: W/C ratio
function calcWC() {
  const wc = parseFloat(document.getElementById('wc-ratio').value);
  const cement = parseFloat(document.getElementById('wc-cement').value);
  const water = wc * cement;
  let strength = 12000 * Math.pow(0.6, wc * 10);
  let cat = wc < 0.40 ? 'High strength — may need HRWR admixture for workability'
          : wc < 0.50 ? 'Structural concrete — good balance'
          : wc < 0.60 ? 'General use — adequate for most applications'
          : 'Lean mix — low strength, use only for non-structural';
  showResult('wc',
    `Water content = ${water.toFixed(1)} kg/m³ = ${water.toFixed(0)} L/m³\n` +
    `Est. f'c ≈ ${strength.toFixed(0)} psi  (Abrams approximation)\n` +
    `Category: ${cat}`
  );
  showStepsContent('wc',
    `W/C = ${wc}\n` +
    `Cement content = ${cement} kg/m³\n\n` +
    `Water = W/C × Cement = ${wc} × ${cement} = ${water.toFixed(1)} kg/m³\n\n` +
    `Strength estimate (Abrams-type):\n` +
    `f'c ≈ 12000 × 0.6^(${wc}×10) = ${strength.toFixed(0)} psi`
  );
}

// Calc 4: Cylinder f'c
function calcFC() {
  const d = parseFloat(document.getElementById('cyl-d').value);
  const P = parseFloat(document.getElementById('cyl-p').value) * 1000;
  const fcSpec = parseFloat(document.getElementById('cyl-fc-spec').value);
  const A = Math.PI * (d / 2) ** 2;
  const fc = P / A;
  const pass1 = fc >= fcSpec;
  const pass2 = fc >= fcSpec - 500;
  showResult('fc',
    `f'c measured = ${fc.toFixed(0)} psi\n` +
    `Cylinder area A = ${A.toFixed(2)} in²\n\n` +
    `ACI Check #1 (avg ≥ f'c): ${fc.toFixed(0)} ≥ ${fcSpec}  →  ${pass1 ? '✓ PASS' : '✗ FAIL'}\n` +
    `ACI Check #2 (min ≥ f'c−500): ${fc.toFixed(0)} ≥ ${fcSpec - 500}  →  ${pass2 ? '✓ PASS' : '✗ FAIL'}`
  );
  showStepsContent('fc',
    `Cylinder diameter d = ${d} in\n` +
    `Area A = π(d/2)² = π(${d/2})² = ${A.toFixed(2)} in²\n` +
    `Failure load P = ${(P/1000).toFixed(0)} kips = ${P.toFixed(0)} lb\n\n` +
    `f'c = P/A = ${P.toFixed(0)} / ${A.toFixed(2)} = ${fc.toFixed(1)} psi`
  );
}

// Calc 5: Ec
function calcEc() {
  const fc = parseFloat(document.getElementById('ec-fc').value);
  const wc = parseFloat(document.getElementById('ec-wc').value);
  const Es = parseFloat(document.getElementById('ec-es').value);
  const Ec_simple = 57000 * Math.sqrt(fc);
  const Ec_general = 33 * Math.pow(wc, 1.5) * Math.sqrt(fc);
  const isNW = wc >= 140;
  const Ec = isNW ? Ec_simple : Ec_general;
  const n = Math.round(Es / Ec * 10) / 10;
  const nRound = Math.round(n);
  showResult('ec',
    `Ec (simplified) = ${(Ec_simple / 1000).toFixed(1)} ksi\n` +
    `Ec (general)    = ${(Ec_general / 1000).toFixed(1)} ksi\n` +
    `Modular ratio n = Es/Ec = ${n.toFixed(2)}  →  use n = ${nRound}`
  );
  showStepsContent('ec',
    `f'c = ${fc} psi,  wc = ${wc} pcf\n\n` +
    `Simplified (NW): Ec = 57,000 × √${fc} = 57,000 × ${Math.sqrt(fc).toFixed(2)} = ${(Ec_simple).toFixed(0)} psi\n\n` +
    `General: Ec = 33 × ${wc}^1.5 × √${fc} = 33 × ${Math.pow(wc,1.5).toFixed(1)} × ${Math.sqrt(fc).toFixed(2)} = ${Ec_general.toFixed(0)} psi\n\n` +
    `n = Es/Ec = ${Es.toLocaleString()} / ${Ec.toFixed(0)} = ${n.toFixed(2)}\n` +
    `Use n = ${nRound} (round to nearest integer per ACI)`
  );
}

// Calc 6: Rebar
function calcSteel() {
  const [barNum, areaStr] = document.getElementById('steel-bar').value.split(',');
  const area = parseFloat(areaStr);
  const N = parseInt(document.getElementById('steel-n').value);
  const fy = parseInt(document.getElementById('steel-grade').value);
  const As = N * area;
  const T = As * fy;
  const C_ = As * fy;
  showResult('steel',
    `${N} × #${barNum} bars\n` +
    `Total As = ${N} × ${area} = ${As.toFixed(2)} in²\n` +
    `Yield force T = As × fy = ${As.toFixed(2)} × ${fy} = ${T.toFixed(1)} kips`
  );
  showStepsContent('steel',
    `Bar #${barNum}: area per bar = ${area} in²\n` +
    `Number of bars = ${N}\n` +
    `fy = ${fy} ksi (Grade ${fy === 40 ? 40 : fy === 60 ? 60 : 75})\n\n` +
    `As = N × Abar = ${N} × ${area} = ${As.toFixed(2)} in²\n` +
    `T = As × fy = ${As.toFixed(2)} × ${fy} = ${T.toFixed(1)} kips\n` +
    `(This is the force the bars can carry at yield — used in Mn calculation)`
  );
}

