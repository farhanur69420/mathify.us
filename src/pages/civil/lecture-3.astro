  .result-value { font-family: 'Space Mono', monospace; font-size: 1.25rem; color: var(--teal); }
  .result-label { font-size: 0.76rem; color: var(--muted); margin-top: 0.2rem; }
  .show-steps-btn {
    background: none;
    border: 1px solid var(--border);
    color: var(--muted);
    font-family: 'Space Mono', monospace;
    font-size: 0.7rem;
    padding: 0.28rem 0.65rem;
    border-radius: 4px;
    cursor: pointer;
    margin-top: 0.7rem;
    transition: all 0.2s;
  }
  .show-steps-btn:hover { color: var(--teal); border-color: var(--teal); }
  .steps-panel { display: none; margin-top: 0.8rem; border-top: 1px solid var(--border); padding-top: 0.8rem; }
  .steps-panel.open { display: block; }
  .step-row { font-size: 0.82rem; color: #c0c0d8; padding: 0.28rem 0; display: flex; gap: 0.6rem; }
  .step-row .sn { font-family: 'Space Mono', monospace; color: var(--amber); flex-shrink: 0; }
  .whatif-row { margin-top: 0.8rem; padding-top: 0.8rem; border-top: 1px dashed var(--border); display: flex; gap: 0.8rem; flex-wrap: wrap; }
  .whatif-chip { background: var(--s3); border: 1px solid var(--border); border-radius: 20px; padding: 0.22rem 0.75rem; font-size: 0.73rem; color: var(--muted); }
  .whatif-chip span { color: var(--amber); }

  /* ── Worked example ── */
  .worked { margin: 1.5rem 0; }
  .problem-card {
    background: var(--s2);
    border: 1px solid var(--teal);
    border-radius: 8px;
    padding: 1.1rem 1.3rem;
    margin-bottom: 1.2rem;
  }
  .problem-card h4 {
    font-family: 'Space Mono', monospace;
    font-size: 0.7rem;
    color: var(--teal);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.7rem;
  }
  .problem-card p { font-size: 0.89rem; }
  .step-item { margin-bottom: 1rem; padding-left: 1rem; border-left: 2px solid var(--border); }
  .step-head { font-family: 'Space Mono', monospace; font-size: 0.76rem; color: var(--amber); margin-bottom: 0.3rem; }
  .step-item p { font-size: 0.87rem; }
  .why { font-style: italic; color: var(--muted); font-size: 0.8rem; margin-top: 0.3rem; }
  .watch-flag {
    background: #1a0e0e;
    border: 1px solid var(--rust);
    border-radius: 5px;
    padding: 0.55rem 0.9rem;
    font-size: 0.82rem;
    color: #e0a0a0;
    margin: 0.6rem 0;
  }
  .watch-flag::before { content: '⚑ '; color: var(--rust); }
  .final-answer {
    background: #1a1400;
    border: 2px solid var(--amber);
    border-radius: 8px;
    padding: 1rem 1.3rem;
    margin-top: 1rem;
  }
  .fa-label { font-family: 'Space Mono', monospace; font-size: 0.66rem; color: var(--amber); letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 0.4rem; }
  .fa-value { font-family: 'Space Mono', monospace; font-size: 1.05rem; color: var(--amber); }
  .fa-interp { font-size: 0.8rem; color: var(--muted); font-style: italic; margin-top: 0.4rem; }

  /* ── Quick ref card ── */
  .qr-card {
    background: var(--s2);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.3rem;
    margin: 1.5rem 0;
  }
  .qr-card h3 {
    font-family: 'Space Mono', monospace;
    font-size: 0.7rem;
    color: var(--amber);
    letter-spacing: 0.1em;
    text-transform: uppercase;
