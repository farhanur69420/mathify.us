  }
  .qr-card table { width: 100%; border-collapse: collapse; font-size: 0.82rem; margin-bottom: 0.8rem; }
  .qr-card th {
    font-family: 'Space Mono', monospace;
    font-size: 0.63rem;
    color: var(--muted);
    text-transform: uppercase;
    text-align: left;
    padding: 0.3rem 0.6rem;
    border-bottom: 1px solid var(--border);
  }
  .qr-card td { padding: 0.3rem 0.6rem; border-bottom: 1px solid #181824; color: #c0c0d8; }
  .qr-card td:first-child { font-family: 'Space Mono', monospace; color: var(--amber); white-space: nowrap; }
  .qr-thumb {
    font-size: 0.84rem;
    color: var(--teal);
    font-style: italic;
    margin-top: 0.5rem;
    padding: 0.55rem 0.85rem;
    background: #0e1a18;
    border-radius: 5px;
  }
  .qr-thumb::before { content: '💡 '; }
</style>

<!-- ══════════════════════════════════════════
     SCRIPTS
══════════════════════════════════════════ -->
<script is:inline>
// Cache original logical heights once, before any DPR scaling touches them
const _H = {};
document.querySelectorAll('canvas[id]').forEach(el => {
  _H[el.id] = parseInt(el.getAttribute('height') || '300');
});

function gc(id) {
  const el = document.getElementById(id);
  const dpr = window.devicePixelRatio || 1;
  const w = el.clientWidth || el.offsetWidth || 700;
  const h = _H[id];
  el.width  = w * dpr;
  el.height = h * dpr;
  const ctx = el.getContext('2d');
  ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  return { ctx, w, h };
}

const T = '#4ec9b0', R = '#c0392b', A = '#d4a94a', M = '#7a7a9a', BG = '#0a0a12';

// Shared animation factory
function makeAnim(sliderId, btnId, drawFn) {
  let raf, playing = false, t = 0;
  const sl = document.getElementById(sliderId);
  const btn = document.getElementById(btnId);
  sl.addEventListener('input', () => drawFn(+sl.value));
  btn.addEventListener('click', () => {
    playing = !playing;
    btn.textContent = playing ? '⏸ Pause' : '▶ Play';
    if (playing) {
      let dir = 1;
      (function step() {
        if (!playing) return;
        t += dir * 0.7;
        if (t >= 100) { t = 100; dir = -1; }
        if (t <= 0)   { t = 0;   dir =  1; }
        sl.value = t;
        drawFn(t);
        raf = requestAnimationFrame(step);
      })();
    } else cancelAnimationFrame(raf);
  });
  drawFn(0);
}

// ── Canvas 1: Strain Compatibility ──────────────────────────
makeAnim('sliderStrain', 'btnStrainPlay', function(val) {
  const { ctx, w, h } = gc('canvasStrain');
  const strain = val / 100 * 0.003;
  ctx.fillStyle = BG; ctx.fillRect(0, 0, w, h);

  const bW = 120, bH = h * 0.7, bx = w * 0.25, by = (h - h*0.7) / 2;
  ctx.fillStyle = '#2a2a3a'; ctx.fillRect(bx, by, bW, bH);
  ctx.strokeStyle = M; ctx.lineWidth = 1; ctx.strokeRect(bx, by, bW, bH);

  // Steel bars
  [bx+20, bx+bW/2, bx+bW-20].forEach(sx => {
    ctx.beginPath(); ctx.arc(sx, by+bH-25, 8, 0, Math.PI*2);
    ctx.fillStyle = A; ctx.fill(); ctx.strokeStyle = '#8a6a1a'; ctx.lineWidth=1.5; ctx.stroke();
  });

  const naY = by + bH * 0.45;
  ctx.setLineDash([6,4]); ctx.strokeStyle=T; ctx.lineWidth=1.5;
  ctx.beginPath(); ctx.moveTo(bx-10,naY); ctx.lineTo(bx+bW+10,naY); ctx.stroke();
  ctx.setLineDash([]); ctx.fillStyle=T; ctx.font='10px Space Mono'; ctx.fillText('N.A.',bx+bW+14,naY+4);

  // Deformation lines
  for (let i=0; i<=5; i++) {
    const lx=bx+(bW/5)*i, f=i===0||i===5?1:0.7;
    ctx.strokeStyle=i===0||i===5?A:'#3a3a5a'; ctx.lineWidth=i===0||i===5?2:1;
    ctx.beginPath(); ctx.moveTo(lx-strain*(naY-by)*400*f,by); ctx.lineTo(lx,naY); ctx.lineTo(lx+strain*(by+bH-naY)*400*f,by+bH); ctx.stroke();
  }

  // Strain diagram
  const sdX=w*0.62, mW=90*strain/0.003;
  ctx.beginPath(); ctx.moveTo(sdX,by); ctx.lineTo(sdX+mW,by); ctx.lineTo(sdX,naY); ctx.closePath();
  ctx.fillStyle=T+'55'; ctx.fill(); ctx.strokeStyle=T; ctx.lineWidth=2; ctx.stroke();
  const bW2=mW*(by+bH-naY)/(naY-by);
  ctx.beginPath(); ctx.moveTo(sdX,naY); ctx.lineTo(sdX+bW2,naY); ctx.lineTo(sdX,by+bH); ctx.closePath();
  ctx.fillStyle=R+'55'; ctx.fill(); ctx.strokeStyle=R; ctx.lineWidth=2; ctx.stroke();
  ctx.strokeStyle=M; ctx.lineWidth=1; ctx.beginPath(); ctx.moveTo(sdX,by); ctx.lineTo(sdX,by+bH); ctx.stroke();
  ctx.fillStyle=T; ctx.font='10px Space Mono'; ctx.fillText('ε (compression)',sdX+2,by+14);
  ctx.fillStyle=R; ctx.fillText('ε (tension)',sdX+2,by+bH-8);
  ctx.fillStyle=M; ctx.fillText('Strain Diagram',sdX,by-10);
  document.getElementById('readoutStrain').textContent=`ε_max = ${strain.toFixed(4)}`;
});

// ── Canvas 2: Plane Sections ──────────────────────────
makeAnim('sliderPlane', 'btnPlanePlay', function(val) {
  const { ctx, w, h } = gc('canvasPlane');
  const phi = val / 100 * 0.008;
  ctx.fillStyle = BG; ctx.fillRect(0, 0, w, h);

  const bH=h*0.65, bW=80, bx=w*0.22, by=(h-h*0.65)/2;
  const naF=0.38, naY=by+bH*naF;
  ctx.fillStyle='#1e1e2e'; ctx.fillRect(bx,by,bW,bH);
  ctx.strokeStyle='#3a3a5a'; ctx.lineWidth=1; ctx.strokeRect(bx,by,bW,bH);

  for (let i=0; i<=10; i++) {
    const fy=by+(bH/10)*i, shift=phi*(fy-naY)*30;
    ctx.strokeStyle=i===Math.round(naF*10)?T:'#2e2e4e'; ctx.lineWidth=i===Math.round(naF*10)?2:1;
    ctx.beginPath(); ctx.moveTo(bx,fy); ctx.lineTo(bx+bW+shift,fy); ctx.stroke();
  }
  ctx.setLineDash([6,4]); ctx.strokeStyle=T; ctx.lineWidth=1.5;
  ctx.beginPath(); ctx.moveTo(bx-8,naY); ctx.lineTo(bx+bW+20,naY); ctx.stroke();
  ctx.setLineDash([]); ctx.fillStyle=T; ctx.font='10px Space Mono'; ctx.fillText('N.A. (ε=0)',bx+bW+24,naY+4);

  [bx+14,bx+bW-14].forEach(sx => {
    ctx.beginPath(); ctx.arc(sx,by+bH-20,7,0,Math.PI*2); ctx.fillStyle=A; ctx.fill();
  });

  const sdX=w*0.62, mS=phi*bH*0.5*30;
  ctx.beginPath(); ctx.moveTo(sdX,by); ctx.lineTo(sdX+mS*naF/0.5,by); ctx.lineTo(sdX,naY); ctx.closePath();
  ctx.fillStyle=T+'44'; ctx.fill(); ctx.strokeStyle=T; ctx.lineWidth=2; ctx.stroke();
  const tM=mS*(1-naF)/0.5;
  ctx.beginPath(); ctx.moveTo(sdX,naY); ctx.lineTo(sdX+tM,naY); ctx.lineTo(sdX,by+bH); ctx.closePath();
  ctx.fillStyle=R+'44'; ctx.fill(); ctx.strokeStyle=R; ctx.lineWidth=2; ctx.stroke();
  ctx.strokeStyle=M; ctx.lineWidth=1; ctx.beginPath(); ctx.moveTo(sdX,by); ctx.lineTo(sdX,by+bH); ctx.stroke();
  ctx.fillStyle=T; ctx.font='10px Space Mono'; ctx.fillText('ε (comp)',sdX+4,by+14);
  ctx.fillStyle=R; ctx.fillText('ε (tens)',sdX+4,by+bH-8);
  ctx.fillStyle=M; ctx.fillText('Linear Distribution',sdX,by-10);
  ctx.fillStyle=A; ctx.fillText('← steel here',bx+bW+5,by+bH-16);
  document.getElementById('readoutPlane').textContent=`ε_max = ${(phi*bH*0.001).toFixed(4)}`;
});

// ── Canvas 3: Crack Formation ──────────────────────────
const crackXs = [0.2,0.38,0.52,0.67,0.81];
makeAnim('sliderCrack', 'btnCrackPlay', function(val) {
  const { ctx, w, h } = gc('canvasCrack');
  ctx.fillStyle=BG; ctx.fillRect(0,0,w,h);
  const bH=h*0.62, bW=w*0.72, bx=w*0.14, by=(h-h*0.62)/2;
  const naF=0.40, naY=by+bH*naF;

  ctx.fillStyle='#1e1e2e'; ctx.fillRect(bx,by,bW,bH);
  ctx.strokeStyle='#3a3a5a'; ctx.lineWidth=1; ctx.strokeRect(bx,by,bW,bH);
  ctx.fillStyle=T+'18'; ctx.fillRect(bx,by,bW,bH*naF);

  // Steel bar
  const barY=by+bH-22;
  ctx.beginPath(); ctx.roundRect(bx+12,barY-8,bW-24,16,4);
  ctx.fillStyle=A+'cc'; ctx.fill(); ctx.strokeStyle='#8a6a1a'; ctx.lineWidth=1.5; ctx.stroke();
  ctx.fillStyle='#8a6a1a'; ctx.font='9px Space Mono'; ctx.fillText('Steel Reinforcement',bx+bW/2-50,barY+5);

  // Cracks
  const n=Math.floor(val/20);
  for (let i=0;i<n;i++) {
    const cx=bx+crackXs[i]*bW, mH=bH*(1-naF)*0.85, cH=mH*Math.min(1,(val-i*20)/15);
    ctx.globalAlpha=0.85; ctx.strokeStyle=R; ctx.lineWidth=1.5; ctx.beginPath(); ctx.moveTo(cx,by+bH);
    let cy=by+bH; const segs=8;
    for(let s=0;s<segs;s++){
      const p=(s+1)/segs; if(p*mH>cH) break;
      cy-=cH/segs; ctx.lineTo(cx+Math.sin(i*10+s*3)*3,cy);
    }
    ctx.stroke(); ctx.globalAlpha=1;
  }
  if (n < crackXs.length && val > n*20) {
    const cx=bx+crackXs[n]*bW, frac=(val%20)/20, cH=bH*(1-naF)*0.85*frac*0.5;
    ctx.globalAlpha=frac; ctx.strokeStyle=R; ctx.lineWidth=1;
    ctx.beginPath(); ctx.moveTo(cx,by+bH); ctx.lineTo(cx,by+bH-cH); ctx.stroke(); ctx.globalAlpha=1;
  }

  ctx.setLineDash([8,5]); ctx.strokeStyle=T; ctx.lineWidth=1.5;
  ctx.beginPath(); ctx.moveTo(bx,naY); ctx.lineTo(bx+bW,naY); ctx.stroke();
  ctx.setLineDash([]); ctx.fillStyle=T; ctx.font='10px Space Mono'; ctx.fillText('Neutral Axis',bx+bW+6,naY+4);
  ctx.fillStyle=T; ctx.fillText('COMPRESSION ZONE',bx+8,by+16);
  ctx.fillStyle=val>10?R:M; ctx.fillText('TENSION ZONE'+(val>10?' (cracked)':''),bx+8,naY+20);

  const s=val<10?'Uncracked':val<40?`${n} crack${n===1?'':'s'} forming`:val<70?`${n} cracks — service load range`:'Multiple cracks — steel carrying all tension';
  document.getElementById('readoutCrack').textContent=s;
});

// ── Canvas 4: Stress Block Evolution ──────────────────────────
makeAnim('sliderStress', 'btnStressPlay', function(val) {
  const { ctx, w, h } = gc('canvasStress');
  ctx.fillStyle=BG; ctx.fillRect(0,0,w,h);
  const bH=h*0.65, bW=90, bx=w*0.12, by=(h-h*0.65)/2;
  const naF=0.38, naY=by+bH*naF, fpc=30;

  ctx.fillStyle='#1e1e2e'; ctx.fillRect(bx,by,bW,bH);
  ctx.strokeStyle='#3a3a5a'; ctx.lineWidth=1; ctx.strokeRect(bx,by,bW,bH);
  [bx+15,bx+bW-15].forEach(sx=>{
    ctx.beginPath(); ctx.arc(sx,by+bH-20,7,0,Math.PI*2); ctx.fillStyle=A; ctx.fill();
  });
  ctx.setLineDash([6,4]); ctx.strokeStyle=T; ctx.lineWidth=1;
  ctx.beginPath(); ctx.moveTo(bx,naY); ctx.lineTo(bx+bW,naY); ctx.stroke(); ctx.setLineDash([]);

  const sdX=bx+bW+20, mW=130, compH=bH*naF;
  if (val<40) {
    const tW=mW*(val/40)*0.65;
    ctx.beginPath(); ctx.moveTo(sdX,by); ctx.lineTo(sdX+tW,by); ctx.lineTo(sdX,naY); ctx.closePath();
    ctx.fillStyle=T+'55'; ctx.fill(); ctx.strokeStyle=T; ctx.lineWidth=2; ctx.stroke();
    document.getElementById('readoutStress').textContent=`Elastic — σ ≈ ${(fpc*0.45*val/40).toFixed(1)} MPa`;
  } else if (val<80) {
    const fr=(val-40)/40, tW=mW*(0.65+fr*0.25);
    ctx.beginPath();
    for(let i=0;i<=40;i++){
      const p=i/40, y=by+compH*p, x=sdX+tW*(1-Math.pow(1-p,1.5));
      i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);
    }
    ctx.lineTo(sdX,naY); ctx.closePath();
    ctx.fillStyle=T+'55'; ctx.fill(); ctx.strokeStyle=T; ctx.lineWidth=2; ctx.stroke();
    document.getElementById('readoutStress').textContent=`Parabolic — σ_max ≈ ${(fpc*0.45+fpc*0.3*fr).toFixed(1)} MPa`;
  } else {
    const rW=mW*0.85, rH=compH*(0.85+(val-80)/20*0.1);
    ctx.fillStyle=T+'55'; ctx.fillRect(sdX,by,rW,rH);
    ctx.strokeStyle=T; ctx.lineWidth=2; ctx.strokeRect(sdX,by,rW,rH);
    ctx.fillStyle=T; ctx.font='10px Space Mono'; ctx.fillText("0.85f'c",sdX+rW/2-22,by+rH/2+4); ctx.fillText('← a →',sdX+rW+4,by+rH/2);
    document.getElementById('readoutStress').textContent=`ACI Rect. Block — 0.85f'c = ${(fpc*0.85).toFixed(1)} MPa`;
  }

  ctx.fillStyle=R+'22'; ctx.fillRect(bx,naY,bW,bH-bH*naF);
  ctx.fillStyle=T; ctx.font='10px Space Mono'; ctx.fillText('Comp.',bx+2,by+14);
  ctx.fillStyle=R; ctx.fillText('Tension',bx+2,naY+18);
  ctx.fillStyle=M; ctx.fillText('Stress Distribution',sdX,by-10);
  ctx.fillStyle=T; ctx.fillText('N.A.',bx+bW+4,naY+4);
  ctx.fillStyle=A; ctx.font='11px Space Mono';
  ctx.fillText(val<40?'Elastic (WSD range)':val<80?'Inelastic — parabolic':'Ultimate — ACI rect. block', w*0.08, h-12);
});

// ── Calculator: T = As * fs ──────────────────────────
document.getElementById('btnCalcT').addEventListener('click',()=>{
  const As=+document.getElementById('cAs').value, fs=+document.getElementById('cFs').value;
  if(isNaN(As)||isNaN(fs)) return;
  const T2=As*fs, res=document.getElementById('resT');
  res.classList.add('visible');
  document.getElementById('resT-val').textContent=`T = ${(T2/1000).toFixed(2)} kN`;
  document.getElementById('stepsT-1').textContent=`Inputs: As = ${As} mm², fs = ${fs} MPa`;
  document.getElementById('stepsT-2').textContent=`T = As × fs = ${As} × ${fs} = ${T2.toFixed(0)} N`;
  document.getElementById('stepsT-3').textContent=`T = ${(T2/1000).toFixed(2)} kN`;
  document.getElementById('whatif-T').innerHTML=
    `<span class="whatif-chip">A<sub>s</sub> ×2 → <span>T = ${(T2/1000*2).toFixed(2)} kN</span></span>
     <span class="whatif-chip">f<sub>s</sub> ×1.5 → <span>T = ${(T2/1000*1.5).toFixed(2)} kN</span></span>`;
});
document.getElementById('btnStepsT').addEventListener('click',function(){
  const p=document.getElementById('stepsT'); p.classList.toggle('open');
  this.textContent=p.classList.contains('open')?'▾ Hide Steps':'▸ Show Steps';
});

// ── Calculator: σ = Mc/I ──────────────────────────
document.getElementById('btnCalcBend').addEventListener('click',()=>{
  const M=+document.getElementById('cM').value, c=+document.getElementById('cC').value, I=+document.getElementById('cI').value;
  if(isNaN(M)||isNaN(c)||isNaN(I)) return;
  const Mn=M*1e6, In=I*1e6, sig=Mn*c/In;
  const res=document.getElementById('resBend'); res.classList.add('visible');
  document.getElementById('resBend-val').textContent=`σ = ${sig.toFixed(2)} MPa`;
  document.getElementById('stepsBend-1').textContent=`Convert M: ${M} kN·m → ${Mn.toExponential(2)} N·mm`;
  document.getElementById('stepsBend-2').textContent=`Convert I: ${I}×10⁶ mm⁴ → ${In.toExponential(2)} mm⁴`;
  document.getElementById('stepsBend-3').textContent=`Numerator: M×c = ${(Mn*c).toExponential(3)} N·mm²`;
  document.getElementById('stepsBend-4').textContent=`σ = ${(Mn*c).toExponential(3)} / ${In.toExponential(2)} = ${sig.toFixed(2)} MPa`;
  document.getElementById('whatif-Bend').innerHTML=
    `<span class="whatif-chip">c ×2 → <span>σ = ${(Mn*c*2/In).toFixed(2)} MPa</span></span>
     <span class="whatif-chip">M ×1.5 → <span>σ = ${(Mn*1.5*c/In).toFixed(2)} MPa</span></span>`;
});
document.getElementById('btnStepsBend').addEventListener('click',function(){
  const p=document.getElementById('stepsBend'); p.classList.toggle('open');
  this.textContent=p.classList.contains('open')?'▾ Hide Steps':'▸ Show Steps';
});

// ── Resize: redraw all canvases ──────────────────────────
window.addEventListener('resize',()=>{
  ['sliderStrain','sliderPlane','sliderCrack','sliderStress'].forEach(id=>{
    document.getElementById(id).dispatchEvent(new Event('input'));
  });
});
</script>

