<script>
// ═══════════════════════════════════════════════════════════
// 1. LOAD VISUALIZER
// ═══════════════════════════════════════════════════════════
(function() {
  const canvas = document.getElementById('load-canvas');
  const ctx = canvas.getContext('2d');
  const info = document.getElementById('load-info');
  let activeLoad = 'dead';
  let animFrame;
  let t = 0;

  function resize() {
    const w = canvas.parentElement.offsetWidth;
    canvas.width = w;
    canvas.height = 320;
  }
  resize();
  window.addEventListener('resize', () => { resize(); draw(); });

  const loadData = {
    dead: {
      info: '<strong>Dead Load (D):</strong> Permanent gravity loads — self-weight of beams, columns, slabs, finishes, and partitions. These never move. In ETABS you assign unit weight of concrete (24 kN/m³) and the software auto-calculates. BNBC & ACI include D in every load combo.',
      color: '#60a5fa',
    },
    live: {
      info: '<strong>Live Load (L):</strong> Occupancy-dependent loads that change over time — people, furniture, equipment. BNBC specifies minimum values: 2.0 kPa for residential, 4.0 kPa for offices. In ETABS these are assigned as uniform area loads on slabs.',
      color: '#4ade80',
    },
    wind: {
      info: '<strong>Wind Load (W):</strong> Lateral pressure from wind acting on the building facade. BNBC defines design wind speed and exposure categories. In ETABS you input wind parameters and the software distributes pressure on exposed surfaces — creating overturning moment and story shear.',
      color: '#3ecfcf',
    },
    seismic: {
      info: '<strong>Seismic Load (E):</strong> Earthquake ground motion translated to equivalent lateral forces. BNBC uses spectral acceleration curves. ETABS applies the base shear V = CsW distributed over building height — higher floors get more force because they have more inertia relative to the shaking base.',
      color: '#e05c5c',
    },
  };

  function drawBuilding(highlights) {
    const W = canvas.width, H = canvas.height;
    const bw = Math.min(220, W * 0.35);
    const bh = 200;
    const bx = W / 2 - bw / 2;
    const by = H - 40 - bh;
    const floors = 4;
    const fh = bh / floors;

    // ground
    ctx.fillStyle = '#1a1a24';
    ctx.fillRect(0, H - 40, W, 40);
    ctx.strokeStyle = '#2a2a3a';
    ctx.lineWidth = 1;
    for (let i = 0; i < W; i += 20) {
      ctx.beginPath();
      ctx.moveTo(i, H - 40);
      ctx.lineTo(i + 10, H);
      ctx.stroke();
    }

    // columns + floors
    const cols = [bx, bx + bw / 2, bx + bw];
    for (let f = 0; f <= floors; f++) {
      const y = by + f * fh;
      ctx.strokeStyle = '#3a3a4a';
      ctx.lineWidth = 2;
      ctx.beginPath();
      ctx.moveTo(bx - 4, y); ctx.lineTo(bx + bw + 4, y);
      ctx.stroke();
    }
    cols.forEach(cx => {
      for (let f = 0; f < floors; f++) {
        const y = by + f * fh;
        ctx.strokeStyle = '#4a4a5a';
        ctx.lineWidth = 10;
        ctx.beginPath();
        ctx.moveTo(cx, y + 4);
        ctx.lineTo(cx, y + fh - 4);
        ctx.stroke();
      }
    });

    // slab fill
    for (let f = 0; f < floors; f++) {
      const y = by + f * fh;
      ctx.fillStyle = 'rgba(255,255,255,0.02)';
      ctx.fillRect(bx + 5, y + 2, bw - 10, fh - 4);
    }

    highlights(W, H, bx, by, bw, bh, fh, floors);
  }

  function drawDeadLoad(W, H, bx, by, bw, bh, fh, floors) {
    ctx.fillStyle = '#60a5fa';
    for (let f = 0; f <= floors; f++) {
      const y = by + f * fh;
      const arrows = 5;
      for (let i = 0; i <= arrows; i++) {
        const ax = bx + (bw / arrows) * i;
        const len = 18 + Math.sin(t * 0.05 + i) * 3;
        ctx.strokeStyle = 'rgba(96,165,250,0.7)';
        ctx.lineWidth = 2;
        ctx.beginPath();
        ctx.moveTo(ax, y - len - 8);
        ctx.lineTo(ax, y - 4);
        ctx.stroke();
        ctx.beginPath();
        ctx.moveTo(ax - 4, y - 10);
        ctx.lineTo(ax, y - 4);
        ctx.lineTo(ax + 4, y - 10);
        ctx.stroke();
      }
    }
  }

  function drawLiveLoad(W, H, bx, by, bw, bh, fh, floors) {
    // animated people on each floor
    for (let f = 0; f < floors; f++) {
      const fy = by + (f + 0.5) * fh;
      const numPeople = 3;
      for (let p = 0; p < numPeople; p++) {
        const px = bx + (bw / (numPeople + 1)) * (p + 1) + Math.sin(t * 0.04 + p * 2 + f) * 6;
        // body
        ctx.strokeStyle = '#4ade80';
        ctx.lineWidth = 2;
        ctx.beginPath();
        ctx.arc(px, fy - 12, 5, 0, Math.PI * 2);
        ctx.stroke();
        ctx.beginPath();
        ctx.moveTo(px, fy - 7);
        ctx.lineTo(px, fy + 4);
        ctx.lineTo(px - 5, fy + 12);
        ctx.moveTo(px, fy + 4);
        ctx.lineTo(px + 5, fy + 12);
        ctx.moveTo(px, fy - 4);
        ctx.lineTo(px - 5, fy);
        ctx.moveTo(px, fy - 4);
        ctx.lineTo(px + 5, fy);
        ctx.stroke();
        // downward arrow
        ctx.strokeStyle = 'rgba(74,222,128,0.4)';
        ctx.lineWidth = 1.5;
        const ay = by + (f + 1) * fh;
        ctx.beginPath();
        ctx.setLineDash([3, 3]);
        ctx.moveTo(px, fy + 14);
        ctx.lineTo(px, ay - 4);
        ctx.stroke();
        ctx.setLineDash([]);
      }
    }
  }

  function drawWindLoad(W, H, bx, by, bw, bh, fh, floors) {
    // wind arrows from left, increasing with height (triangular distribution)
    const side = bx;
    for (let f = 0; f < floors; f++) {
      const fy = by + (f + 0.5) * fh;
      const magnitude = (floors - f) / floors; // more at top for wind
      const len = 20 + magnitude * 50;
      const offset = Math.sin(t * 0.08 + f * 0.5) * 4;
      ctx.strokeStyle = `rgba(62,207,207,${0.4 + magnitude * 0.5})`;
      ctx.lineWidth = 2 + magnitude * 2;
      ctx.beginPath();
      ctx.moveTo(side - len + offset, fy);
      ctx.lineTo(side - 4, fy);
      ctx.stroke();
      ctx.beginPath();
      ctx.moveTo(side - 12, fy - 6);
      ctx.lineTo(side - 4, fy);
      ctx.lineTo(side - 12, fy + 6);
      ctx.stroke();
    }
    // label
    ctx.fillStyle = 'rgba(62,207,207,0.7)';
    ctx.font = `10px 'Space Mono', monospace`;
    ctx.fillText('WIND', bx - 70, by + bh / 2);
    ctx.fillText('PRESSURE', bx - 75, by + bh / 2 + 14);
    // pressure triangle
    ctx.strokeStyle = 'rgba(62,207,207,0.15)';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(bx - 5, by);
    ctx.lineTo(bx - 5, by + bh);
    ctx.stroke();
  }

  function drawSeismicLoad(W, H, bx, by, bw, bh, fh, floors) {
    // shaking ground + lateral forces increasing up floors
    const shake = Math.sin(t * 0.15) * 8;
    // ground motion
    ctx.strokeStyle = 'rgba(224,92,92,0.8)';
    ctx.lineWidth = 3;
    ctx.beginPath();
    for (let x = 0; x < W; x += 4) {
      const y = H - 20 + Math.sin(x * 0.2 + t * 0.2) * 6;
      x === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    }
    ctx.stroke();

    // lateral forces on each floor (inverted triangle)
    for (let f = 0; f < floors; f++) {
      const fy = by + (f + 0.5) * fh;
      const heightRatio = (floors - f) / floors; // more force at top
      const forceLen = 15 + heightRatio * 45;
      const dir = Math.sign(Math.sin(t * 0.1)) * (0.8 + heightRatio * 0.2);
      const fx = bx + bw / 2 + shake * heightRatio;
      ctx.strokeStyle = `rgba(224,92,92,${0.5 + heightRatio * 0.4})`;
      ctx.lineWidth = 2 + heightRatio * 2;
      ctx.beginPath();
      ctx.moveTo(fx, fy);
      ctx.lineTo(fx + forceLen * dir, fy);
      ctx.stroke();
      ctx.beginPath();
      const arrowDir = dir > 0 ? 1 : -1;
      ctx.moveTo(fx + forceLen * dir, fy);
      ctx.lineTo(fx + forceLen * dir - 8 * arrowDir, fy - 5);
      ctx.moveTo(fx + forceLen * dir, fy);
      ctx.lineTo(fx + forceLen * dir - 8 * arrowDir, fy + 5);
      ctx.stroke();
    }

    ctx.fillStyle = 'rgba(224,92,92,0.6)';
    ctx.font = `9px 'Space Mono', monospace`;
    ctx.fillText(`V = Cs × W`, bx + bw + 10, by + 20);
    ctx.fillText('(BNBC seismic)', bx + bw + 10, by + 33);
  }

  function draw() {
    const W = canvas.width, H = canvas.height;
    ctx.clearRect(0, 0, W, H);
    drawBuilding((W, H, bx, by, bw, bh, fh, floors) => {
      if (activeLoad === 'dead')    drawDeadLoad(W, H, bx, by, bw, bh, fh, floors);
      if (activeLoad === 'live')    drawLiveLoad(W, H, bx, by, bw, bh, fh, floors);
      if (activeLoad === 'wind')    drawWindLoad(W, H, bx, by, bw, bh, fh, floors);
      if (activeLoad === 'seismic') drawSeismicLoad(W, H, bx, by, bw, bh, fh, floors);
    });
    // load label
    const c = loadData[activeLoad].color;
    ctx.fillStyle = c;
    ctx.font = `bold 11px 'Space Mono', monospace`;
    ctx.fillText(activeLoad.toUpperCase() + ' LOAD', 16, 24);
    t++;
    animFrame = requestAnimationFrame(draw);
  }

  draw();

  document.querySelectorAll('.load-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.load-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeLoad = btn.dataset.load;
      info.innerHTML = loadData[activeLoad].info;
    });
  });
})();


// ═══════════════════════════════════════════════════════════
// 2. ETABS PIPELINE
// ═══════════════════════════════════════════════════════════
(function() {
  const steps = [
    {
      title: 'STEP 1 — GEOMETRY DEFINITION',
      items: [
        'Create a grid system — define column line spacings in X and Y direction',
        'Set story heights (e.g. 3.5 m per floor × 4 floors)',
        'Define material properties: f\'c, fy, unit weight, elastic modulus',
        'This is the skeleton — no members yet, just coordinate system',
      ]
    },
    {
      title: 'STEP 2 — MEMBER ASSIGNMENT',
      items: [
        'Draw beams along grid lines using "Draw Frame Element"',
        'Draw columns at grid intersections',
        'Define slab/wall sections and assign as area objects',
        'Assign frame sections (e.g. 300×600 beam, 400×400 column)',
        'Define veranda using "Draw Line with None Properties" then expand to area',
      ]
    },
    {
      title: 'STEP 3 — BOUNDARY CONDITIONS',
      items: [
        'Assign fixed supports at base of all ground-floor columns',
        'Fixed = all 6 DOFs restrained (Ux, Uy, Uz, Rx, Ry, Rz)',
        'Incorrect supports = wrong reactions — most common student error',
        'Replicate one story to create multi-story building using Edit > Replicate',
      ]
    },
    {
      title: 'STEP 4 — LOAD DEFINITION',
      items: [
        'Define static load cases: DEAD, LIVE, WINDX, WINDY, SEISMIC',
        'Assign floor loads (kPa) on slabs using "Assign > Shell Loads > Uniform"',
        'Input BNBC wind parameters: basic wind speed V, exposure category',
        'Input BNBC seismic parameters: seismic zone, soil type, response spectrum',
        'ETABS auto-generates ACI load combinations: 1.2D+1.6L, 1.2D+1.0W+1.0L, etc.',
      ]
    },
    {
      title: 'STEP 5 — ANALYSIS RUN',
      items: [
        'Assign Diaphragm constraint to each floor slab (rigid floor assumption)',
        'Run Area Mesh to subdivide slabs for accurate load distribution',
        'Analyze > Run Analysis (or F5)',
        'ETABS solves the global stiffness matrix [K]{d} = {F} for all DOFs',
        'Solver returns displacements at every node, reactions at every support',
      ]
    },
    {
      title: 'STEP 6 — RESULTS EXTRACTION',
      items: [
        'View > Show Forces/Stresses: moment diagrams, shear, axial in every member',
        'Display > Show Tables: export numerical reactions for design checks',
        'Support reactions → used to design foundations',
        'Column/beam forces → used to check capacity against ACI φMn, φVn',
        'Story drifts and displacements → check BNBC serviceability limits',
      ]
    },
  ];

  const detail = document.getElementById('pipe-detail');
  const detailTitle = document.getElementById('pipe-detail-title');
  const detailList = document.getElementById('pipe-detail-list');

  function showStep(idx) {
    document.querySelectorAll('.pipe-step').forEach((s, i) => {
      s.classList.toggle('active', i === idx);
    });
    const s = steps[idx];
    detailTitle.textContent = s.title;
    detailList.innerHTML = s.items.map(i => `<li>${i}</li>`).join('');
    detail.classList.add('visible');
  }

  showStep(0);

  document.getElementById('pipeline').addEventListener('click', e => {
    const step = e.target.closest('.pipe-step');
    if (step) showStep(parseInt(step.dataset.step));
  });
})();


