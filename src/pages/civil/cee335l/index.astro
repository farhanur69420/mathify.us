// 5. GRADE DONUT CHART
// ═══════════════════════════════════════════════════════════
(function() {
  const canvas = document.getElementById('gradeCanvas');
  const ctx = canvas.getContext('2d');
  const legend = document.getElementById('grade-legend');

  const grades = [
    { name: 'Attendance & Performance', sub: 'Every class counts', pct: 20, color: '#60a5fa' },
    { name: 'Quizzes',                  sub: 'Day 3 — Basic ETABS check', pct: 20, color: '#4ade80' },
    { name: 'Midterm Exam',             sub: 'Day 6 — Beams & bridges', pct: 25, color: '#f0a500' },
    { name: 'Final Exam',               sub: 'Day 11 — Full building',   pct: 35, color: '#e05c5c' },
  ];

  let hovered = -1;
  let animProgress = 0;
  let animating = true;

  // legend
  grades.forEach((g, i) => {
    const item = document.createElement('div');
    item.className = 'legend-item';
    item.innerHTML = `
      <div class="legend-swatch" style="background:${g.color}"></div>
      <div class="legend-text">
        <div class="legend-name">${g.name}</div>
        <div class="legend-sub">${g.sub}</div>
      </div>
      <div class="legend-pct">${g.pct}%</div>
    `;
    item.addEventListener('mouseenter', () => { hovered = i; drawDonut(); });
    item.addEventListener('mouseleave', () => { hovered = -1; drawDonut(); });
    legend.appendChild(item);
  });

  function drawDonut(progress = 1) {
    const W = 200, H = 200;
    ctx.clearRect(0, 0, W, H);
    const cx = W / 2, cy = H / 2;
    const r = 78, inner = 48;
    let startAngle = -Math.PI / 2;

    grades.forEach((g, i) => {
      const slice = (g.pct / 100) * 2 * Math.PI * progress;
      const endAngle = startAngle + slice;
      const isHov = hovered === i;
      const offset = isHov ? 6 : 0;
      const midAngle = startAngle + slice / 2;
      const ox = Math.cos(midAngle) * offset;
      const oy = Math.sin(midAngle) * offset;

      ctx.beginPath();
      ctx.arc(cx + ox, cy + oy, r, startAngle, endAngle);
      ctx.arc(cx + ox, cy + oy, inner, endAngle, startAngle, true);
      ctx.closePath();
      ctx.fillStyle = isHov ? g.color : g.color + 'cc';
      ctx.fill();
      if (isHov) {
        ctx.strokeStyle = '#fff';
        ctx.lineWidth = 2;
        ctx.stroke();
      }
      startAngle = endAngle;
    });

    // center text
    if (hovered >= 0 && progress === 1) {
      ctx.fillStyle = grades[hovered].color;
      ctx.font = `bold 24px 'Space Mono', monospace`;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(`${grades[hovered].pct}%`, cx, cy);
    } else {
      ctx.fillStyle = '#7a7a9a';
      ctx.font = `11px 'Space Mono', monospace`;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText('CEE335L', cx, cy - 8);
      ctx.fillText('GRADE', cx, cy + 8);
    }
  }

  function animate() {
    if (!animating) return;
    animProgress += 0.04;
    if (animProgress >= 1) { animProgress = 1; animating = false; drawDonut(1); return; }
    drawDonut(animProgress);
    requestAnimationFrame(animate);
  }

  // Start animation when visible
  const obs = new IntersectionObserver(entries => {
    if (entries[0].isIntersecting) { animate(); obs.disconnect(); }
  }, { threshold: 0.3 });
  obs.observe(canvas);

  canvas.addEventListener('mousemove', e => {
    const rect = canvas.getBoundingClientRect();
    const mx = e.clientX - rect.left - 100;
    const my = e.clientY - rect.top - 100;
    const dist = Math.sqrt(mx*mx + my*my);
    if (dist < 78 && dist > 48) {
      const angle = Math.atan2(my, mx) + Math.PI / 2;
      const normalized = (angle < 0 ? angle + 2 * Math.PI : angle) / (2 * Math.PI);
      let cumulative = 0;
      hovered = -1;
      grades.forEach((g, i) => {
        cumulative += g.pct / 100;
        if (normalized <= cumulative && hovered === -1) hovered = i;
      });
    } else {
      hovered = -1;
    }
    drawDonut();
  });
  canvas.addEventListener('mouseleave', () => { hovered = -1; drawDonut(); });
})();
</script>
