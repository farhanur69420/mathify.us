// 3. CODE EXPLORER
// ═══════════════════════════════════════════════════════════
(function() {
  const codes = {
    bnbc: {
      title: 'Bangladesh National Building Code',
      use: 'Used for: all loads on buildings in Bangladesh — dead, live, wind, and seismic. Governs building design in Days 7 & 8.',
      items: [
        { label: 'Live Load — Residential', val: '2.0 kPa (UDL)' },
        { label: 'Live Load — Office',      val: '4.0 kPa (UDL)' },
        { label: 'Basic Wind Speed (Dhaka)', val: 'V = 200 km/h (zone)' },
        { label: 'Seismic Zone (Dhaka)',     val: 'Zone 2 (moderate)' },
        { label: 'Seismic Base Shear',       val: 'V = C·S·W / R' },
        { label: 'Wind Pressure Formula',    val: 'p = q·G·Cp' },
      ]
    },
    aci: {
      title: 'American Concrete Institute — ACI 318',
      use: 'Used for: concrete member design — beam flexure, shear, column interaction. The underlying design standard for CEE335 theory course.',
      items: [
        { label: 'Governing Combo (gravity)', val: 'U = 1.2D + 1.6L' },
        { label: 'With wind',                 val: 'U = 1.2D + 1.0W + 1.0L' },
        { label: 'Flexure capacity',          val: 'φMn ≥ Mu, φ = 0.90' },
        { label: 'Shear capacity',            val: 'φVn ≥ Vu, φ = 0.75' },
        { label: 'Minimum steel ratio',       val: 'ρ_min = 3√f\'c / fy' },
        { label: 'Max. usable strain (εcu)',  val: '0.003 (concrete crushes)' },
      ]
    },
    aashto: {
      title: 'American Assoc. of State Highway & Transportation Officials',
      use: 'Used for: bridge design — slab bridges, deck girders, balanced cantilever bridges. Applied in Days 4 & 5.',
      items: [
        { label: 'Bridge Load: HS20 Truck',     val: '8 + 32 + 32 kips axles' },
        { label: 'Lane Load',                   val: '0.64 k/ft + 18-k conc.' },
        { label: 'Slab Span Direction',         val: 'Perpendicular to traffic' },
        { label: 'Moment (slab, S ≤ 16 ft)',   val: 'M = (S+2)/32 × P' },
        { label: 'Effective slab width (E)',    val: 'E = 4 + 0.06S (ft)' },
        { label: 'Impact Factor (I)',           val: 'I = 50/(L+125) ≤ 0.30' },
      ]
    },
  };

  const panelsDiv = document.getElementById('code-panels');

  Object.keys(codes).forEach(key => {
    const d = codes[key];
    const div = document.createElement('div');
    div.className = 'code-panel' + (key === 'bnbc' ? ' visible' : '');
    div.id = 'panel-' + key;
    div.innerHTML = `
      <h4>${d.title}</h4>
      <p class="code-use">${d.use}</p>
      <div class="code-items">
        ${d.items.map(it => `
          <div class="code-item">
            <div class="code-item-label">${it.label}</div>
            <div class="code-item-val">${it.val}</div>
          </div>
        `).join('')}
      </div>
    `;
    panelsDiv.appendChild(div);
  });

  document.getElementById('code-tabs').addEventListener('click', e => {
    const tab = e.target.closest('.code-tab');
    if (!tab) return;
    document.querySelectorAll('.code-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.code-panel').forEach(p => p.classList.remove('visible'));
    tab.classList.add('active');
    document.getElementById('panel-' + tab.dataset.code).classList.add('visible');
  });
})();


