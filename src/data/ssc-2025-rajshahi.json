  "cq": [
    {
      "n": 1,
      "ch": "Sets and Functions",
      "stem": "In a class of 60 students, 35 study Mathematics (M), 30 study Science (S), and 10 study both.",
      "stemBn": "60 জন শিক্ষার্থীর একটি শ্রেণিতে 35 জন গণিত (M), 30 জন বিজ্ঞান (S) এবং 10 জন উভয় বিষয় পড়ে।",
      "viz": "venn",
      "vizData": {
        "A": 35,
        "B": 30,
        "AB": 10,
        "total": 60
      },
      "parts": [
        {
          "l": "ক",
          "m": 2,
          "q": "How many study only Mathematics?",
          "sol": [
            {
              "m": "M \\text{ only} = n(M) - n(M \\cap S) = 35 - 10 = \\boxed{25}"
            }
          ]
        },
        {
          "l": "খ",
          "m": 4,
          "q": "How many study at least one of the two subjects?",
          "sol": [
            {
              "m": "n(M \\cup S) = n(M) + n(S) - n(M \\cap S) = 35 + 30 - 10 = \\boxed{55}"
            }
          ]
        },
        {
          "l": "গ",
          "m": 4,
          "q": "How many study neither subject? Express \\(n(M' \\cap S')\\) in terms of the universal set.",
          "sol": [
            {
              "m": "n(M' \\cap S') = n(U) - n(M \\cup S) = 60 - 55 = \\boxed{5}"
            },
            {
              "note": "Check: 25 + 10 + 20 + 5 = 60 ✓"
            }
          ]
        }
      ]
    },
    {
      "n": 2,
      "ch": "Algebraic Expressions",
      "stem": "\\(x - \\frac{1}{x} = 5\\)",
      "stemBn": "\\(x - \\frac{1}{x} = 5\\)",
      "parts": [
        {
          "l": "ক",
          "m": 2,
          "q": "Find \\(x^2 + \\frac{1}{x^2}\\).",
          "sol": [
            {
              "m": "\\left(x - \\frac{1}{x}\\right)^2 = x^2 - 2 + \\frac{1}{x^2} = 25"
            },
            {
              "m": "x^2 + \\frac{1}{x^2} = 25 + 2 = \\boxed{27}"
            }
          ]
        },
        {
          "l": "খ",
          "m": 4,
          "q": "Find \\(x^4 + \\frac{1}{x^4}\\).",
          "sol": [
            {
              "m": "\\left(x^2 + \\frac{1}{x^2}\\right)^2 = x^4 + 2 + \\frac{1}{x^4} = 729"
            },
            {
              "m": "x^4 + \\frac{1}{x^4} = 729 - 2 = \\boxed{727}"
            }
          ]
        },
        {
          "l": "গ",
          "m": 4,
          "q": "Find \\(x^3 - \\frac{1}{x^3}\\).",
          "sol": [
            {
              "t": "Using \\(a^3 - b^3 = (a-b)(a^2 + ab + b^2)\\) with \\(a = x, b = \\frac{1}{x}\\):"
            },
            {
              "m": "x^3 - \\frac{1}{x^3} = \\left(x - \\frac{1}{x}\\right)\\left(x^2 + 1 + \\frac{1}{x^2}\\right)"
            },
            {
              "m": "= 5 \\times (27 + 1) = 5 \\times 28 = \\boxed{140}"
            }
          ]
        }
      ]
    },
    {
