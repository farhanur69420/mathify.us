  "cq": [
    {
      "n": 1,
      "ch": "Sets and Functions",
      "stem": "In a class of 50 students, 30 like Mathematics (M), 25 like Science (S), and 10 like both.",
      "stemBn": "50 জন শিক্ষার্থীর একটি ক্লাসে, 30 জন গণিত (M) পছন্দ করে, 25 জন বিজ্ঞান (S) পছন্দ করে এবং 10 জন উভয়ই পছন্দ করে।",
      "parts": [
        {
          "l": "ক",
          "m": 2,
          "q": "Find \\(n(M \\cup S)\\).",
          "sol": [
            {
              "m": "n(M \\cup S) = 30+25-10 = \\boxed{45}"
            }
          ]
        },
        {
          "l": "খ",
          "m": 4,
          "q": "How many students like only Mathematics?",
          "sol": [
            {
              "m": "n(M \\text{ only}) = n(M) - n(M \\cap S) = 30-10 = \\boxed{20}"
            },
            {
              "t": "Similarly, Science only = \\(25-10 = 15\\)"
            }
          ]
        },
        {
          "l": "গ",
          "m": 4,
          "q": "How many students like neither? Draw a Venn diagram.",
          "sol": [
            {
              "m": "n(\\text{neither}) = 50 - n(M \\cup S) = 50 - 45 = \\boxed{5}"
            },
            {
              "note": "Venn: M only = 20, Both = 10, S only = 15, Outside = 5. Total = 50 \\checkmark"
            }
          ]
        }
      ]
    },
    {
      "n": 2,
      "ch": "Algebraic Expressions",
      "stem": "\\(x - \\frac{1}{x} = 3\\)",
      "stemBn": "\\(x - \\frac{1}{x} = 3\\)",
      "parts": [
        {
          "l": "ক",
          "m": 2,
          "q": "Find \\(x^2 + \\frac{1}{x^2}\\).",
          "sol": [
            {
              "m": "\\left(x - \\frac{1}{x}\\right)^2 = x^2 - 2 + \\frac{1}{x^2} = 9"
            },
            {
              "m": "x^2 + \\frac{1}{x^2} = 9 + 2 = \\boxed{11}"
            }
          ]
        },
        {
          "l": "খ",
          "m": 4,
          "q": "Find \\(x^2 - \\frac{1}{x^2}\\).",
          "sol": [
            {
              "t": "We need \\(x + \\frac{1}{x}\\). Use: \\((x+1/x)^2 = x^2+2+1/x^2 = 11+2 = 13\\)"
            },
            {
              "m": "x + \\frac{1}{x} = \\sqrt{13} \\quad (\\text{taking positive root})"
            },
            {
              "m": "x^2 - \\frac{1}{x^2} = \\left(x-\\frac{1}{x}\\right)\\left(x+\\frac{1}{x}\\right) = 3\\sqrt{13}"
            }
          ]
        },
        {
          "l": "গ",
          "m": 4,
          "q": "Find \\(x^4 + \\frac{1}{x^4}\\).",
          "sol": [
            {
              "m": "\\left(x^2 + \\frac{1}{x^2}\\right)^2 = x^4 + 2 + \\frac{1}{x^4}"
            },
            {
              "m": "121 = x^4 + 2 + \\frac{1}{x^4}"
            },
            {
              "m": "x^4 + \\frac{1}{x^4} = \\boxed{119}"
            }
          ]
        }
      ]
    },
