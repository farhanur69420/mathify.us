    {
      "n": 1,
      "ch": "Algebraic Expressions",
      "stem": "\\(x + \\frac{1}{x} = 5\\)",
      "stemBn": "\\(x + \\frac{1}{x} = 5\\)",
      "parts": [
        {
          "l": "ক",
          "m": 2,
          "q": "Find \\(x^2 + \\frac{1}{x^2}\\). \\(x^2 + \\frac{1}{x^2}\\) নির্ণয় করো।",
          "sol": [
            {
              "m": "\\left(x + \\frac{1}{x}\\right)^2 = x^2 + 2 + \\frac{1}{x^2} = 25"
            },
            {
              "m": "x^2 + \\frac{1}{x^2} = 25 - 2 = \\boxed{23}"
            }
          ]
        },
        {
          "l": "খ",
          "m": 4,
          "q": "Find \\(x^2 - \\frac{1}{x^2}\\) given that \\(x > 1\\). \\(x > 1\\) হলে \\(x^2 - \\frac{1}{x^2}\\) নির্ণয় করো।",
          "sol": [
            {
              "m": "\\left(x - \\frac{1}{x}\\right)^2 = x^2 - 2 + \\frac{1}{x^2} = 23 - 2 = 21"
            },
            {
              "m": "x - \\frac{1}{x} = \\sqrt{21} \\quad (\\text{since } x > 1)"
            },
            {
              "m": "x^2 - \\frac{1}{x^2} = \\left(x + \\frac{1}{x}\\right)\\left(x - \\frac{1}{x}\\right) = 5\\sqrt{21}"
            }
          ]
        },
        {
          "l": "গ",
          "m": 4,
          "q": "Find \\(x^3 + \\frac{1}{x^3}\\). \\(x^3 + \\frac{1}{x^3}\\) নির্ণয় করো।",
          "sol": [
            {
              "t": "Use: \\(a^3 + b^3 = (a+b)^3 - 3ab(a+b)\\) with \\(a=x, b=1/x\\)"
            },
            {
              "m": "x^3 + \\frac{1}{x^3} = 5^3 - 3(1)(5) = 125 - 15 = \\boxed{110}"
            }
          ]
        }
      ]
    },
    {
