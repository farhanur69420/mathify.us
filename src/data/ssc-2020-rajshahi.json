    {
      "n": 1,
      "ch": "Sets and Functions",
      "en": "If \\(A = \\{2, 4, 6\\}\\), how many proper subsets does \\(A\\) have?",
      "bn": "\\(A = \\{2, 4, 6\\}\\) এর প্রকৃত উপসেটের সংখ্যা কত?",
      "opts": [
        "6",
        "7",
        "8",
        "3"
      ],
      "ans": 1,
      "sol": [
        {
          "t": "Number of subsets = \\(2^n = 2^3 = 8\\). Proper subsets exclude the set itself."
        },
        {
          "m": "\\text{Proper subsets} = 2^3 - 1 = \\boxed{7}"
        }
      ]
    },
