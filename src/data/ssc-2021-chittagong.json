          "l": "খ", "m": 4,
          "q": "Find \\(\\log 42\\).",
          "sol": [
            {"m": "\\log 42 = \\log(2 \\times 3 \\times 7) = \\log 2 + \\log 3 + \\log 7"},
            {"m": "= 0.3010 + 0.4771 + 0.8451 = \\boxed{1.6232}"}
          ]
        },
        {
          "l": "গ", "m": 4,
          "q": "Find the number of digits in \\(3^{20}\\).",
          "sol": [
            {"m": "\\log 3^{20} = 20 \\times 0.4771 = 9.542"},
            {"m": "\\text{Number of digits} = \\lfloor 9.542 \\rfloor + 1 = 9 + 1 = \\boxed{10}"},
            {"note": "\\(3^{20} = 3486784401\\) indeed has 10 digits."}
          ]
        }
      ]
    },
