  "cq": [
    {
      "n": 1, "ch": "Algebra",
      "stem": "\\(x + \\frac{1}{x} = 5\\)",
      "stemBn": "\\(x + \\frac{1}{x} = 5\\)",
      "parts": [
        {
          "l": "ক", "m": 2,
          "q": "Find \\(x^2 + \\frac{1}{x^2}\\).",
          "sol": [
            {"m": "\\left(x+\\frac{1}{x}\\right)^2 = x^2 + 2 + \\frac{1}{x^2} = 25"},
            {"m": "x^2 + \\frac{1}{x^2} = \\boxed{23}"}
          ]
        },
        {
          "l": "খ", "m": 4,
          "q": "Find \\(x^2 - \\frac{1}{x^2}\\) given \\(x - \\frac{1}{x} = \\sqrt{21}\\).",
          "sol": [
            {"m": "x^2 - \\frac{1}{x^2} = \\left(x+\\frac{1}{x}\\right)\\left(x-\\frac{1}{x}\\right)"},
            {"m": "= 5 \\times \\sqrt{21} = \\boxed{5\\sqrt{21}}"}
          ]
        },
        {
          "l": "গ", "m": 4,
          "q": "Find \\(x^3 + \\frac{1}{x^3}\\).",
          "sol": [
            {"m": "x^3 + \\frac{1}{x^3} = \\left(x+\\frac{1}{x}\\right)^3 - 3\\left(x+\\frac{1}{x}\\right)"},
            {"m": "= 125 - 15 = \\boxed{110}"}
          ]
        }
      ]
    },
    {
      "n": 2, "ch": "Sets",
      "stem": "In a survey of 60 people, 35 like tea (T), 25 like coffee (C), and 10 like both.",
      "stemBn": "60 জনের জরিপে 35 জন চা (T), 25 জন কফি (C) পছন্দ করে এবং 10 জন উভয়ই পছন্দ করে।",
      "viz": "venn",
      "parts": [
        {
          "l": "ক", "m": 2,
          "q": "Find the number who like only tea.",
          "sol": [
            {"m": "\\text{Only tea} = 35 - 10 = \\boxed{25}"}
          ]
        },
        {
          "l": "খ", "m": 4,
          "q": "Find \\(n(T \\cup C)\\) and the number who like neither.",
          "sol": [
            {"m": "n(T \\cup C) = 35 + 25 - 10 = \\boxed{50}"},
            {"m": "\\text{Neither} = 60 - 50 = \\boxed{10}"}
          ]
        },
        {
          "l": "গ", "m": 4,
          "q": "If 5 more people start liking both, find the new \\(n(T \\cup C)\\). (Assume total stays same.)",
          "sol": [
            {"t": "New \\(n(T \\cap C) = 15\\). The totals n(T) and n(C) remain 35 and 25."},
            {"m": "n(T \\cup C) = 35 + 25 - 15 = \\boxed{45}"},
            {"m": "\\text{New neither} = 60 - 45 = 15"}
          ]
        }
      ]
    },
    {
      "n": 3, "ch": "Surds",
      "stem": "\\(p = 2 + \\sqrt{3}\\) and \\(q = 2 - \\sqrt{3}\\)",
      "stemBn": "\\(p = 2 + \\sqrt{3}\\) এবং \\(q = 2 - \\sqrt{3}\\)",
      "parts": [
        {
          "l": "ক", "m": 2,
          "q": "Find \\(pq\\).",
          "sol": [
            {"m": "pq = (2+\\sqrt{3})(2-\\sqrt{3}) = 4 - 3 = \\boxed{1}"}
          ]
        },
        {
          "l": "খ", "m": 4,
          "q": "Show that \\(p^2 + q^2 = 14\\).",
          "sol": [
            {"m": "p + q = 4 \\implies (p+q)^2 = 16"},
            {"m": "p^2 + q^2 = (p+q)^2 - 2pq = 16 - 2 = \\boxed{14}\\quad\\checkmark"}
          ]
        },
        {
          "l": "গ", "m": 4,
          "q": "Find \\(p^3 + q^3\\).",
          "sol": [
            {"m": "p^3 + q^3 = (p+q)(p^2 - pq + q^2) = 4(14-1) = 4 \\times 13 = \\boxed{52}"}
          ]
        }
      ]
    },
    {
