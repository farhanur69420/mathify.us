    {
      "n": 1,
      "ch": "Sets and Functions",
      "en": "If \\(A = \\{a, b, c\\}\\), how many proper subsets does \\(A\\) have?",
      "bn": "\\(A = \\{a, b, c\\}\\) হলে \\(A\\) এর প্রকৃত উপসেটের সংখ্যা কত?",
      "opts": [
        "6",
        "7",
        "8",
        "9"
      ],
      "ans": 1,
      "sol": [
        {
          "t": "Total subsets = \\(2^3 = 8\\). Proper subsets exclude the set itself."
        },
        {
          "m": "\\text{Proper subsets} = 2^3 - 1 = \\boxed{7}"
        }
      ]
    },
    {
      "n": 2,
      "ch": "Sets and Functions",
      "en": "If \\(A \\cup B = A\\), then which is true?",
      "bn": "\\(A \\cup B = A\\) হলে কোনটি সত্য?",
      "opts": [
        "\\(A \\subset B\\)",
        "\\(B \\subseteq A\\)",
        "\\(A = \\emptyset\\)",
        "\\(B = U\\)"
      ],
      "ans": 1,
      "viz": "venn",
      "sol": [
        {
          "t": "If \\(A \\cup B = A\\), every element of \\(B\\) is already in \\(A\\)."
        },
        {
          "m": "\\therefore B \\subseteq A"
        }
      ]
    },
