  "cq": [
    {
      "n": 1,
      "ch": "Algebraic Expressions",
      "stem": "Given \\(x - \\frac{1}{x} = 5\\).",
      "stemBn": "দেওয়া আছে \\(x - \\frac{1}{x} = 5\\)।",
      "parts": [
        {
          "l": "ক",
          "m": 2,
          "q": "Find \\(x^2 + \\frac{1}{x^2}\\).",
          "sol": [
            {
              "m": "\\left(x - \\frac{1}{x}\\right)^2 = 25"
            },
            {
              "m": "x^2 - 2 + \\frac{1}{x^2} = 25 \\implies x^2 + \\frac{1}{x^2} = \\boxed{27}"
            }
          ]
        },
        {
          "l": "খ",
          "m": 4,
          "q": "Find \\(x^2 - \\frac{1}{x^2}\\) given \\(x > 0\\).",
          "sol": [
            {
              "m": "x^2 - \\frac{1}{x^2} = \\left(x - \\frac{1}{x}\\right)\\left(x + \\frac{1}{x}\\right)"
            },
            {
              "m": "\\left(x + \\frac{1}{x}\\right)^2 = x^2 + 2 + \\frac{1}{x^2} = 27 + 2 = 29"
            },
            {
              "m": "x + \\frac{1}{x} = \\sqrt{29}"
            },
            {
              "m": "x^2 - \\frac{1}{x^2} = 5\\sqrt{29} \\approx \\boxed{26.93}"
            }
          ]
        },
        {
          "l": "গ",
          "m": 4,
          "q": "Find \\(x^4 + \\frac{1}{x^4}\\).",
          "sol": [
            {
              "m": "\\left(x^2 + \\frac{1}{x^2}\\right)^2 = x^4 + 2 + \\frac{1}{x^4}"
            },
            {
              "m": "27^2 = x^4 + 2 + \\frac{1}{x^4}"
            },
            {
              "m": "x^4 + \\frac{1}{x^4} = 729 - 2 = \\boxed{727}"
            }
          ]
        }
      ]
    },
