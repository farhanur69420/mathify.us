      "n": 1,
      "ch": "Real Numbers",
      "stem": "\\(u=\\sqrt{3}+\\sqrt{2},\\quad v=\\sqrt{3}-\\sqrt{2}\\)",
      "stemBn": "",
      "parts": [
        {
          "l": "ক",
          "m": 2,
          "q": "Find \\(uv\\).",
          "sol": [
            {
              "m": "uv=(\\sqrt{3})^2-(\\sqrt{2})^2=3-2=\\boxed{1}"
            }
          ]
        },
        {
          "l": "খ",
          "m": 4,
          "q": "Find \\(u^2+v^2\\).",
          "sol": [
            {
              "m": "u+v=2\\sqrt{3},\\ uv=1"
            },
            {
              "m": "u^2+v^2=(2\\sqrt{3})^2-2(1)=12-2=\\boxed{10}"
            }
          ]
        },
        {
          "l": "গ",
          "m": 4,
          "q": "Find \\(u^3+v^3\\).",
          "sol": [
            {
              "t": "\\(u^3+v^3=(u+v)(u^2-uv+v^2)\\)"
            },
            {
              "m": "=(2\\sqrt{3})(10-1)=2\\sqrt{3}\\times9=18\\sqrt{3}"
            }
          ]
        }
      ]
