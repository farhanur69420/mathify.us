    {
      "n": 1,
      "ch": "Real Numbers",
      "stem": "\\(p = \\sqrt{5}+\\sqrt{3},\\quad q = \\sqrt{5}-\\sqrt{3}\\)",
      "stemBn": "\\(p = \\sqrt{5}+\\sqrt{3},\\quad q = \\sqrt{5}-\\sqrt{3}\\)",
      "parts": [
        {
          "l": "ক",
          "m": 2,
          "q": "Find \\(pq\\). &nbsp; \\(pq\\) নির্ণয় করো।",
          "sol": [
            {
              "m": "pq = (\\sqrt{5}+\\sqrt{3})(\\sqrt{5}-\\sqrt{3}) = 5-3 = \\boxed{2}"
