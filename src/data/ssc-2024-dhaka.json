      "n": 1,
      "ch": "Algebraic Expressions",
      "en": "If \\(a+b=5\\) and \\(ab=6\\), then \\(a^2+b^2=\\)?",
      "bn": "যদি \\(a+b=5\\) এবং \\(ab=6\\) হয়, তাহলে \\(a^2+b^2\\) = ?",
      "opts": [
        "11",
        "12",
        "13",
        "25"
      ],
      "ans": 2,
      "sol": [
        {
          "t": "Use the identity: \\(a^2+b^2 = (a+b)^2 - 2ab\\)"
        },
        {
          "m": "(5)^2 - 2(6) = 25 - 12 = \\boxed{13}"
        },
        {
          "note": "🔑 This identity appears in almost every SSC paper. Memorize it as the '2ab trick'."
        }
      ]
    },
