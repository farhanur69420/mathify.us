    {
      "n": 1,
      "ch": "Sets and Functions",
      "stem": "In a class of 60 students, 35 play cricket, 25 play football, and 10 play both.",
      "stemBn": "60 জন ছাত্রের একটি শ্রেণিতে 35 জন ক্রিকেট, 25 জন ফুটবল খেলে এবং 10 জন উভয় খেলা খেলে।",
      "viz": "venn",
      "parts": [
        {
          "l": "ক",
          "m": 2,
          "q": "Find \\(n(C \\cup F)\\).",
          "sol": [
            {
              "m": "n(C \\cup F) = n(C) + n(F) - n(C \\cap F) = 35 + 25 - 10 = \\boxed{50}"
            }
          ]
        },
        {
          "l": "খ",
          "m": 4,
          "q": "How many students play only cricket? Find the number who play neither.",
          "sol": [
            {
              "m": "\\text{Only cricket} = n(C) - n(C \\cap F) = 35 - 10 = 25"
            },
            {
              "m": "\\text{Neither} = n(U) - n(C \\cup F) = 60 - 50 = \\boxed{10}"
            }
          ]
        },
        {
          "l": "গ",
          "m": 4,
          "q": "Draw a Venn diagram and verify the total.",
          "sol": [
            {
              "t": "Only cricket = 25, Only football = 15, Both = 10, Neither = 10."
            },
            {
              "m": "25 + 15 + 10 + 10 = 60 = n(U) \\quad \\checkmark"
            }
          ]
        }
      ]
    },
