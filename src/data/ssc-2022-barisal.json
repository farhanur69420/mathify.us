            },
            {
              "m": "\\cos A = \\frac{AB}{AC} = \\frac{10}{2\\sqrt{41}} = \\frac{5}{\\sqrt{41}}"
            },
            {
              "m": "\\tan A = \\frac{BC}{AB} = \\frac{8}{10} = \\boxed{\\frac{4}{5}}"
            }
          ]
        }
      ]
