      "viz": "right_triangle_trig",
      "parts": [
        {
          "l": "ক",
          "m": 2,
          "q": "Find \\(AC\\).",
          "sol": [
            {
              "m": "AC = \\sqrt{AB^2 + BC^2} = \\sqrt{100 + 64} = \\sqrt{164} = 2\\sqrt{41} \\approx \\boxed{12.81 \\text{ cm}}"
            }
          ]
        },
        {
          "l": "খ",
          "m": 4,
          "q": "Find the area of \\(\\triangle ABC\\) and the length of the perpendicular from \\(B\\) to \\(AC\\).",
          "sol": [
            {
              "m": "\\text{Area} = \\frac{1}{2} \\times AB \\times BC = \\frac{1}{2} \\times 10 \\times 8 = 40 \\text{ sq cm}"
            },
            {
              "t": "Let \\(h\\) be the perpendicular from \\(B\\) to \\(AC\\)."
            },
            {
              "m": "\\frac{1}{2} \\times AC \\times h = 40 \\implies h = \\frac{80}{2\\sqrt{41}} = \\frac{40}{\\sqrt{41}} \\approx \\boxed{6.25 \\text{ cm}}"
            }
          ]
        },
        {
