      {"l":"খ","m":4,"q":"Find \\(p^2+q^2\\).","sol":[{"m":"p+q=2\\sqrt{6},\\quad pq=4"},{"m":"p^2+q^2=(2\\sqrt{6})^2-2(4)=24-8=\\boxed{16}"}]},
      {"l":"গ","m":4,"q":"Rationalize \\(\\frac{1}{p}\\).","sol":[{"m":"\\frac{1}{\\sqrt{6}+\\sqrt{2}}\\cdot\\frac{\\sqrt{6}-\\sqrt{2}}{\\sqrt{6}-\\sqrt{2}}=\\frac{\\sqrt{6}-\\sqrt{2}}{4}"}]}
    ]},
    {"n":2,"ch":"Logarithms","stem":"\\(\\log_4 x + \\log_4 16 = 4\\)","stemBn":"","parts":[
