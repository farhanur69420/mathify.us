  "cq": [
    {
      "n": 1, "ch": "Algebra",
      "stem": "\\(a + b = 7\\) and \\(ab = 10\\)",
      "stemBn": "\\(a + b = 7\\) এবং \\(ab = 10\\)",
      "parts": [
        {
          "l": "ক", "m": 2,
          "q": "Find \\(a^2 + b^2\\).",
          "sol": [
            {"m": "a^2+b^2 = (a+b)^2 - 2ab = 49 - 20 = \\boxed{29}"}
          ]
        },
        {
          "l": "খ", "m": 4,
          "q": "Find \\((a - b)^2\\).",
          "sol": [
            {"m": "(a-b)^2 = (a+b)^2 - 4ab = 49 - 40 = \\boxed{9}"},
            {"t": "Therefore \\(a - b = \\pm 3\\)"}
          ]
        },
        {
          "l": "গ", "m": 4,
          "q": "Find \\(a^3 + b^3\\).",
          "sol": [
            {"t": "Use identity: \\(a^3+b^3 = (a+b)(a^2-ab+b^2)\\)"},
            {"m": "a^2 - ab + b^2 = 29 - 10 = 19"},
            {"m": "a^3+b^3 = 7 \\times 19 = \\boxed{133}"}
          ]
        }
      ]
    },
    {
      "n": 2, "ch": "Surds",
      "stem": "\\(x = \\sqrt{3} + \\sqrt{2}\\) and \\(y = \\sqrt{3} - \\sqrt{2}\\)",
      "stemBn": "\\(x = \\sqrt{3} + \\sqrt{2}\\) এবং \\(y = \\sqrt{3} - \\sqrt{2}\\)",
      "parts": [
        {
          "l": "ক", "m": 2,
          "q": "Find \\(xy\\).",
          "sol": [
            {"m": "xy = (\\sqrt{3}+\\sqrt{2})(\\sqrt{3}-\\sqrt{2}) = 3-2 = \\boxed{1}"}
          ]
        },
        {
          "l": "খ", "m": 4,
          "q": "Show that \\(x^2 + y^2 = 10\\).",
          "sol": [
            {"m": "x^2 = (\\sqrt{3}+\\sqrt{2})^2 = 3+2\\sqrt{6}+2 = 5+2\\sqrt{6}"},
            {"m": "y^2 = (\\sqrt{3}-\\sqrt{2})^2 = 3-2\\sqrt{6}+2 = 5-2\\sqrt{6}"},
            {"m": "x^2+y^2 = 5+2\\sqrt{6}+5-2\\sqrt{6} = \\boxed{10} \\checkmark"}
          ]
        },
        {
          "l": "গ", "m": 4,
          "q": "Find \\(\\frac{x}{y} + \\frac{y}{x}\\).",
          "sol": [
            {"m": "\\frac{x}{y}+\\frac{y}{x} = \\frac{x^2+y^2}{xy} = \\frac{10}{1} = \\boxed{10}"}
          ]
        }
      ]
    },
    {
      "n": 3, "ch": "Logarithms",
      "stem": "Given \\(\\log 2 = 0.3010\\) and \\(\\log 3 = 0.4771\\)",
      "stemBn": "দেওয়া আছে \\(\\log 2 = 0.3010\\) এবং \\(\\log 3 = 0.4771\\)",
      "parts": [
        {
          "l": "ক", "m": 2,
          "q": "Find \\(\\log 6\\).",
          "sol": [
            {"m": "\\log 6 = \\log(2\\times3) = \\log 2 + \\log 3 = 0.3010 + 0.4771 = \\boxed{0.7781}"}
          ]
        },
        {
          "l": "খ", "m": 4,
          "q": "Find \\(\\log 12\\).",
          "sol": [
            {"m": "\\log 12 = \\log(4\\times3) = \\log 2^2 + \\log 3"},
            {"m": "= 2(0.3010) + 0.4771 = 0.6020 + 0.4771 = \\boxed{1.0791}"}
          ]
        },
        {
          "l": "গ", "m": 4,
          "q": "Find \\(\\log 0.15\\).",
          "sol": [
            {"m": "\\log 0.15 = \\log\\frac{15}{100} = \\log 15 - \\log 100"},
            {"m": "\\log 15 = \\log(3\\times5) = \\log 3 + \\log 5"},
            {"m": "\\log 5 = \\log\\frac{10}{2} = 1 - 0.3010 = 0.6990"},
            {"m": "\\log 15 = 0.4771 + 0.6990 = 1.1761"},
            {"m": "\\log 0.15 = 1.1761 - 2 = \\boxed{-0.8239}"}
          ]
        }
      ]
    },
