  "cq": [
    {
      "n": 1,
      "ch": "Algebraic Expressions",
      "stem": "\\(x + \\frac{1}{x} = \\sqrt{5}\\)",
      "stemBn": "\\(x + \\frac{1}{x} = \\sqrt{5}\\)",
      "parts": [
        {
          "l": "ক",
          "m": 2,
          "q": "Find \\(x^2 + \\frac{1}{x^2}\\).",
          "sol": [
            {
              "m": "\\left(x + \\frac{1}{x}\\right)^2 = x^2 + 2 + \\frac{1}{x^2} = 5"
            },
            {
              "m": "x^2 + \\frac{1}{x^2} = 5 - 2 = \\boxed{3}"
            }
          ]
        },
        {
          "l": "খ",
          "m": 4,
          "q": "Find \\(x^2 - \\frac{1}{x^2}\\) given \\(x > 1\\).",
          "sol": [
            {
              "m": "x - \\frac{1}{x} = \\pm\\sqrt{\\left(x + \\frac{1}{x}\\right)^2 - 4} = \\pm\\sqrt{5-4} = \\pm 1"
            },
            {
              "t": "Since \\(x > 1\\), \\(x - \\frac{1}{x} > 0\\), so \\(x - \\frac{1}{x} = 1\\)"
            },
            {
              "m": "x^2 - \\frac{1}{x^2} = \\left(x + \\frac{1}{x}\\right)\\left(x - \\frac{1}{x}\\right) = \\sqrt{5} \\times 1 = \\boxed{\\sqrt{5}}"
            }
          ]
        },
        {
          "l": "গ",
          "m": 4,
          "q": "Find \\(x^4 + \\frac{1}{x^4}\\).",
          "sol": [
            {
              "m": "\\left(x^2 + \\frac{1}{x^2}\\right)^2 = x^4 + 2 + \\frac{1}{x^4} = 9"
            },
            {
              "m": "x^4 + \\frac{1}{x^4} = 9 - 2 = \\boxed{7}"
            }
          ]
        }
      ]
    },
