  "cq": [
    {
      "n": 1, "ch": "Algebra",
      "stem": "Given \\(a + b = 8\\) and \\(a - b = 2\\).",
      "stemBn": "দেওয়া আছে \\(a + b = 8\\) এবং \\(a - b = 2\\)।",
      "parts": [
        {
          "l": "ক", "m": 2, "q": "Find the values of \\(a\\) and \\(b\\).",
          "sol": [
            {"m": "a = \\frac{8+2}{2} = 5, \\quad b = \\frac{8-2}{2} = 3"},
            {"m": "\\boxed{a = 5, \\; b = 3}"}
          ]
        },
        {
          "l": "খ", "m": 4, "q": "Find \\(a^3 + b^3\\).",
          "sol": [
            {"m": "a^3 + b^3 = (a+b)(a^2 - ab + b^2)"},
            {"m": "ab = 5 \\times 3 = 15, \\quad a^2+b^2 = 25+9 = 34"},
            {"m": "a^3+b^3 = 8(34-15) = 8 \\times 19 = \\boxed{152}"}
          ]
        },
        {
          "l": "গ", "m": 4, "q": "Find \\(a^3 - b^3\\).",
          "sol": [
            {"m": "a^3 - b^3 = (a-b)(a^2+ab+b^2) = 2(34+15) = 2 \\times 49 = \\boxed{98}"}
          ]
        }
      ]
    },
    {
      "n": 2, "ch": "Functions",
      "stem": "\\(f(x) = 3x^2 - 2x + 1\\) and \\(g(x) = x + 2\\).",
      "stemBn": "\\(f(x) = 3x^2 - 2x + 1\\) এবং \\(g(x) = x + 2\\)।",
      "parts": [
        {
          "l": "ক", "m": 2, "q": "Find \\(f(0)\\) and \\(g(3)\\).",
          "sol": [
            {"m": "f(0) = 0 - 0 + 1 = 1, \\quad g(3) = 3 + 2 = \\boxed{5}"}
          ]
        },
        {
          "l": "খ", "m": 4, "q": "Find \\(f(g(1))\\).",
          "sol": [
            {"m": "g(1) = 1 + 2 = 3"},
            {"m": "f(g(1)) = f(3) = 3(9) - 2(3) + 1 = 27 - 6 + 1 = \\boxed{22}"}
          ]
        },
        {
          "l": "গ", "m": 4, "q": "For what value of \\(x\\) is \\(f(x) = g(x)\\)?",
          "sol": [
            {"m": "3x^2 - 2x + 1 = x + 2"},
            {"m": "3x^2 - 3x - 1 = 0"},
            {"m": "x = \\frac{3 \\pm \\sqrt{9+12}}{6} = \\frac{3 \\pm \\sqrt{21}}{6}"},
            {"m": "x \\approx \\boxed{1.26 \\text{ or } -0.26}"}
          ]
        }
      ]
    },
    {
      "n": 3, "ch": "Exponents",
      "stem": "Given \\(2^x = 8\\) and \\(3^y = 81\\).",
      "stemBn": "দেওয়া আছে \\(2^x = 8\\) এবং \\(3^y = 81\\)।",
      "parts": [
        {
          "l": "ক", "m": 2, "q": "Find \\(x\\) and \\(y\\).",
          "sol": [
            {"m": "2^x = 2^3 \\implies x = 3"},
            {"m": "3^y = 3^4 \\implies y = \\boxed{4}"}
          ]
        },
        {
          "l": "খ", "m": 4, "q": "Find \\(2^{2x} \\times 3^{y-2}\\).",
          "sol": [
            {"m": "2^{2x} = 2^6 = 64"},
            {"m": "3^{y-2} = 3^2 = 9"},
            {"m": "64 \\times 9 = \\boxed{576}"}
          ]
        },
        {
          "l": "গ", "m": 4, "q": "Show that \\(6^{x+y} = 2^x \\times 3^x \\times 6^y\\) and find its value.",
          "sol": [
            {"m": "6^{x+y} = 6^{3+4} = 6^7"},
            {"m": "2^x \\times 3^x \\times 6^y = 2^3 \\times 3^3 \\times 6^4 = 8 \\times 27 \\times 1296"},
            {"m": "= 216 \\times 1296 = 6^3 \\times 6^4 = 6^7 \\quad \\checkmark"},
            {"m": "6^7 = \\boxed{279936}"}
          ]
        }
      ]
    },
    {
      "n": 4, "ch": "Geometry",
      "stem": "In \\(\\triangle ABC\\), \\(\\angle A = 90°\\), \\(AB = 6\\) cm, \\(AC = 8\\) cm.",
