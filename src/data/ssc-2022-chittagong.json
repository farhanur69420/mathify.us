        {
          "l": "খ", "m": 4, "q": "Find the area and perimeter of \\(\\triangle ABC\\).",
          "sol": [
            {"m": "\\text{Area} = \\frac{1}{2} \\times 6 \\times 8 = \\boxed{24 \\text{ sq cm}}"},
            {"m": "\\text{Perimeter} = 6 + 8 + 10 = \\boxed{24 \\text{ cm}}"}
          ]
        },
        {
          "l": "গ", "m": 4, "q": "Find \\(\\sin B\\), \\(\\cos B\\), and \\(\\tan B\\).",
          "sol": [
            {"t": "In \\(\\triangle ABC\\), opposite to B is AC = 8, adjacent is AB = 6, hypotenuse BC = 10."},
            {"m": "\\sin B = \\frac{AC}{BC} = \\frac{8}{10} = \\frac{4}{5}"},
            {"m": "\\cos B = \\frac{AB}{BC} = \\frac{6}{10} = \\frac{3}{5}"},
            {"m": "\\tan B = \\frac{AC}{AB} = \\frac{8}{6} = \\boxed{\\frac{4}{3}}"}
          ]
        }
      ]
    },
