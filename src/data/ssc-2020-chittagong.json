  "cq": [
    {
      "n": 1, "ch": "Algebra",
      "stem": "\\(a - b = 4\\) and \\(ab = 21\\)",
      "stemBn": "\\(a - b = 4\\) এবং \\(ab = 21\\)",
      "parts": [
        {
          "l": "ক", "m": 2,
          "q": "Find \\(a^2 + b^2\\). \\(a^2 + b^2\\) নির্ণয় করো।",
          "sol": [
            {"m": "a^2 + b^2 = (a-b)^2 + 2ab = 16 + 42 = \\boxed{58}"}
          ]
        },
        {
          "l": "খ", "m": 4,
          "q": "Find \\(a + b\\) and hence the values of \\(a\\) and \\(b\\). \\(a + b\\) এবং \\(a\\), \\(b\\) নির্ণয় করো।",
          "sol": [
            {"m": "(a+b)^2 = a^2 + 2ab + b^2 = 58 + 42 = 100"},
            {"m": "a + b = 10 \\quad (\\text{taking positive root})"},
            {"m": "a = \\frac{(a+b)+(a-b)}{2} = \\frac{10+4}{2} = 7"},
            {"m": "b = \\frac{(a+b)-(a-b)}{2} = \\frac{10-4}{2} = 3"},
            {"t": "Verification: \\(7 - 3 = 4\\) and \\(7 \\times 3 = 21\\) \\(\\checkmark\\)"}
          ]
        },
        {
          "l": "গ", "m": 4,
          "q": "Find \\(a^3 - b^3\\). \\(a^3 - b^3\\) নির্ণয় করো।",
          "sol": [
            {"t": "Use: \\(a^3 - b^3 = (a-b)(a^2 + ab + b^2)\\)"},
            {"m": "= 4(58 + 21) = 4 \\times 79 = \\boxed{316}"}
          ]
        }
      ]
    },
    {
      "n": 2, "ch": "Surds",
      "stem": "\\(p = 2 + \\sqrt{3}\\)",
      "stemBn": "\\(p = 2 + \\sqrt{3}\\)",
      "parts": [
        {
          "l": "ক", "m": 2,
          "q": "Find \\(\\frac{1}{p}\\) by rationalizing. \\(\\frac{1}{p}\\) এর হর মূলদ করো।",
          "sol": [
            {"m": "\\frac{1}{2+\\sqrt{3}} \\times \\frac{2-\\sqrt{3}}{2-\\sqrt{3}} = \\frac{2-\\sqrt{3}}{4-3} = \\boxed{2 - \\sqrt{3}}"}
          ]
        },
        {
          "l": "খ", "m": 4,
          "q": "Find \\(p + \\frac{1}{p}\\) and \\(p - \\frac{1}{p}\\). \\(p + \\frac{1}{p}\\) ও \\(p - \\frac{1}{p}\\) নির্ণয় করো।",
          "sol": [
            {"m": "p + \\frac{1}{p} = (2+\\sqrt{3}) + (2-\\sqrt{3}) = \\boxed{4}"},
            {"m": "p - \\frac{1}{p} = (2+\\sqrt{3}) - (2-\\sqrt{3}) = \\boxed{2\\sqrt{3}}"}
          ]
        },
        {
          "l": "গ", "m": 4,
          "q": "Find \\(p^2 + \\frac{1}{p^2}\\). \\(p^2 + \\frac{1}{p^2}\\) নির্ণয় করো।",
          "sol": [
            {"m": "p^2 + \\frac{1}{p^2} = \\left(p + \\frac{1}{p}\\right)^2 - 2 = 16 - 2 = \\boxed{14}"}
          ]
        }
      ]
    },
    {
