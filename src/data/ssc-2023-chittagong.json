      "stem": "\\(\\sec\\theta = \\frac{5}{3}\\) where \\(\\theta\\) is an acute angle.",
      "stemBn": "\\(\\sec\\theta = \\frac{5}{3}\\) যেখানে \\(\\theta\\) সূক্ষ্মকোণ।",
      "parts": [
        {
          "l": "ক", "m": 2,
          "q": "Find \\(\\cos\\theta\\).",
          "sol": [
            {"m": "\\cos\\theta = \\frac{1}{\\sec\\theta} = \\frac{1}{5/3} = \\boxed{\\frac{3}{5}}"}
          ]
        },
        {
          "l": "খ", "m": 4,
          "q": "Find \\(\\sin\\theta\\) and \\(\\tan\\theta\\).",
          "sol": [
            {"m": "\\sin\\theta = \\sqrt{1-\\cos^2\\theta} = \\sqrt{1-\\frac{9}{25}} = \\sqrt{\\frac{16}{25}} = \\frac{4}{5}"},
            {"m": "\\tan\\theta = \\frac{\\sin\\theta}{\\cos\\theta} = \\frac{4/5}{3/5} = \\boxed{\\frac{4}{3}}"}
          ]
        },
        {
          "l": "গ", "m": 4,
          "q": "Verify that \\(\\sec^2\\theta - \\tan^2\\theta = 1\\).",
          "sol": [
            {"m": "\\sec^2\\theta = \\left(\\frac{5}{3}\\right)^2 = \\frac{25}{9}"},
            {"m": "\\tan^2\\theta = \\left(\\frac{4}{3}\\right)^2 = \\frac{16}{9}"},
            {"m": "\\sec^2\\theta-\\tan^2\\theta = \\frac{25}{9}-\\frac{16}{9} = \\frac{9}{9} = \\boxed{1} \\checkmark"}
          ]
        }
      ]
