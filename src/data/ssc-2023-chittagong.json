  "cq": [
    {
      "n": 1, "ch": "Algebra",
      "stem": "\\(p + q = 5\\) and \\(pq = 6\\)",
      "stemBn": "\\(p + q = 5\\) এবং \\(pq = 6\\)",
      "parts": [
        {
          "l": "ক", "m": 2,
          "q": "Find \\(p^2 + q^2\\).",
          "sol": [
            {"m": "p^2+q^2 = (p+q)^2-2pq = 25-12 = \\boxed{13}"}
          ]
        },
        {
          "l": "খ", "m": 4,
          "q": "Find the values of \\(p\\) and \\(q\\).",
          "sol": [
            {"m": "p-q = \\pm\\sqrt{(p+q)^2-4pq} = \\pm\\sqrt{25-24} = \\pm 1"},
            {"t": "If \\(p-q=1\\): \\(p=3, q=2\\). If \\(p-q=-1\\): \\(p=2, q=3\\)."}
          ]
        },
        {
          "l": "গ", "m": 4,
          "q": "Find \\(p^3 - q^3\\) when \\(p > q\\).",
          "sol": [
            {"m": "p^3-q^3 = (p-q)(p^2+pq+q^2)"},
            {"m": "= 1 \\times (13+6) = \\boxed{19}"}
          ]
        }
      ]
    },
    {
      "n": 2, "ch": "Surds",
      "stem": "\\(m = 2 + \\sqrt{3}\\)",
      "stemBn": "\\(m = 2 + \\sqrt{3}\\)",
      "parts": [
        {
          "l": "ক", "m": 2,
          "q": "Find \\(\\frac{1}{m}\\).",
          "sol": [
            {"m": "\\frac{1}{m} = \\frac{1}{2+\\sqrt{3}} \\times \\frac{2-\\sqrt{3}}{2-\\sqrt{3}} = \\frac{2-\\sqrt{3}}{4-3} = \\boxed{2-\\sqrt{3}}"}
          ]
        },
        {
          "l": "খ", "m": 4,
          "q": "Find \\(m^2 + \\frac{1}{m^2}\\).",
          "sol": [
            {"m": "m + \\frac{1}{m} = (2+\\sqrt{3})+(2-\\sqrt{3}) = 4"},
            {"m": "m^2+\\frac{1}{m^2} = \\left(m+\\frac{1}{m}\\right)^2-2 = 16-2 = \\boxed{14}"}
          ]
        },
        {
          "l": "গ", "m": 4,
          "q": "Find \\(m^3 + \\frac{1}{m^3}\\).",
          "sol": [
            {"t": "Use identity: \\(a^3+b^3 = (a+b)^3-3ab(a+b)\\) where \\(a=m, b=1/m\\)"},
            {"m": "m^3+\\frac{1}{m^3} = 4^3-3(1)(4) = 64-12 = \\boxed{52}"}
          ]
        }
      ]
    },
    {
      "n": 3, "ch": "Logarithms",
      "stem": "\\(\\log_2 x + \\log_4 x = 6\\)",
      "stemBn": "\\(\\log_2 x + \\log_4 x = 6\\)",
      "parts": [
        {
          "l": "ক", "m": 2,
          "q": "Express \\(\\log_4 x\\) in terms of \\(\\log_2 x\\).",
          "sol": [
            {"m": "\\log_4 x = \\frac{\\log_2 x}{\\log_2 4} = \\frac{\\log_2 x}{2}"}
          ]
        },
        {
          "l": "খ", "m": 4,
          "q": "Find \\(x\\).",
          "sol": [
            {"t": "Let \\(\\log_2 x = k\\). Then \\(k + k/2 = 6\\)"},
            {"m": "\\frac{3k}{2} = 6 \\implies k = 4"},
            {"m": "\\log_2 x = 4 \\implies x = 2^4 = \\boxed{16}"}
          ]
        },
        {
          "l": "গ", "m": 4,
          "q": "Verify your answer.",
          "sol": [
            {"m": "\\log_2 16 + \\log_4 16 = 4 + 2 = \\boxed{6} \\checkmark"}
          ]
        }
      ]
    },
