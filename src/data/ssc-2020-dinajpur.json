    {
      "n": 1, "ch": "Sets",
      "en": "If \\(A = \\{1, 2, 3, 4\\}\\) and \\(B = \\{3, 4, 5, 6\\}\\), then \\(A \\cap B = ?\\)",
      "bn": "যদি \\(A = \\{1, 2, 3, 4\\}\\) এবং \\(B = \\{3, 4, 5, 6\\}\\) হয়, তাহলে \\(A \\cap B = ?\\)",
      "opts": ["\\(\\{1, 2\\}\\)", "\\(\\{3, 4\\}\\)", "\\(\\{5, 6\\}\\)", "\\(\\{1, 2, 3, 4, 5, 6\\}\\)"],
      "ans": 1,
      "viz": "venn",
      "vizData": {"A": 4, "B": 4, "AB": 2, "total": 6},
      "sol": [
        {"t": "Intersection contains elements common to both sets."},
        {"m": "A \\cap B = \\{3, 4\\}"}
      ]
    },
    {
