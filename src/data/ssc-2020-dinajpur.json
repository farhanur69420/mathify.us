  "cq": [
    {
      "n": 1, "ch": "Algebra",
      "stem": "\\(a + b = 7\\) and \\(ab = 12\\)",
      "stemBn": "\\(a + b = 7\\) এবং \\(ab = 12\\)",
      "parts": [
        {
          "l": "ক", "m": 2,
          "q": "Find \\(a^2 + b^2\\). \\(a^2 + b^2\\) নির্ণয় করো।",
          "sol": [
            {"m": "a^2 + b^2 = (a+b)^2 - 2ab = 49 - 24 = \\boxed{25}"}
          ]
        },
        {
          "l": "খ", "m": 4,
          "q": "Find \\((a - b)^2\\) and hence the values of \\(a\\) and \\(b\\). \\((a - b)^2\\) এবং \\(a\\), \\(b\\) এর মান নির্ণয় করো।",
          "sol": [
            {"m": "(a-b)^2 = (a+b)^2 - 4ab = 49 - 48 = 1"},
            {"m": "a - b = \\pm 1"},
            {"t": "From \\(a+b=7\\) and \\(a-b=1\\): \\(a=4, b=3\\)"},
            {"t": "From \\(a+b=7\\) and \\(a-b=-1\\): \\(a=3, b=4\\)"}
          ]
        },
        {
          "l": "গ", "m": 4,
          "q": "Find \\(a^3 + b^3\\). \\(a^3 + b^3\\) নির্ণয় করো।",
          "sol": [
            {"t": "Use: \\(a^3 + b^3 = (a+b)(a^2 - ab + b^2)\\)"},
            {"m": "= 7(25 - 12) = 7 \\times 13 = \\boxed{91}"}
          ]
        }
      ]
    },
    {
      "n": 2, "ch": "Surds",
      "stem": "\\(x = \\sqrt{7} + \\sqrt{6}\\) and \\(y = \\sqrt{7} - \\sqrt{6}\\)",
      "stemBn": "\\(x = \\sqrt{7} + \\sqrt{6}\\) এবং \\(y = \\sqrt{7} - \\sqrt{6}\\)",
      "parts": [
        {
          "l": "ক", "m": 2,
          "q": "Find \\(xy\\). \\(xy\\) নির্ণয় করো।",
          "sol": [
            {"m": "xy = (\\sqrt{7}+\\sqrt{6})(\\sqrt{7}-\\sqrt{6}) = 7 - 6 = \\boxed{1}"}
          ]
        },
        {
          "l": "খ", "m": 4,
          "q": "Find \\(x^2 + y^2\\). \\(x^2 + y^2\\) নির্ণয় করো।",
          "sol": [
            {"m": "x + y = 2\\sqrt{7}"},
            {"m": "x^2 + y^2 = (x+y)^2 - 2xy = (2\\sqrt{7})^2 - 2(1) = 28 - 2 = \\boxed{26}"}
          ]
        },
        {
          "l": "গ", "m": 4,
          "q": "Find \\(\\frac{x}{y} + \\frac{y}{x}\\). \\(\\frac{x}{y} + \\frac{y}{x}\\) নির্ণয় করো।",
          "sol": [
            {"m": "\\frac{x}{y} + \\frac{y}{x} = \\frac{x^2 + y^2}{xy} = \\frac{26}{1} = \\boxed{26}"}
          ]
        }
      ]
    },
    {
      "n": 3, "ch": "Logarithms",
      "stem": "Given: \\(\\log_2 3 = p\\) and \\(\\log_2 5 = q\\)",
      "stemBn": "দেওয়া আছে: \\(\\log_2 3 = p\\) এবং \\(\\log_2 5 = q\\)",
      "parts": [
        {
          "l": "ক", "m": 2,
          "q": "Find \\(\\log_2 15\\) in terms of \\(p\\) and \\(q\\). \\(p\\) ও \\(q\\) এর মাধ্যমে \\(\\log_2 15\\) নির্ণয় করো।",
          "sol": [
            {"m": "\\log_2 15 = \\log_2 (3 \\times 5) = \\log_2 3 + \\log_2 5 = \\boxed{p + q}"}
          ]
        },
        {
          "l": "খ", "m": 4,
          "q": "Express \\(\\log_2 45\\) in terms of \\(p\\) and \\(q\\). \\(p\\) ও \\(q\\) এর মাধ্যমে \\(\\log_2 45\\) প্রকাশ করো।",
          "sol": [
            {"m": "45 = 9 \\times 5 = 3^2 \\times 5"},
            {"m": "\\log_2 45 = 2\\log_2 3 + \\log_2 5 = \\boxed{2p + q}"}
          ]
        },
        {
          "l": "গ", "m": 4,
          "q": "Find \\(\\log_2 \\frac{75}{8}\\) in terms of \\(p\\) and \\(q\\). \\(p\\) ও \\(q\\) এর মাধ্যমে \\(\\log_2 \\frac{75}{8}\\) নির্ণয় করো।",
          "sol": [
            {"m": "75 = 3 \\times 25 = 3 \\times 5^2"},
            {"m": "\\log_2 \\frac{75}{8} = \\log_2 75 - \\log_2 8 = (p + 2q) - 3 = \\boxed{p + 2q - 3}"}
          ]
        }
      ]
    },
