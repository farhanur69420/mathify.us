  "cq": [
    {
      "n": 1, "ch": "Surds",
      "stem": "\\(a = \\sqrt{5} + 1\\) and \\(b = \\sqrt{5} - 1\\)",
      "stemBn": "\\(a = \\sqrt{5} + 1\\) এবং \\(b = \\sqrt{5} - 1\\)",
      "parts": [
        {
          "l": "ক", "m": 2,
          "q": "Find \\(ab\\).",
          "sol": [
            {"m": "ab = (\\sqrt{5}+1)(\\sqrt{5}-1) = 5 - 1 = \\boxed{4}"}
          ]
        },
        {
          "l": "খ", "m": 4,
          "q": "Show that \\(a^2 + b^2 = 12\\).",
          "sol": [
            {"m": "a + b = 2\\sqrt{5},\\quad (a+b)^2 = 20"},
            {"m": "a^2 + b^2 = (a+b)^2 - 2ab = 20 - 8 = \\boxed{12} \\quad \\checkmark"}
          ]
        },
        {
          "l": "গ", "m": 4,
          "q": "Find the value of \\(\\frac{a^2 - b^2}{ab}\\).",
          "sol": [
            {"m": "a^2 - b^2 = (a+b)(a-b) = 2\\sqrt{5} \\times 2 = 4\\sqrt{5}"},
            {"m": "\\frac{a^2-b^2}{ab} = \\frac{4\\sqrt{5}}{4} = \\boxed{\\sqrt{5}}"}
          ]
        }
      ]
    },
    {
      "n": 2, "ch": "Algebra",
      "stem": "\\(x - \\frac{1}{x} = 3\\)",
      "stemBn": "\\(x - \\frac{1}{x} = 3\\)",
      "parts": [
        {
          "l": "ক", "m": 2,
          "q": "Find \\(x^2 + \\frac{1}{x^2}\\).",
          "sol": [
            {"m": "\\left(x - \\frac{1}{x}\\right)^2 = x^2 - 2 + \\frac{1}{x^2} = 9"},
            {"m": "x^2 + \\frac{1}{x^2} = 9 + 2 = \\boxed{11}"}
          ]
        },
        {
          "l": "খ", "m": 4,
          "q": "Find \\(x^4 + \\frac{1}{x^4}\\).",
          "sol": [
            {"m": "\\left(x^2 + \\frac{1}{x^2}\\right)^2 = x^4 + 2 + \\frac{1}{x^4} = 121"},
            {"m": "x^4 + \\frac{1}{x^4} = 121 - 2 = \\boxed{119}"}
          ]
        },
        {
          "l": "গ", "m": 4,
          "q": "Find \\(x^3 - \\frac{1}{x^3}\\).",
          "sol": [
            {"t": "Use identity: \\(a^3 - b^3 = (a-b)(a^2 + ab + b^2)\\) with \\(a=x, b=1/x\\)"},
            {"m": "x^3 - \\frac{1}{x^3} = \\left(x - \\frac{1}{x}\\right)\\left(x^2 + 1 + \\frac{1}{x^2}\\right)"},
            {"m": "= 3 \\times (11 + 1) = 3 \\times 12 = \\boxed{36}"}
          ]
        }
      ]
    },
    {
      "n": 3, "ch": "Logarithms",
      "stem": "\\(\\log_2 x + \\log_2 8 = 6\\)",
      "stemBn": "\\(\\log_2 x + \\log_2 8 = 6\\)",
      "parts": [
        {
          "l": "ক", "m": 2,
          "q": "Find \\(\\log_2 8\\).",
          "sol": [
            {"m": "\\log_2 8 = \\log_2 2^3 = \\boxed{3}"}
          ]
        },
        {
          "l": "খ", "m": 4,
          "q": "Find the value of \\(x\\).",
          "sol": [
            {"m": "\\log_2 x + 3 = 6 \\implies \\log_2 x = 3"},
            {"m": "x = 2^3 = \\boxed{8}"}
          ]
        },
        {
          "l": "গ", "m": 4,
          "q": "Verify that the answer is correct and find \\(\\log_4 x\\).",
          "sol": [
            {"t": "Verification: \\(\\log_2 8 + \\log_2 8 = 3 + 3 = 6\\) \\(\\checkmark\\)"},
            {"m": "\\log_4 8 = \\frac{\\log 8}{\\log 4} = \\frac{3\\log 2}{2\\log 2} = \\boxed{\\frac{3}{2}}"}
          ]
        }
      ]
    },
    {
      "n": 4, "ch": "Coordinate Geometry",
      "stem": "Points \\(P(2, 3)\\), \\(Q(6, 3)\\), \\(R(6, 6)\\)",
      "stemBn": "\\(P(2, 3)\\), \\(Q(6, 3)\\), \\(R(6, 6)\\) বিন্দুত্রয়",
      "viz": "coordplane",
      "parts": [
        {
          "l": "ক", "m": 2,
          "q": "Find the length of \\(PQ\\).",
          "sol": [
            {"m": "PQ = \\sqrt{(6-2)^2 + (3-3)^2} = \\sqrt{16} = \\boxed{4}"}
          ]
        },
        {
          "l": "খ", "m": 4,
          "q": "Find \\(QR\\) and \\(PR\\). Show that \\(\\triangle PQR\\) is a right triangle.",
          "sol": [
            {"m": "QR = \\sqrt{(6-6)^2 + (6-3)^2} = \\sqrt{9} = 3"},
            {"m": "PR = \\sqrt{(6-2)^2 + (6-3)^2} = \\sqrt{16+9} = 5"},
            {"m": "PQ^2 + QR^2 = 16 + 9 = 25 = PR^2 \\quad \\checkmark"},
            {"note": "3-4-5 Pythagorean triple. Right angle at Q."}
          ]
        },
        {
          "l": "গ", "m": 4,
          "q": "Find the area and perimeter of \\(\\triangle PQR\\).",
          "sol": [
            {"m": "\\text{Area} = \\frac{1}{2} \\times 4 \\times 3 = \\boxed{6 \\text{ sq. units}}"},
            {"m": "\\text{Perimeter} = 4 + 3 + 5 = \\boxed{12 \\text{ units}}"}
          ]
        }
      ]
    },
    {
