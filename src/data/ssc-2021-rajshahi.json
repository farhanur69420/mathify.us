          "q": "How high up the wall does the ladder reach?",
          "sol": [
            {"m": "\\sin 60° = \\frac{h}{10}"},
            {"m": "h = 10 \\sin 60° = 10 \\times \\frac{\\sqrt{3}}{2} = \\boxed{5\\sqrt{3} \\approx 8.66 \\text{ m}}"}
          ]
