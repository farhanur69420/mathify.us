  "cq": [
    {
      "n": 1,
      "ch": "Algebraic Expressions",
      "stem": "\\(a + b = 7\\) and \\(ab = 10\\)",
      "stemBn": "\\(a + b = 7\\) а¶Па¶ђа¶В \\(ab = 10\\)",
      "parts": [
        {
          "l": "а¶Х",
          "m": 2,
          "q": "Find \\(a^2 + b^2\\).",
          "sol": [
            {
              "m": "(a+b)^2 = a^2 + 2ab + b^2 = 49"
            },
            {
              "m": "a^2 + b^2 = 49 - 2(10) = \\boxed{29}"
            }
          ]
        },
        {
          "l": "а¶Ц",
          "m": 4,
          "q": "Find \\((a - b)^2\\) and hence find \\(a - b\\).",
          "sol": [
            {
              "m": "(a-b)^2 = (a+b)^2 - 4ab = 49 - 40 = 9"
            },
            {
              "m": "a - b = \\pm 3"
            },
            {
              "note": "We get two cases: \\(a-b=3\\) or \\(a-b=-3\\)."
            }
          ]
        },
        {
          "l": "а¶Ч",
