      "parts": [
        {
          "l": "ক", "m": 2,
          "q": "Express \\(\\log_2 15\\) in terms of \\(p\\) and \\(q\\).",
          "sol": [
            {"m": "\\log_2 15 = \\log_2(3 \\times 5) = \\log_2 3 + \\log_2 5 = \\boxed{p + q}"}
          ]
        },
        {
          "l": "খ", "m": 4,
          "q": "Express \\(\\log_2 45\\) in terms of \\(p\\) and \\(q\\).",
          "sol": [
            {"m": "45 = 9 \\times 5 = 3^2 \\times 5"},
            {"m": "\\log_2 45 = 2\\log_2 3 + \\log_2 5 = \\boxed{2p + q}"}
          ]
        },
        {
          "l": "গ", "m": 4,
          "q": "Express \\(\\log_2 \\frac{25}{9}\\) in terms of \\(p\\) and \\(q\\).",
          "sol": [
            {"m": "\\log_2 \\frac{25}{9} = \\log_2 25 - \\log_2 9"},
            {"m": "= \\log_2 5^2 - \\log_2 3^2 = 2\\log_2 5 - 2\\log_2 3"},
            {"m": "= \\boxed{2q - 2p}"}
          ]
        }
      ]
    },
    {
