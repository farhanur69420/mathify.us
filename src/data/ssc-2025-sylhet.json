  "cq": [
    {
      "n": 1, "ch": "Algebra",
      "stem": "\\(a + b = 7\\) and \\(ab = 10\\)",
      "stemBn": "\\(a + b = 7\\) এবং \\(ab = 10\\)",
      "parts": [
        {
          "l": "ক", "m": 2,
          "q": "Find \\(a^2 + b^2\\).",
          "sol": [
            {"m": "a^2 + b^2 = (a+b)^2 - 2ab = 49 - 20 = \\boxed{29}"}
          ]
        },
        {
          "l": "খ", "m": 4,
          "q": "Find \\((a - b)^2\\) and hence find \\(a - b\\).",
          "sol": [
            {"m": "(a-b)^2 = (a+b)^2 - 4ab = 49 - 40 = 9"},
            {"m": "a - b = \\pm\\sqrt{9} = \\boxed{\\pm 3}"}
          ]
        },
        {
          "l": "গ", "m": 4,
          "q": "Find the values of \\(a\\) and \\(b\\).",
          "sol": [
            {"t": "Case 1: \\(a - b = 3\\). Adding with \\(a + b = 7\\):"},
            {"m": "2a = 10 \\implies a = 5, \\quad b = 2"},
            {"t": "Case 2: \\(a - b = -3\\). Adding with \\(a + b = 7\\):"},
            {"m": "2a = 4 \\implies a = 2, \\quad b = 5"},
            {"m": "\\boxed{(a, b) = (5, 2) \\text{ or } (2, 5)}"}
          ]
        }
      ]
    },
    {
