          "l": "খ", "m": 4,
          "q": "Find \\(x^2 + y^2\\).",
          "sol": [
            {"m": "x + y = 2\\sqrt{7}, \\quad (x+y)^2 = 28"},
            {"m": "x^2 + y^2 = (x+y)^2 - 2xy = 28 - 4 = \\boxed{24}"}
          ]
        },
        {
          "l": "গ", "m": 4,
          "q": "Find \\(\\dfrac{x^2 + xy + y^2}{x^2 - xy + y^2}\\).",
          "sol": [
            {"m": "x^2 + xy + y^2 = 24 + 2 = 26"},
            {"m": "x^2 - xy + y^2 = 24 - 2 = 22"},
            {"m": "\\frac{26}{22} = \\boxed{\\frac{13}{11}}"}
          ]
        }
      ]
