---
export interface Props {
  title: string;
  description?: string;
  activeNav?: string;
}
const { title, description = 'Free math, physics, and civil engineering education.', activeNav = '' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Mathify</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={`https://mathify.us${Astro.url.pathname}`} />
  <meta property="og:title" content={`${title} | Mathify`} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://mathify.us/cover.png" />
  <meta name="twitter:card" content="summary_large_image" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <style is:global>
    :root {
      --bg: #0a0a0f;
      --surf: #111118;
      --surf2: #1a1a24;
      --bdr: #222233;
      --teal: #4ec9b0;
      --tdim: rgba(78,201,176,.08);
      --tline: rgba(78,201,176,.2);
      --amb: #d4a94a;
      --adim: rgba(212,169,74,.08);
      --aline: rgba(212,169,74,.2);
      --txt: #e0e4ef;
      --txt2: #a0a8be;
      --mut: #5a6070;
      --nav-bg: rgba(10,10,15,.92);
    }
    [data-theme="light"] {
      --nav-bg: rgba(245,245,250,.92);
      --bg: #f5f5fa;
      --surf: #ffffff;
      --surf2: #eeeef4;
      --bdr: #d8d8e4;
      --teal: #0d9488;
      --tdim: rgba(13,148,136,.08);
      --tline: rgba(13,148,136,.2);
      --amb: #b45309;
      --adim: rgba(180,83,9,.08);
      --aline: rgba(180,83,9,.2);
      --txt: #1a1a2e;
      --txt2: #4a4a6a;
      --mut: #7a7a9a;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--bg);
      color: var(--txt);
      font-family: 'Inter', -apple-system, sans-serif;
      font-size: 15px;
      line-height: 1.6;
      min-height: 100vh;
      transition: background .3s, color .3s;
    }
    a { color: inherit; }

    /* ── NAV ── */
    .site-nav {
      position: sticky; top: 0; z-index: 300;
      display: flex; align-items: center; gap: 2rem;
      padding: 0 2rem; height: 52px;
      background: var(--nav-bg, rgba(10,10,15,.92));
      backdrop-filter: blur(14px);
      border-bottom: 1px solid var(--bdr);
    }
    .site-nav .logo {
      font-family: 'Space Mono', monospace;
      font-weight: 700; font-size: .85rem;
      color: var(--teal); text-decoration: none;
      letter-spacing: .04em;
      margin-right: auto;
    }
    .site-nav .links { display: flex; gap: 1.5rem; list-style: none; }
    .site-nav .links a {
      font-size: .72rem; font-weight: 500;
      letter-spacing: .06em; text-transform: uppercase;
      color: var(--mut); text-decoration: none;
      transition: color .2s;
    }
    .site-nav .links a:hover,
    .site-nav .links a.active { color: var(--teal); }

    /* ── FOOTER ── */
    .site-footer {
      position: relative;
      border-top: 1px solid var(--bdr);
      padding: 2rem;
      text-align: center;
      font-size: .72rem;
      color: var(--mut);
      letter-spacing: .04em;
    }
    .site-footer a { color: var(--teal); text-decoration: none; }
    .visitor-count {
      display: inline-flex; align-items: center; gap: .4rem;
      margin-top: .6rem; font-size: .65rem;
      color: var(--mut);
    }
    .visitor-dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: #4ade80;
      animation: blink 2s ease-in-out infinite;
    }
    @keyframes blink { 0%,100%{opacity:1;} 50%{opacity:.3;} }

    /* ── THEME TOGGLE ── */
    .theme-toggle {
      width: 32px; height: 32px; border-radius: 50%;
      background: var(--surf2); border: 1px solid var(--bdr);
      color: var(--txt); cursor: pointer; font-size: .9rem;
      display: flex; align-items: center; justify-content: center;
      transition: border-color .2s, transform .2s;
    }
    .theme-toggle:hover { border-color: var(--teal); transform: rotate(20deg) scale(1.1); }

    /* ── MOBILE ── */
    .mobile-toggle { display: none; background: none; border: none; color: var(--txt); font-size: 1.3rem; cursor: pointer; }
    @media (max-width: 700px) {
      .site-nav { padding: 0 1rem; }
      .mobile-toggle { display: block; }
      .site-nav .links {
        display: none; position: absolute; top: 52px; left: 0; right: 0;
        flex-direction: column; gap: 0;
        background: rgba(10,10,15,.98); border-bottom: 1px solid var(--bdr);
      }
      .site-nav .links.open { display: flex; }
      .site-nav .links a { padding: .8rem 2rem; display: block; }
    }
  </style>
</head>
<body>
  <nav class="site-nav">
    <a href="/" class="logo">mathify</a>
    <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme"></button>
    <button class="mobile-toggle" id="menuBtn" aria-label="Menu">&#9776;</button>
    <ul class="links" id="navLinks">
      <li><a href="/math" class={activeNav === 'math' ? 'active' : ''}>Math</a></li>
      <li><a href="/physics" class={activeNav === 'physics' ? 'active' : ''}>Physics</a></li>
      <li><a href="/civil" class={activeNav === 'civil' ? 'active' : ''}>Civil</a></li>
      <li><a href="/ssc" class={activeNav === 'ssc' ? 'active' : ''}>SSC</a></li>
      <li><a href="/shop" class={activeNav === 'shop' ? 'active' : ''}>Shop</a></li>
      <li><a href="/explore" class={activeNav === 'explore' ? 'active' : ''}>Explore</a></li>
    </ul>
  </nav>

  <slot />

  <footer class="site-footer">
    <p><a href="/">mathify.us</a> &middot; Free education for everyone</p>
    <div class="visitor-count">
      <span class="visitor-dot"></span>
      <span id="visitorCount">—</span> visitors today
    </div>
  </footer>

  <script is:inline>
    // Theme toggle
    const root = document.documentElement;
    const tBtn = document.getElementById('themeToggle');
    function setTheme(t) {
      root.setAttribute('data-theme', t);
      tBtn.textContent = t === 'dark' ? '\u2600\uFE0F' : '\uD83C\uDF19';
      localStorage.setItem('mathify-theme', t);
    }
    const saved = localStorage.getItem('mathify-theme');
    setTheme(saved || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light'));
    tBtn.addEventListener('click', () => {
      setTheme(root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark');
    });

    // Mobile menu
    document.getElementById('menuBtn')?.addEventListener('click', () => {
      document.getElementById('navLinks')?.classList.toggle('open');
    });

    // Visitor counter using CountAPI
    (async () => {
      try {
        const r = await fetch('https://api.countapi.xyz/hit/mathify.us/visits');
        const d = await r.json();
        const el = document.getElementById('visitorCount');
        if (el && d.value) el.textContent = d.value.toLocaleString();
      } catch {}
    })();
  </script>
</body>
</html>
