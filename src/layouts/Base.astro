---
export interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Free, intuition-first math and engineering education.' } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Mathify</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&family=Playfair+Display:ital,wght@0,700;0,900&family=Noto+Sans+Bengali:wght@400;600;700&display=swap" rel="stylesheet" />
  <!-- MathJax -->
  <script is:inline>
    window.MathJax = {
      tex: {
        inlineMath: [['\\(','\\)']],
        displayMath: [['\\[','\\]']],
        tags: 'ams'
      },
      options: { skipHtmlTags: ['script','noscript','style','textarea'] }
    };
  </script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/mathjax/3.2.2/es5/tex-chtml.min.js" defer></script>
  <style is:global>
    :root {
      --bg:      #0d0f14;
      --surf:    #13161e;
      --surf2:   #1a1e2a;
      --surf3:   #1e2435;
      --bdr:     #252a38;
      --bdr2:    #2e3548;
      --teal:    #4ec9b0;
      --tdim:    rgba(78,201,176,.10);
      --tline:   rgba(78,201,176,.22);
      --amb:     #d4a94a;
      --adim:    rgba(212,169,74,.10);
      --aline:   rgba(212,169,74,.22);
      --rust:    #c25a3b;
      --rdim:    rgba(194,90,59,.10);
      --vio:     #9b7fe8;
      --vdim:    rgba(155,127,232,.10);
      --vline:   rgba(155,127,232,.22);
      --grn:     #5cb85c;
      --gdim:    rgba(92,184,92,.10);
      --gline:   rgba(92,184,92,.22);
      --blu:     #6ab0e0;
      --bdim:    rgba(106,176,224,.10);
      --txt:     #e0e4ef;
      --txt2:    #c8cede;
      --mut:     #6b7280;
      --fnt:     #1e2330;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--bg);
      color: var(--txt);
      font-family: 'Space Mono', monospace;
      font-size: 13.5px;
      overflow-x: hidden;
      min-height: 100vh;
    }
    body::before {
      content: '';
      position: fixed; inset: 0;
      background-image:
        linear-gradient(var(--fnt) 1px, transparent 1px),
        linear-gradient(90deg, var(--fnt) 1px, transparent 1px);
      background-size: 40px 40px;
      opacity: .22;
      pointer-events: none;
      z-index: 0;
    }
    .bn { font-family: 'Noto Sans Bengali', sans-serif !important; }

    /* ── NAV ── */
    nav {
      position: sticky; top: 0; z-index: 300;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 1.5rem; height: 54px;
      background: rgba(13,15,20,.95);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--bdr);
    }
    .nav-logo {
      text-decoration: none; color: var(--teal);
      font-weight: 700; font-size: .9rem; letter-spacing: .06em;
    }
    .nav-links { display: flex; gap: 1.4rem; list-style: none; }
    .nav-links a {
      color: var(--mut); text-decoration: none;
      font-size: .68rem; letter-spacing: .08em; text-transform: uppercase;
      transition: color .2s;
    }
    .nav-links a:hover { color: var(--teal); }
    .nav-tag {
      font-size: .6rem; letter-spacing: .12em; text-transform: uppercase;
      color: var(--amb); background: var(--adim);
      border: 1px solid var(--aline);
      padding: .2rem .6rem; border-radius: 2px;
    }

    /* ── UTILITY ── */
    .z1 { position: relative; z-index: 1; }
    .mblk {
      font-family: 'Space Mono', monospace;
      background: var(--surf2);
      border: 1px solid rgba(78,201,176,.14);
      border-left: 3px solid var(--teal);
      padding: .55rem .9rem; border-radius: 3px;
      font-size: .8rem; color: var(--teal);
      margin: .35rem 0; overflow-x: auto; display: block;
    }
    code {
      font-family: 'Space Mono', monospace;
      background: var(--surf2);
      color: var(--teal);
      padding: 0.2rem 0.5rem;
      border-radius: 3px;
      font-size: 0.9em;
      border: 1px solid var(--bdr2);
    }
    pre {
      background: var(--surf2);
      border: 1px solid var(--bdr);
      border-left: 3px solid var(--teal);
      padding: 1rem;
      border-radius: 4px;
      overflow-x: auto;
      margin: 0.5rem 0;
      font-family: 'Space Mono', monospace;
    }
    pre code {
      background: none;
      border: none;
      padding: 0;
      color: var(--txt);
    }
    .nbox {
      font-size: .72rem; color: var(--amb);
      background: var(--adim);
      border: 1px solid var(--aline);
      border-left: 3px solid var(--amb);
      padding: .4rem .7rem; border-radius: 3px;
      margin-top: .5rem; line-height: 1.7;
    }
    footer {
      position: relative; z-index: 1;
      border-top: 1px solid var(--bdr);
      padding: 1.5rem 2rem; text-align: center;
      font-size: .68rem; color: var(--mut); letter-spacing: .06em;
    }
    footer a { color: var(--teal); text-decoration: none; }
  </style>
</head>
<body>
  <nav>
    <a href="/" class="nav-logo">mathify.us</a>
    <ul class="nav-links">
      <li><a href="/civil">Civil Engineering</a></li>
      <li><a href="/math">Mathematics</a></li>
      <li><a href="/physics">Physics</a></li>
      <li><a href="/about">About</a></li>
    </ul>
  </nav>

  <slot />

  <footer>
    <p>
      <a href="/">mathify.us</a> · Free, open educational resources ·
      <a href="mailto:hello@mathify.us">hello@mathify.us</a>
    </p>
  </footer>
</body>
</html>
