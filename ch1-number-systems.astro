/* ════════════════════════════════════════
   HELPERS
════════════════════════════════════════ */
const dark = true;
const BG2  = '#1a1a24';
const BP   = '#4ec9b0';
const AM   = '#d4a94a';
const RUST = '#c0392b';
const T2   = '#8888a8';
const T3   = '#44445a';
const TEXT = '#e2e2ee';

function typeset(el) {
  if (window.MathJax && MathJax.typesetPromise) {
    MathJax.typesetPromise([el]);
  }
}
function fmt(v) {
  if (!isFinite(v)) return '∞';
  if (Math.abs(v) > 1e12) return v.toExponential(3);
  if (Number.isInteger(v)) return String(v);
  return parseFloat(v.toFixed(6)).toString();
}

/* ════════════════════════════════════════
   SECTION 1 — VENN DIAGRAM
════════════════════════════════════════ */
let vennMode = 'all';

const VENN_SETS = {
  R: { label:'ℝ Real',      color:'#7060ff', desc:'All numbers — rational and irrational alike. Every point on the number line.', examples:'√2, π, e, 3/5, −7, 0, 42' },
  Q: { label:'ℚ Rational',  color: BP,       desc:'Any number p/q with integers p,q and q≠0. Decimal terminates or repeats.', examples:'1/2, −3/4, 0.25, 0.333̄, 7, −5' },
  Z: { label:'ℤ Integer',   color: AM,       desc:'All whole numbers, positive and negative, including zero.', examples:'…,−3,−2,−1, 0, 1, 2, 3,…' },
  W: { label:'𝕎 Whole',     color:'#ff6a9a', desc:'Non-negative integers. Like integers but without negatives.', examples:'0, 1, 2, 3, 4, …' },
  N: { label:'ℕ Natural',   color:'#ffd75a', desc:'Counting numbers — the first numbers humans ever used.', examples:'1, 2, 3, 4, 5, …' },
};

function vennHighlight(mode, btn) {
  vennMode = mode;
  document.querySelectorAll('.ctrl-btn').forEach(b => b.classList.remove('active'));
  if (btn) btn.classList.add('active');
  drawVenn();
  const s = VENN_SETS[mode];
  const info = document.getElementById('venn-info');
  if (mode === 'all') {
    info.innerHTML = 'All five number sets shown. Click any button to highlight one.';
  } else {
    info.innerHTML = `<strong style="color:${s.color}">${s.label}</strong> — ${s.desc}<br><span style="font-family:'Space Mono',monospace;font-size:12px;color:${T3}">Examples: ${s.examples}</span>`;
  }
}

function drawVenn() {
  const canvas = document.getElementById('vennCanvas');
  if (!canvas) return;
  const W = canvas.width, H = canvas.height;
  const ctx = canvas.getContext('2d');
  ctx.clearRect(0,0,W,H);

  // Ellipses (cx,cy,rx,ry,label,key,color)
  const rings = [
    { cx:W/2, cy:H/2, rx:W/2-10, ry:H/2-12, key:'R', color:'#7060ff' },
    { cx:W/2+8, cy:H/2+6, rx:W*0.37, ry:H/2-36, key:'Q', color:BP },
    { cx:W/2+16, cy:H/2+14, rx:W*0.25, ry:H/2-66, key:'Z', color:AM },
    { cx:W/2+20, cy:H/2+20, rx:W*0.155, ry:H/2-96, key:'W', color:'#ff6a9a' },
    { cx:W/2+24, cy:H/2+28, rx:W*0.08, ry:H/2-122, key:'N', color:'#ffd75a' },
  ];

  rings.forEach(r => {
    const alpha = (vennMode === 'all' || vennMode === r.key) ? 0.18 : 0.05;
    const strokeAlpha = (vennMode === 'all' || vennMode === r.key) ? 0.9 : 0.15;
    ctx.beginPath();
    ctx.ellipse(r.cx, r.cy, r.rx, r.ry, 0, 0, Math.PI*2);
    ctx.fillStyle = r.color.replace(')',`,${alpha})`).replace('rgb(','rgba(');
    // Use hex → fill with alpha trick
    ctx.globalAlpha = alpha;
    ctx.fillStyle = r.color;
    ctx.fill();
    ctx.globalAlpha = strokeAlpha;
    ctx.strokeStyle = r.color;
    ctx.lineWidth = vennMode === r.key ? 2.5 : 1.2;
    ctx.stroke();
    ctx.globalAlpha = 1;
  });

  // Labels
  const labelPos = [
    { key:'R', x:30, y:32,  color:'#7060ff', txt:'ℝ' },
    { key:'Q', x:80, y:54,  color:BP,        txt:'ℚ' },
    { key:'Z', x:140, y:80, color:AM,        txt:'ℤ' },
    { key:'W', x:200, y:105,color:'#ff6a9a', txt:'𝕎' },
    { key:'N', x:W/2+20, y:H/2+26, color:'#ffd75a', txt:'ℕ' },
  ];
  ctx.font = 'bold 13px "Space Mono",monospace';
  labelPos.forEach(l => {
    ctx.globalAlpha = (vennMode==='all'||vennMode===l.key) ? 1 : 0.2;
    ctx.fillStyle = l.color;
    ctx.fillText(l.txt, l.x, l.y);
  });
  ctx.globalAlpha = 1;

  // Sample numbers scattered
  const nums = [
    { txt:'1,2,3…', x:W/2+22, y:H/2+28, color:'#ffd75a' },
    { txt:'0',       x:W/2+14, y:H/2+48, color:'#ff6a9a' },
    { txt:'−3,−7',   x:W/2-12, y:H/2+30, color:AM },
    { txt:'½, 0.3̄',  x:W/2-60, y:H/2+20, color:BP },
    { txt:'√2, π',   x:62,     y:H/2+5,  color:'#9090c0' },
  ];
  ctx.font = '10px "Space Mono",monospace';
  nums.forEach(n => {
    const relevantKey = n.color === '#ffd75a' ? 'N' : n.color === '#ff6a9a' ? 'W' : n.color === AM ? 'Z' : n.color === BP ? 'Q' : 'R';
    const isHighlighted = vennMode==='all' || vennMode===relevantKey;
    ctx.globalAlpha = isHighlighted ? 0.75 : 0.1;
    ctx.fillStyle = n.color;
    ctx.fillText(n.txt, n.x, n.y);
  });
  ctx.globalAlpha = 1;
}

document.addEventListener('DOMContentLoaded', () => {
  drawVenn();
  document.getElementById('venn-all-btn')?.classList.add('active');
});


/* ════════════════════════════════════════
   SECTION 1 — NUMBER CLASSIFIER
════════════════════════════════════════ */
function classifyNum() {
  const raw = document.getElementById('cls-inp').value.trim();
  const el = document.getElementById('cls-out');
  if (!raw) { el.innerHTML = 'Enter a number to classify.'; return; }

  // Parse
  let val = NaN;
  if (/^-?\d+$/.test(raw)) val = parseInt(raw);
  else if (/^-?\d*\.?\d+$/.test(raw)) val = parseFloat(raw);
  else if (/^-?\d+\/\d+$/.test(raw)) {
    const [p,q] = raw.split('/').map(Number);
    val = p/q;
  }

  const isNat = Number.isInteger(val) && val > 0;
  const isWhole = Number.isInteger(val) && val >= 0;
  const isInt = Number.isInteger(val);
  const isRat = isFinite(val) && !isNaN(val);
  // For √n notation
  let isSqrt = false;
  const sqrtMatch = raw.match(/^√(\d+)$/);
  if (sqrtMatch) {
    const n = parseInt(sqrtMatch[1]);
    const sq = Math.sqrt(n);
    const isPerfect = Number.isInteger(sq);
    val = sq;
    isSqrt = !isPerfect;
  }

  if (isNaN(val) && !sqrtMatch) {
    el.innerHTML = `<span style="color:${RUST}">Could not parse "${raw}" — try integers, decimals, fractions like 3/7, or √n notation.</span>`;
    return;
  }

  const sets = [];
  if (!isSqrt) {
    if (isNat)   sets.push(`<span style="color:#ffd75a">ℕ Natural</span>`);
    if (isWhole) sets.push(`<span style="color:#ff6a9a">𝕎 Whole</span>`);
    if (isInt)   sets.push(`<span style="color:${AM}">ℤ Integer</span>`);
    if (isRat)   sets.push(`<span style="color:${BP}">ℚ Rational</span>`);
    if (isRat)   sets.push(`<span style="color:#7060ff">ℝ Real</span>`);
  } else {
    sets.push(`<span style="color:#9090c0">Irrational</span>`);
    sets.push(`<span style="color:#7060ff">ℝ Real</span>`);
  }

  el.innerHTML = `<strong style="color:${TEXT}">${raw}</strong> ∈ ${sets.join(', ')}`;
  typeset(el);
}


/* ════════════════════════════════════════
   SECTION 2 — DENSITY CANVAS
════════════════════════════════════════ */
let densityLo = 0, densityHi = 1, densityZoom = 1;

function drawDensity() {
  const canvas = document.getElementById('densityCanvas');
  if (!canvas) return;
  const W = canvas.width, H = canvas.height;
  const ctx = canvas.getContext('2d');
  ctx.clearRect(0,0,W,H);
  const PAD = 50;
  const lineY = H/2;

  // Axis line
  ctx.strokeStyle = T3;
  ctx.lineWidth = 1;
  ctx.beginPath();
  ctx.moveTo(PAD, lineY); ctx.lineTo(W-PAD, lineY);
  ctx.stroke();

  // Ticks between lo and hi
  const range = densityHi - densityLo;
  const step = range / 8;
  ctx.font = '10px "Space Mono",monospace';
  ctx.textAlign = 'center';
  for (let i=0; i<=8; i++) {
    const v = densityLo + i*step;
    const x = PAD + (i/8)*(W-2*PAD);
    ctx.strokeStyle = BP;
    ctx.lineWidth = 1.5;
    ctx.beginPath();
    ctx.moveTo(x, lineY-7); ctx.lineTo(x, lineY+7);
    ctx.stroke();
    ctx.fillStyle = i===0||i===8 ? AM : BP;
    ctx.fillText(v.toFixed(4), x, lineY+20);
  }

  // Mid-point highlight
  const mid = (densityLo+densityHi)/2;
  const midX = PAD + 0.5*(W-2*PAD);
  ctx.fillStyle = RUST;
  ctx.beginPath();
  ctx.arc(midX, lineY, 5, 0, Math.PI*2);
  ctx.fill();
  ctx.fillStyle = RUST;
  ctx.font = 'bold 10px "Space Mono",monospace';
  ctx.fillText(`mid = ${mid.toFixed(6)}`, midX, lineY-14);

  // Endpoints
  [0,8].forEach(i => {
    const x = PAD + (i/8)*(W-2*PAD);
    const v = i===0 ? densityLo : densityHi;
    ctx.fillStyle = AM;
    ctx.beginPath(); ctx.arc(x, lineY, 5, 0, Math.PI*2); ctx.fill();
  });

  document.getElementById('density-info').textContent =
    `Showing rationals between ${densityLo.toFixed(6)} and ${densityHi.toFixed(6)} (zoom: ${densityZoom}×)`;
}

function densityZoomIn() {
  const mid = (densityLo+densityHi)/2;
  const half = (densityHi-densityLo)/4;
  densityLo = mid - half;
  densityHi = mid + half;
  densityZoom *= 2;
  drawDensity();
}
function densityReset() { densityLo=0; densityHi=1; densityZoom=1; drawDensity(); }


/* ════════════════════════════════════════
   SECTION 2 — RATIONAL FINDER CALCULATOR
════════════════════════════════════════ */
function findRationals() {
  const a = parseFloat(document.getElementById('rat-a1').value);
  const b = parseFloat(document.getElementById('rat-b1').value);
  const n = Math.min(20, Math.max(1, parseInt(document.getElementById('rat-n1').value)||6));
  const el = document.getElementById('rat-out1');

  if (isNaN(a)||isNaN(b)||a>=b) {
    el.innerHTML = '<span style="color:'+RUST+'">Please enter valid numbers with a < b.</span>';
    return;
  }

  // Convert to fractions with denominator n+1
  const d = n+1;
  // Scale a and b
  const lo = Math.ceil(a * d);
  const hi = Math.floor(b * d);
  const fracs = [];
  for (let num = lo; num <= hi && fracs.length < n; num++) {
    if (num/d > a && num/d < b) fracs.push(`${num}/${d}`);
  }

  if (fracs.length === 0) {
    // Fallback to averaging
    const results = [];
    let lo2 = a, hi2 = b;
    for (let i=0; i<n; i++) {
      const m = (lo2+hi2)/2;
      results.push(m.toFixed(6));
      lo2 = m;
    }
    el.innerHTML = `<strong>${n} rationals between ${a} and ${b}:</strong><br><span style="color:${BP};font-family:'Space Mono',monospace;">${results.join(',  ')}</span><br><span style="color:${T3};font-size:12px;">(averaging method)</span>`;
  } else {
    el.innerHTML = `<strong>${fracs.length} rationals between ${a} and ${b}</strong> (denom = ${d}):<br><span style="color:${BP};font-family:'Space Mono',monospace;">${fracs.join(',  ')}</span><br><span style="color:${T3};font-size:12px;">There are infinitely more — these are just ${fracs.length} of them.</span>`;
  }
}


/* ════════════════════════════════════════
   SECTION 3 — √2 GEOMETRIC CONSTRUCTION
════════════════════════════════════════ */
let sqrt2Step = 0, sqrt2Timer = null;

function sqrt2Reset() {
  clearTimeout(sqrt2Timer);
  sqrt2Timer = null;
  sqrt2Step = 0;
  drawSqrt2(0);
  document.getElementById('sqrt2-info').textContent = 'Press Animate to see the construction unfold step by step.';
}

function sqrt2Animate() {
  clearTimeout(sqrt2Timer);
  sqrt2Step = 0;
  const steps = [
    'Step 1: Draw number line. Mark O (origin) and A at position 1.',
    'Step 2: At A, erect a perpendicular segment AB of length 1 unit.',
    'Step 3: By Pythagoras, OB² = OA² + AB² = 1 + 1 = 2 → OB = √2.',
    'Step 4: With compass at O, arc of radius OB cuts the number line at C = √2 ≈ 1.414…',
    'Done! C is the exact location of √2 on the number line.'
  ];
  function tick() {
    sqrt2Step++;
    drawSqrt2(sqrt2Step);
    document.getElementById('sqrt2-info').textContent = steps[Math.min(sqrt2Step-1, steps.length-1)];
    if (sqrt2Step < 5) sqrt2Timer = setTimeout(tick, 900);
  }
  tick();
}

function drawSqrt2(step) {
  const canvas = document.getElementById('sqrt2Canvas');
  if (!canvas) return;
  const W = canvas.width, H = canvas.height;
  const ctx = canvas.getContext('2d');
  ctx.clearRect(0,0,W,H);

  const scale = 80;
  const ox = 100, oy = H-60;

  // Number line
  ctx.strokeStyle = T3; ctx.lineWidth = 1;
  ctx.beginPath(); ctx.moveTo(30, oy); ctx.lineTo(W-30, oy); ctx.stroke();

  // Axis labels
  ctx.font = '11px "Space Mono",monospace';
  ctx.fillStyle = T2; ctx.textAlign = 'center';
  for (let i=0; i<=5; i++) {
    const x = ox + i*scale;
    ctx.fillStyle = T3; ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(x, oy-5); ctx.lineTo(x, oy+5); ctx.stroke();
    ctx.fillStyle = T2; ctx.fillText(String(i), x, oy+18);
  }

  if (step < 1) return;

  // Step 1: Mark O and A
  ctx.fillStyle = BP;
  ctx.beginPath(); ctx.arc(ox, oy, 4, 0, Math.PI*2); ctx.fill();
  ctx.fillText('O', ox, oy-10);
  ctx.beginPath(); ctx.arc(ox+scale, oy, 4, 0, Math.PI*2); ctx.fill();
  ctx.fillText('A', ox+scale, oy-10);

  if (step < 2) return;

  // Step 2: Perpendicular AB
  ctx.strokeStyle = AM; ctx.lineWidth = 2;
  ctx.beginPath(); ctx.moveTo(ox+scale, oy); ctx.lineTo(ox+scale, oy-scale); ctx.stroke();
  ctx.fillStyle = AM;
  ctx.beginPath(); ctx.arc(ox+scale, oy-scale, 4, 0, Math.PI*2); ctx.fill();
  ctx.fillText('B', ox+scale+12, oy-scale);
  // Right angle symbol
  ctx.strokeStyle = T3; ctx.lineWidth = 1;
  const ra = 8;
  ctx.strokeRect(ox+scale, oy-ra, -ra, ra);
  // Labels
  ctx.fillStyle = T3; ctx.font = '10px "Space Mono",monospace';
  ctx.fillText('1', ox+scale+14, oy-scale/2);
  ctx.fillText('1', ox+scale/2, oy+15);

  if (step < 3) return;

  // Step 3: Hypotenuse OB
  const bx = ox+scale, by = oy-scale;
  ctx.strokeStyle = BP; ctx.lineWidth = 2.5;
  ctx.beginPath(); ctx.moveTo(ox, oy); ctx.lineTo(bx, by); ctx.stroke();
  ctx.fillStyle = BP; ctx.font = 'bold 11px "Space Mono",monospace';
  ctx.fillText('√2', (ox+bx)/2-18, (oy+by)/2-6);

  if (step < 4) return;

  // Step 4: Arc and C
  const sqrt2 = Math.SQRT2;
  const cx2 = ox + sqrt2*scale;
  ctx.strokeStyle = RUST; ctx.lineWidth = 1.5; ctx.setLineDash([4,3]);
  ctx.beginPath(); ctx.arc(ox, oy, sqrt2*scale, -Math.PI/2, 0); ctx.stroke();
  ctx.setLineDash([]);
  ctx.fillStyle = RUST;
  ctx.beginPath(); ctx.arc(cx2, oy, 5, 0, Math.PI*2); ctx.fill();
  ctx.fillStyle = RUST; ctx.font = 'bold 11px "Space Mono",monospace';
  ctx.fillText(`C = √2`, cx2, oy-12);

  // Dashed drop from C to number line label
  ctx.strokeStyle = T3; ctx.lineWidth = 1; ctx.setLineDash([3,3]);
  ctx.beginPath(); ctx.moveTo(cx2, oy-8); ctx.lineTo(cx2, oy+20); ctx.stroke();
  ctx.setLineDash([]);
  ctx.fillStyle = T3; ctx.font = '10px "Space Mono",monospace';
  ctx.fillText('≈1.414', cx2, oy+30);
}


/* ════════════════════════════════════════
   SECTION 3 — SURD SIMPLIFIER
════════════════════════════════════════ */
function simplifySurd() {
  const n = Math.abs(parseInt(document.getElementById('surd-n').value)||1);
  let outside=1, inside=n;
  for (let i=Math.floor(Math.sqrt(n)); i>=2; i--) {
    if (inside % (i*i) === 0) {
      outside *= i; inside /= (i*i);
      for (let j=Math.floor(Math.sqrt(inside)); j>=2; j--) {
        if (inside % (j*j) === 0) { outside*=j; inside/=(j*j); }
      }
      break;
    }
  }
  const el = document.getElementById('surd-out');
  if (inside===1) {
    el.innerHTML = `\\(\\sqrt{${n}} = ${outside}\\) &nbsp;&mdash;&nbsp; <strong style="color:${BP}">Perfect square — rational!</strong>`;
  } else if (outside===1) {
    el.innerHTML = `\\(\\sqrt{${n}}\\) is already fully simplified \\(\\approx ${Math.sqrt(n).toFixed(6)}\\) &nbsp;&mdash;&nbsp; <span style="color:${AM}">Irrational</span>`;
  } else {
    el.innerHTML = `\\(\\sqrt{${n}} = \\sqrt{${outside*outside} \\times ${inside}} = ${outside}\\sqrt{${inside}} \\approx ${(outside*Math.sqrt(inside)).toFixed(6)}\\) &nbsp;&mdash;&nbsp; <span style="color:${AM}">Irrational</span>`;
  }
  typeset(el);
}


/* ════════════════════════════════════════
   SECTION 4 — SPIRAL OF THEODORUS
════════════════════════════════════════ */
let spiralN = 6, spiralAnimTimer = null;
const spiralColors = ['#4ec9b0','#5dd9c0','#6ae8cc','#d4a94a','#ddb85a','#e6c870','#7c6aff','#9280ff','#a896ff','#c0392b','#cc4d41','#d86254','#ff6a9a','#ff80aa'];

function drawSpiral() {
  const canvas = document.getElementById('spiralCanvas');
  if (!canvas) return;
  const W = canvas.width, H = canvas.height;
  const ctx = canvas.getContext('2d');
  ctx.clearRect(0,0,W,H);

  const scale = Math.min(W,H)*0.13;
  const cx = W/2-20, cy = H/2+20;

  ctx.fillStyle = BP;
  ctx.beginPath(); ctx.arc(cx,cy,3,0,Math.PI*2); ctx.fill();

  let angle = 0;
  let endX = cx+scale, endY = cy;

  for (let n=1; n<=spiralN; n++) {
    const perpAngle = angle - Math.PI/2;
    const rightX = endX + Math.cos(perpAngle)*scale;
    const rightY = endY + Math.sin(perpAngle)*scale;
    const col = spiralColors[(n-1) % spiralColors.length];

    // Leg from end to right-angle vertex
    ctx.strokeStyle = '#22223a'; ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(endX,endY); ctx.lineTo(rightX,rightY); ctx.stroke();

    // Hypotenuse
    ctx.strokeStyle = col; ctx.lineWidth = 2;
    ctx.beginPath(); ctx.moveTo(cx,cy); ctx.lineTo(rightX,rightY); ctx.stroke();

    // Right-angle symbol
    const ra=6;
    const ux=(endX-rightX)/Math.hypot(endX-rightX,endY-rightY)*ra;
    const uy=(endY-rightY)/Math.hypot(endX-rightX,endY-rightY)*ra;
    const ox2=(cx-rightX)/Math.hypot(cx-rightX,cy-rightY)*ra;
    const oy2=(cy-rightY)/Math.hypot(cx-rightX,cy-rightY)*ra;
    ctx.strokeStyle='#2e2e40'; ctx.lineWidth=1;
    ctx.beginPath();
    ctx.moveTo(rightX+ux,rightY+uy);
    ctx.lineTo(rightX+ux+ox2,rightY+uy+oy2);
    ctx.lineTo(rightX+ox2,rightY+oy2);
    ctx.stroke();

    // Hyp label
    const labX=(cx+rightX)/2+Math.cos(angle-Math.PI/2)*13;
    const labY=(cy+rightY)/2+Math.sin(angle-Math.PI/2)*13;
    ctx.fillStyle=col; ctx.font='10px "Space Mono",monospace'; ctx.textAlign='center';
    ctx.fillText(`√${n+1}`, labX, labY);

    angle = Math.atan2(rightY-cy, rightX-cx);
    endX=rightX; endY=rightY;
  }

  const lbl = document.getElementById('spiral-label');
  if (lbl) lbl.textContent = `n = ${spiralN}  (up to √${spiralN+1})`;
}

function spiralStep(d) {
  spiralN = Math.max(1, Math.min(14, spiralN+d));
  clearTimeout(spiralAnimTimer);
  drawSpiral();
}
function spiralAnimate() {
  clearTimeout(spiralAnimTimer);
  spiralN=1;
  function tick() {
    drawSpiral();
    if (spiralN<14) { spiralN++; spiralAnimTimer=setTimeout(tick,280); }
  }
  tick();
}


/* ════════════════════════════════════════
   SECTION 4 — LOCATE √n CALCULATOR
════════════════════════════════════════ */
function locateSqrt() {
  const n = parseInt(document.getElementById('sqrt-n').value)||7;
  const sq = Math.sqrt(n);
  const isPerfect = Number.isInteger(sq);
  const el = document.getElementById('sqrt-out');
  const lineC = document.getElementById('sqrtLineCanvas');

  el.innerHTML = isPerfect
    ? `\\(\\sqrt{${n}} = ${sq}\\) &nbsp;&mdash;&nbsp; <strong style="color:${BP}">Rational (perfect square)</strong>`
    : `\\(\\sqrt{${n}} \\approx ${sq.toFixed(8)}\ldots\\) &nbsp;&mdash;&nbsp; <span style="color:${AM}">Irrational — non-terminating, non-repeating</span><br>
       It lies between \\(${Math.floor(sq)}\\) and \\(${Math.ceil(sq)}\\) on the number line.`;
  typeset(el);

  // Draw mini number line
  lineC.style.display='block';
  const W=lineC.width, H=lineC.height;
  const ctx=lineC.getContext('2d');
  ctx.clearRect(0,0,W,H);
  const lo=Math.max(0,Math.floor(sq)-1), hi=Math.ceil(sq)+1;
  const toX=v=>50+(v-lo)/(hi-lo)*(W-100);
  ctx.strokeStyle=T3; ctx.lineWidth=1;
  ctx.beginPath(); ctx.moveTo(30,H/2); ctx.lineTo(W-30,H/2); ctx.stroke();
  for (let i=lo; i<=hi; i++) {
    const x=toX(i);
    ctx.strokeStyle=BP; ctx.lineWidth=1.5;
    ctx.beginPath(); ctx.moveTo(x,H/2-6); ctx.lineTo(x,H/2+6); ctx.stroke();
    ctx.fillStyle=T2; ctx.font='10px "Space Mono",monospace'; ctx.textAlign='center';
    ctx.fillText(String(i),x,H/2+18);
  }
  const cx=toX(sq);
  ctx.fillStyle=isPerfect?BP:AM;
  ctx.beginPath(); ctx.arc(cx,H/2,6,0,Math.PI*2); ctx.fill();
  ctx.fillStyle=isPerfect?BP:AM; ctx.font='bold 10px "Space Mono",monospace'; ctx.textAlign='center';
  ctx.fillText(`√${n}`, cx, H/2-12);
}


/* ════════════════════════════════════════
   SECTION 5 — CONJUGATE CANVAS
════════════════════════════════════════ */
function drawConjugate() {
  const aSlider=document.getElementById('conj-a'), bSlider=document.getElementById('conj-b');
  if (!aSlider) return;
  const a=parseInt(aSlider.value), b=parseInt(bSlider.value);
  document.getElementById('conj-a-val').textContent=a;
  document.getElementById('conj-b-val').textContent=b;

  const canvas=document.getElementById('conjugateCanvas');
  if(!canvas) return;
  const W=canvas.width, H=canvas.height;
  const ctx=canvas.getContext('2d');
  ctx.clearRect(0,0,W,H);

  const sqB=Math.sqrt(b);
  const product=a*a-b;
  const unit=Math.min((W-80)/((a+sqB)*2+2), 40);
  const baseY=H/2;

  // Draw rectangle representing (a+√b)
  const wPlus=(a+sqB)*unit;
  const rectX=40, rectH=50;
  ctx.strokeStyle=BP; ctx.lineWidth=2;
  ctx.strokeRect(rectX, baseY-rectH/2, wPlus, rectH);
  ctx.fillStyle='rgba(78,201,176,.06)'; ctx.fillRect(rectX, baseY-rectH/2, wPlus, rectH);
  ctx.fillStyle=BP; ctx.font='bold 12px "Space Mono",monospace'; ctx.textAlign='center';
  ctx.fillText(`a+√b = ${a}+√${b} ≈ ${(a+sqB).toFixed(3)}`, rectX+wPlus/2, baseY-rectH/2-8);

  // Draw rectangle representing (a-√b)
  const wMinus=(a-sqB)*unit;
  const rectX2=W/2;
  if (wMinus > 0) {
    ctx.strokeStyle=AM; ctx.lineWidth=2;
    ctx.strokeRect(rectX2, baseY-rectH/2, wMinus, rectH);
    ctx.fillStyle='rgba(212,169,74,.06)'; ctx.fillRect(rectX2, baseY-rectH/2, wMinus, rectH);
    ctx.fillStyle=AM; ctx.font='bold 12px "Space Mono",monospace'; ctx.textAlign='center';
    ctx.fillText(`a−√b = ${a}−√${b} ≈ ${(a-sqB).toFixed(3)}`, rectX2+wMinus/2, baseY-rectH/2-8);
  }

  // Product label
  ctx.fillStyle= product>0 ? BP : RUST;
  ctx.font='14px "Space Mono",monospace'; ctx.textAlign='center';
  ctx.fillText(`(${a}+√${b})(${a}−√${b}) = ${a}²−${b} = ${product}`, W/2, baseY+rectH/2+24);
  ctx.fillStyle=T3; ctx.font='11px "Space Mono",monospace';
  ctx.fillText(product>0 ? '✓ Rational result' : 'Negative result (still rational)', W/2, baseY+rectH/2+42);
}


/* ════════════════════════════════════════
   SECTION 5 — RATIONALIZATION CALCULATOR
════════════════════════════════════════ */
function doRationalize() {
  const c=parseFloat(document.getElementById('rat-c').value)||1;
  const a=parseFloat(document.getElementById('rat-a').value)||3;
  const b=parseFloat(document.getElementById('rat-b').value);
  if (isNaN(b)||b<0) { document.getElementById('rat-out').innerHTML=`<span style="color:${RUST}">b must be ≥ 0 (need √b to be real)</span>`; return; }
  const denom=a*a-b;
  if (denom===0) { document.getElementById('rat-out').innerHTML=`<span style="color:${RUST}">a²=b → denominator becomes 0 after rationalization!</span>`; return; }

  const sqB=Math.sqrt(b);
  const numA=c*a, numSqB=c*sqB;
  const bd=Number.isInteger(b)?b:b.toFixed(2), ad=Number.isInteger(a)?a:a.toFixed(2), cd=Number.isInteger(c)?c:c.toFixed(2);

  document.getElementById('rat-out').innerHTML=`
    <div style="background:var(--sur2);border-radius:9px;padding:18px 20px;line-height:2.2;font-size:14.5px;">
      <div style="font-family:'Space Mono',monospace;font-size:10px;color:${T3};margin-bottom:10px;text-transform:uppercase;">Step-by-step</div>
      <strong>Original:</strong> \\(\\dfrac{${cd}}{${ad} + \\sqrt{${bd}}}\\)<br>
      <strong>Step 1 — multiply by conjugate:</strong>
      \\[\\frac{${cd}}{${ad}+\\sqrt{${bd}}} \\times \\frac{${ad}-\\sqrt{${bd}}}{${ad}-\\sqrt{${bd}}}\\]
      <strong>Step 2 — denominator</strong> \\((x+y)(x-y)=x^2-y^2\\):
      \\[\\text{denom} = ${ad}^2 - (\\sqrt{${bd}})^2 = ${a*a} - ${bd} = ${denom}\\]
      <strong>Step 3 — numerator:</strong>
      \\[${cd}(${ad}-\\sqrt{${bd}}) = ${numA} - ${cd}\\sqrt{${bd}}\\]
      <strong style="color:${AM}">Result:</strong>
      \\[\\dfrac{${numA} - ${cd}\\sqrt{${bd}}}{${denom}}\\]
    </div>`;
  typeset(document.getElementById('rat-out'));
}


/* ════════════════════════════════════════
   SECTION 6 — EXPONENT CHART
════════════════════════════════════════ */
let showNeg = false;

function toggleNegExp() {
  showNeg = !showNeg;
  drawExpChart();
}

function drawExpChart() {
  const canvas = document.getElementById('expCanvas');
  if (!canvas) return;
  const W=canvas.width, H=canvas.height;
  const ctx=canvas.getContext('2d');
  ctx.clearRect(0,0,W,H);

  const aSlider=document.getElementById('exp-base');
  const a=parseFloat(aSlider.value)||2;
  document.getElementById('exp-base-val').textContent=a.toFixed(1);

  const PAD_L=54, PAD_R=20, PAD_T=20, PAD_B=40;
  const plotW=W-PAD_L-PAD_R, plotH=H-PAD_T-PAD_B;

  const nMin=showNeg?-4:0, nMax=7;
  const vals=[];
  for (let n=nMin; n<=nMax; n++) vals.push({n, v:Math.pow(a,n)});
  const maxV=Math.max(...vals.map(d=>d.v));
  const barW=plotW/(vals.length+1);

  // Axes
  const baselineY=PAD_T+plotH;
  ctx.strokeStyle=T3; ctx.lineWidth=1;
  ctx.beginPath(); ctx.moveTo(PAD_L,PAD_T); ctx.lineTo(PAD_L,baselineY+1); ctx.lineTo(W-PAD_R,baselineY+1); ctx.stroke();

  // Bars
  vals.forEach((d,i)=>{
    const barH=(d.v/maxV)*plotH*0.92;
    const x=PAD_L+barW*(i+0.5)-barW*0.35;
    const y=baselineY-barH;
    const col = d.n>=0 ? BP : RUST;
    const grad=ctx.createLinearGradient(x, y, x, baselineY);
    grad.addColorStop(0, col);
    grad.addColorStop(1, col+'44');
    ctx.fillStyle=grad;
    ctx.fillRect(x, y, barW*0.7, barH);

    // Value label
    ctx.fillStyle=col; ctx.font='bold 9px "Space Mono",monospace'; ctx.textAlign='center';
    const dispV=d.v>=10000?d.v.toExponential(1):(d.v<0.001?d.v.toExponential(1):fmt(d.v));
    ctx.fillText(dispV, x+barW*0.35, y-4);

    // n label
    ctx.fillStyle=T3; ctx.font='10px "Space Mono",monospace';
    ctx.fillText(`n=${d.n}`, x+barW*0.35, baselineY+14);
  });

  // Y label
  ctx.fillStyle=T3; ctx.font='10px "Space Mono",monospace'; ctx.textAlign='center';
  ctx.save(); ctx.translate(14, H/2); ctx.rotate(-Math.PI/2);
  ctx.fillText(`${a.toFixed(1)}ⁿ`, 0, 0);
  ctx.restore();
}


/* ════════════════════════════════════════
   SECTION 6 — EXPONENT SANDBOX
════════════════════════════════════════ */
function doExpSandbox() {
  const a=parseFloat(document.getElementById('exp-a').value)||2;
  const m=parseFloat(document.getElementById('exp-m').value)||3;
  const n=parseFloat(document.getElementById('exp-n').value)||2;
  const el=document.getElementById('exp-out');
  el.innerHTML=`
    <div style="font-family:'Space Mono',monospace;font-size:12px;line-height:2.3;color:${T2};">
      <span style="color:${T3};font-size:10px;text-transform:uppercase;letter-spacing:.07em;">With a=${a}, m=${m}, n=${n}</span><br>
      \\(a^m \\cdot a^n = a^{m+n}\\): &nbsp; \\(${a}^{${m}} \\cdot ${a}^{${n}} = ${a}^{${m+n}} = ${fmt(Math.pow(a,m+n))}\\)<br>
      \\(a^m / a^n = a^{m-n}\\): &nbsp; \\(${a}^{${m}} / ${a}^{${n}} = ${a}^{${m-n}} = ${fmt(Math.pow(a,m-n))}\\)<br>
      \\((a^m)^n = a^{mn}\\): &nbsp; \\((${a}^{${m}})^{${n}} = ${a}^{${m*n}} = ${fmt(Math.pow(a,m*n))}\\)<br>
      \\(a^0 = 1\\): &nbsp; \\(${a}^0 = 1\\)<br>
      \\(a^{-m} = 1/a^m\\): &nbsp; \\(${a}^{-${m}} = 1/${a}^{${m}} = ${fmt(1/Math.pow(a,m))}\\)<br>
      \\(a^{1/n} = \\sqrt[n]{a}\\): &nbsp; \\(${a}^{1/${n}} = ${fmt(Math.pow(a,1/n))}\\)<br>
      \\(a^{m/n} = (\\sqrt[n]{a})^m\\): &nbsp; \\(${a}^{${m}/${n}} = ${fmt(Math.pow(a,m/n))}\\)
    </div>`;
  typeset(el);
}


/* ════════════════════════════════════════
   INIT ALL ON DOM READY
